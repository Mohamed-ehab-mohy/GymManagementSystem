@using GymManagementSystem.Domain
@model GymManagementSystem.PL.ViewModels.TrainerViewModel

@{
    ViewData["Title"] = "Edit Trainer";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-12 col-xl-10">
            <header class="d-flex justify-content-between mb-4 align-items-center border-bottom pb-3" style="border-color: var(--border-color) !important;">
                <div>
                    <h2 class="display-6 fw-bold mb-1">Edit <span class="text-gradient">Trainer</span></h2>
                    <p class="text-secondary fs-6 mb-0">Update information for @Model.FirstName @Model.LastName.</p>
                </div>
                <a asp-action="Index" class="btn btn-outline-secondary">
                    <i class="bi bi-arrow-left me-2"></i> Back to List
                </a>
            </header>

            <div class="premium-card p-4 p-md-5">
                <form asp-action="Edit" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-4"></div>
                    
                    <input type="hidden" asp-for="Id" />

                    <h5 class="text-primary-theme fw-bold mb-4 border-bottom pb-2" style="border-color: var(--border-color) !important;">
                        <i class="bi bi-person-badge me-2"></i>Personal Details
                    </h5>
                    <div class="row g-4 mb-5">
                        <div class="col-md-6">
                            <label asp-for="FirstName" class="form-label text-secondary fw-semibold"></label>
                            <input asp-for="FirstName" class="form-control form-control-lg premium-input" placeholder="Enter first name" />
                            <span asp-validation-for="FirstName" class="text-danger small mt-1"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="LastName" class="form-label text-secondary fw-semibold"></label>
                            <input asp-for="LastName" class="form-control form-control-lg premium-input" placeholder="Enter last name" />
                            <span asp-validation-for="LastName" class="text-danger small mt-1"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Email" class="form-label text-secondary fw-semibold"></label>
                            <input asp-for="Email" class="form-control form-control-lg premium-input" placeholder="example@email.com" />
                            <span asp-validation-for="Email" class="text-danger small mt-1"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="PhoneNumber" class="form-label text-secondary fw-semibold"></label>
                            <input asp-for="PhoneNumber" class="form-control form-control-lg premium-input" placeholder="01xxxxxxxxx" />
                            <span asp-validation-for="PhoneNumber" class="text-danger small mt-1"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="DateOfBirth" class="form-label text-secondary fw-semibold"></label>
                            <input asp-for="DateOfBirth" class="form-control form-control-lg premium-input" type="date" />
                            <span asp-validation-for="DateOfBirth" class="text-danger small mt-1"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Gender" class="form-label text-secondary fw-semibold"></label>
                            <select asp-for="Gender" class="form-select form-select-lg premium-input">
                                <option value="">-- Select Gender --</option>
                                <option value="Male">Male</option>
                                <option value="Female">Female</option>
                            </select>
                            <span asp-validation-for="Gender" class="text-danger small mt-1"></span>
                        </div>
                    </div>

                    <h5 class="text-primary-theme fw-bold mb-4 border-bottom pb-2" style="border-color: var(--border-color) !important;">
                        <i class="bi bi-geo-alt me-2"></i>Address Information
                    </h5>
                    <div class="row g-4 mb-5">
                        <div class="col-12">
                            <label asp-for="Street" class="form-label text-secondary fw-semibold"></label>
                            <input asp-for="Street" class="form-control form-control-lg premium-input" placeholder="Street name and building number" />
                            <span asp-validation-for="Street" class="text-danger small mt-1"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="City" class="form-label text-secondary fw-semibold"></label>
                            <input asp-for="City" class="form-control form-control-lg premium-input" placeholder="City" />
                            <span asp-validation-for="City" class="text-danger small mt-1"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="State" class="form-label text-secondary fw-semibold"></label>
                            <input asp-for="State" class="form-control form-control-lg premium-input" placeholder="State/Province" />
                            <span asp-validation-for="State" class="text-danger small mt-1"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="ZipCode" class="form-label text-secondary fw-semibold"></label>
                            <input asp-for="ZipCode" class="form-control form-control-lg premium-input" placeholder="Postal Code" />
                            <span asp-validation-for="ZipCode" class="text-danger small mt-1"></span>
                        </div>
                    </div>

                    <h5 class="text-info fw-bold mb-4 border-bottom pb-2" style="border-color: var(--border-color) !important;">
                        <i class="bi bi-briefcase me-2"></i>Employment Information
                    </h5>
                    <div class="row g-4 mb-5">
                        <div class="col-md-6">
                            <label asp-for="Specialty" class="form-label text-secondary fw-semibold"></label>
                            <select asp-for="Specialty" class="form-select form-select-lg premium-input" asp-items="Html.GetEnumSelectList<TrainerSpecialty>()">
                                <option value="">-- Select Specialty --</option>
                            </select>
                            <span asp-validation-for="Specialty" class="text-danger small mt-1"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="HireDate" class="form-label text-secondary fw-semibold"></label>
                            <input asp-for="HireDate" class="form-control form-control-lg premium-input" type="date" />
                            <span asp-validation-for="HireDate" class="text-danger small mt-1"></span>
                        </div>
                    </div>

                    <div class="d-flex justify-content-end gap-3 mt-4 pt-4 border-top" style="border-color: var(--border-color) !important;">
                        <button type="button" class="btn btn-outline-secondary px-4 py-2" onclick="window.history.back()">Cancel</button>
                        <button type="submit" class="btn btn-gradient px-5 py-2 fw-bold">
                            <i class="bi bi-check-circle me-2"></i> Save Changes
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
