@model GymManagementSystem.PL.ViewModels.TrainerViewModel

@{
    ViewData["Title"] = "Trainer Details";
}

<div class="mb-6 flex flex-col md:flex-row md:items-center md:justify-between gap-4">
    <div>
        <h1 class="page-title">Trainer Profile</h1>
        <p class="page-subtitle mt-1">Detailed professional information.</p>
    </div>
    <div class="flex flex-wrap gap-3">
        <a asp-action="Index" class="btn-outline py-2 text-sm">
            <i class="bi bi-list mr-1"></i> Back to List
        </a>
        <a asp-action="Edit" asp-route-id="@Model?.Id" class="btn-primary py-2 text-sm">
            <i class="bi bi-pencil mr-1"></i> Edit Trainer
        </a>
    </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6 items-start">
    <!-- Profile Card -->
    <div class="page-card p-6 flex flex-col items-center text-center">
        <div class="w-28 h-28 rounded-full bg-primary-100 dark:bg-primary-900/30 flex items-center justify-center text-primary-700 dark:text-primary-400 text-4xl font-bold mb-4">
            @Model?.FirstName?.Substring(0, 1)@Model?.LastName?.Substring(0, 1)
        </div>

        <h3 class="text-xl font-bold text-slate-900 dark:text-white mb-2">@Model?.FirstName @Model?.LastName</h3>
        <span class="badge badge-info mb-4">@Model?.Specialty</span>

        <div class="w-full space-y-2 mt-2">
            <button class="w-full btn-outline py-2 text-sm">
                <i class="bi bi-envelope mr-1"></i> Send Email
            </button>
            <button class="w-full btn-outline py-2 text-sm">
                <i class="bi bi-whatsapp mr-1"></i> Message
            </button>
        </div>
    </div>

    <!-- Details Card -->
    <div class="lg:col-span-2 page-card overflow-hidden">
        <div class="p-6">
            <h4 class="text-base font-semibold text-slate-900 dark:text-white mb-4 flex items-center gap-2">
                <i class="bi bi-info-circle-fill text-primary-600 dark:text-primary-400"></i> Professional Information
            </h4>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-y-5 gap-x-8">
                <div>
                    <label class="block text-xs font-medium text-slate-500 dark:text-slate-400 uppercase tracking-wider mb-1">Email</label>
                    <p class="text-sm text-slate-900 dark:text-slate-200">@Model?.Email</p>
                </div>
                <div>
                    <label class="block text-xs font-medium text-slate-500 dark:text-slate-400 uppercase tracking-wider mb-1">Phone</label>
                    <p class="text-sm text-slate-900 dark:text-slate-200">@Model?.PhoneNumber</p>
                </div>
                <div>
                    <label class="block text-xs font-medium text-slate-500 dark:text-slate-400 uppercase tracking-wider mb-1">Date of Birth</label>
                    <p class="text-sm text-slate-900 dark:text-slate-200">@Model?.DateOfBirth.ToString("MMM dd, yyyy")</p>
                </div>
                <div>
                    <label class="block text-xs font-medium text-slate-500 dark:text-slate-400 uppercase tracking-wider mb-1">Gender</label>
                    <p class="text-sm text-slate-900 dark:text-slate-200">@Model?.Gender</p>
                </div>
                <div class="md:col-span-2">
                    <label class="block text-xs font-medium text-slate-500 dark:text-slate-400 uppercase tracking-wider mb-1">Address</label>
                    <p class="text-sm text-slate-900 dark:text-slate-200">@Model?.Street, @Model?.City, @Model?.State @Model?.ZipCode</p>
                </div>
                <div class="md:col-span-2">
                    <label class="block text-xs font-medium text-slate-500 dark:text-slate-400 uppercase tracking-wider mb-1">Hire Date</label>
                    <p class="text-sm font-semibold text-primary-600 dark:text-primary-400">@Model?.HireDate.ToString("MMMM dd, yyyy")</p>
                </div>
            </div>
        </div>
    </div>
</div>
