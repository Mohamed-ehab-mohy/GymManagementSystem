@{
    ViewData["Title"] = "Trainers";
}

<div class="mb-6 flex flex-col md:flex-row md:items-center md:justify-between gap-4">
    <div>
        <h1 class="page-title">Trainers</h1>
        <p class="page-subtitle mt-1">Manage gym trainers and their specializations.</p>
    </div>
    <a asp-action="Create" class="btn-primary py-2 text-sm">
        <i class="bi bi-person-plus mr-1"></i> Add Trainer
    </a>
</div>

<div class="page-card">
    <div class="overflow-x-auto">
        <table id="dataTable" class="data-table">
            <thead>
                <tr>
                    <th>Trainer Info</th>
                    <th>Specialization</th>
                    <th>Contact</th>
                    <th class="text-right">Actions</th>
                </tr>
            </thead>
            <tbody>
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.datatables.net/2.0.8/js/dataTables.min.js"></script>
    <script>
        $(document).ready(function () {
            $('#dataTable').DataTable({
                processing: true,
                serverSide: true,
                ajax: { url: '@Url.Action("DataTableData", "Trainers")', type: 'POST' },
                pageLength: 10,
                lengthMenu: [10, 25, 50, 100],
                columns: [
                    { data: 'name', name: 'FirstName', orderable: true, className: 'py-3 px-4 align-middle font-semibold text-slate-900 dark:text-white' },
                    { data: 'specialty', name: 'Specialty', orderable: true, className: 'py-3 px-4 align-middle' },
                    { data: 'contact', name: '', orderable: false, className: 'py-3 px-4 align-middle text-slate-600 dark:text-slate-400' },
                    { data: 'actions', name: '', orderable: false, className: 'py-3 px-4 text-right align-middle' }
                ],
                language: { search: "_INPUT_", searchPlaceholder: "Search trainers..." },
                layout: { topStart: 'pageLength', topEnd: 'search', bottomStart: 'info', bottomEnd: 'paging' },
                drawCallback: function() {
                    $('#dataTable tbody tr').addClass('group');
                    $('#dataTable tbody tr').each(function() {
                        var specTd = $(this).find('td:eq(1)');
                        if (specTd.length) {
                            var text = specTd.text().trim();
                            if (text && !specTd.find('span').length) {
                                specTd.html(`<span class="badge badge-info">${text}</span>`);
                            }
                        }
                    });
                    $('#dataTable tbody .btn').each(function() {
                        var $btn = $(this);
                        if ($btn.hasClass('btn-primary') || $btn.text().includes('Edit')) {
                            $btn.removeClass('btn btn-primary btn-sm').addClass('btn-primary text-xs py-1.5 px-3 mr-2');
                        } else if ($btn.hasClass('btn-info') || $btn.text().includes('Details')) {
                            $btn.removeClass('btn btn-info btn-sm').addClass('btn-outline text-xs py-1.5 px-3 mr-2');
                        } else if ($btn.hasClass('btn-danger') || $btn.text().includes('Delete')) {
                            $btn.removeClass('btn btn-danger btn-sm').addClass('btn-danger text-xs py-1.5 px-3');
                        }
                    });
                }
            });

            setTimeout(() => {
                $('.dt-container').addClass('flex flex-col w-full');
                $('.dt-layout-row').addClass('flex justify-between items-center p-4 flex-wrap gap-4 border-b border-slate-200 dark:border-slate-700').first().removeClass('border-b');
                $('.dt-layout-row:last-child').removeClass('border-b').addClass('border-t border-slate-200 dark:border-slate-700');
                $('.dt-search input').addClass('form-input w-full md:w-64');
                $('.dt-length select').addClass('form-select');
                $('.dt-paging').addClass('flex gap-1');
                $('.dt-paging-button').addClass('px-3 py-1.5 rounded-lg border border-slate-200 dark:border-slate-700 hover:bg-slate-100 dark:hover:bg-slate-700 cursor-pointer text-sm text-slate-500 dark:text-slate-400 transition-colors bg-white dark:bg-transparent');
                $('.dt-paging-button.current').removeClass('bg-white dark:bg-transparent border-slate-200 dark:border-slate-700 text-slate-500 dark:text-slate-400').addClass('bg-primary-50 dark:bg-primary-900/20 border-primary-300 dark:border-primary-700 text-primary-700 dark:text-primary-400 font-semibold');
                $('.dt-info').addClass('text-sm text-slate-500 dark:text-slate-400');
            }, 100);
        });
    </script>
}
