@{
    ViewData["Title"] = "Trainers";
}

<div class="container py-4">
    <header class="d-flex justify-content-between mb-5 align-items-center flex-wrap gap-3 border-bottom pb-4" style="border-color: var(--border-color) !important;">
        <div>
            <h2 class="display-5 fw-bold mb-2">Professional <span class="text-gradient">Trainers</span></h2>
            <p class="text-secondary fs-5 mb-0">Manage gym trainers and their specializations.</p>
        </div>
        <div>
            <a asp-action="Create" class="btn btn-gradient btn-lg">
                <i class="bi bi-person-plus me-2"></i> Add New Trainer
            </a>
        </div>
    </header>

    <div class="premium-card p-4">
        <div class="table-responsive">
            <table id="dataTable" class="table table-hover align-middle mb-0">
                <thead>
                    <tr style="border-bottom: 2px solid var(--border-color);">
                        <th class="py-3 px-4 fw-bold">Trainer Info</th>
                        <th class="py-3 px-4 fw-bold">Specialization</th>
                        <th class="py-3 px-4 fw-bold">Contact</th>
                        <th class="py-3 px-4 fw-bold text-end">Actions</th>
                    </tr>
                </thead>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#dataTable').DataTable({
                processing: true,
                serverSide: true,
                ajax: { url: '@Url.Action("DataTableData", "Trainers")', type: 'POST' },
                pageLength: 10,
                lengthMenu: [10, 25, 50, 100],
                columns: [
                    { data: 'name', name: 'FirstName', orderable: true },
                    { data: 'specialty', name: 'Specialty', orderable: true },
                    { data: 'contact', name: '', orderable: false },
                    { data: 'actions', name: '', orderable: false }
                ],
                language: { search: "Search:" }
            });
        });
    </script>
}
