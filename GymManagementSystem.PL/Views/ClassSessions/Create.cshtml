@model GymManagementSystem.PL.ViewModels.CreateSessionViewModel

@{
    ViewData["Title"] = "Schedule Session";
}

<div class="mb-6 flex flex-col md:flex-row md:items-center md:justify-between gap-4">
    <div>
        <h2 class="text-3xl font-display font-bold text-zinc-900 dark:text-white">Schedule <span class="text-transparent bg-clip-text bg-gradient-to-r from-neon-cyan to-neon-green">Session</span></h2>
        <p class="text-zinc-500 dark:text-zinc-400 mt-1">Create a new training class.</p>
    </div>
    <a asp-action="Index" class="btn-outline">
        <i class="bi bi-arrow-left mr-2"></i> Back to Schedule
    </a>
</div>

<div class="glass-card p-6 md:p-8 max-w-4xl mx-auto">
    <form asp-action="Create" method="post">
        <div asp-validation-summary="ModelOnly" class="text-red-500 mb-4 bg-red-50 dark:bg-red-500/10 p-3 rounded-lg text-sm border border-red-200 dark:border-red-500/20"></div>

        <div class="mb-8">
            <h5 class="flex items-center text-lg font-bold text-zinc-900 dark:text-white mb-4 pb-2 border-b border-zinc-200 dark:border-zinc-800">
                <i class="bi bi-calendar-event text-neon-cyan mr-2"></i> Session Details
            </h5>
            
            <div class="mb-6">
                <label asp-for="Description" class="form-label"></label>
                <input asp-for="Description" class="form-input" placeholder="e.g., Morning Yoga, HIIT Training" />
                <span asp-validation-for="Description" class="text-red-500 text-xs mt-1 block"></span>
            </div>
            
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
                <div>
                    <label asp-for="StartDate" class="form-label"></label>
                    <input asp-for="StartDate" class="form-input" />
                    <span asp-validation-for="StartDate" class="text-red-500 text-xs mt-1 block"></span>
                </div>
                <div>
                    <label asp-for="EndDate" class="form-label"></label>
                    <input asp-for="EndDate" class="form-input" />
                    <span asp-validation-for="EndDate" class="text-red-500 text-xs mt-1 block"></span>
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                <div>
                    <label asp-for="Capacity" class="form-label"></label>
                    <input asp-for="Capacity" class="form-input" type="number" min="1" max="25" />
                    <span asp-validation-for="Capacity" class="text-red-500 text-xs mt-1 block"></span>
                </div>
                <div>
                    <label asp-for="TrainerId" class="form-label"></label>
                    <select asp-for="TrainerId" asp-items="Model.TrainersList" class="form-input">
                        <option value="">-- Select Trainer --</option>
                    </select>
                    <span asp-validation-for="TrainerId" class="text-red-500 text-xs mt-1 block"></span>
                </div>
                <div>
                    <label asp-for="CategoryId" class="form-label"></label>
                    <select asp-for="CategoryId" asp-items="Model.CategoriesList" class="form-input">
                        <option value="">-- Select Category --</option>
                    </select>
                    <span asp-validation-for="CategoryId" class="text-red-500 text-xs mt-1 block"></span>
                </div>
            </div>
        </div>

        <div class="flex justify-end gap-3 mt-8 pt-6 border-t border-zinc-200 dark:border-zinc-800">
            <button type="button" class="btn-outline" onclick="window.history.back()">Cancel</button>
            <button type="submit" class="btn-primary px-8">
                <i class="bi bi-check-circle mr-2"></i> Schedule Class
            </button>
        </div>
    </form>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
