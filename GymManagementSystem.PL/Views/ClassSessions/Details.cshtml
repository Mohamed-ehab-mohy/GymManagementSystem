@model GymManagementSystem.PL.ViewModels.SessionViewModel

@{
    ViewData["Title"] = "Session Details";
}

<div class="mb-6 flex flex-col md:flex-row md:items-center md:justify-between gap-4">
    <div>
        <h1 class="page-title">Session Details</h1>
        <p class="page-subtitle mt-1">Full information about the class session.</p>
    </div>
    <div class="flex flex-wrap gap-3">
        <a asp-action="Index" class="btn-outline py-2 text-sm">
            <i class="bi bi-list mr-1"></i> Back to List
        </a>
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn-primary py-2 text-sm">
            <i class="bi bi-pencil mr-1"></i> Edit Session
        </a>
    </div>
</div>

<div class="page-card overflow-hidden">
    <div class="grid grid-cols-1 md:grid-cols-3">
        <div class="p-8 flex flex-col items-center justify-center text-center bg-slate-50 dark:bg-slate-800/50 border-b md:border-b-0 md:border-r border-slate-200 dark:border-slate-700">
            <div class="w-24 h-24 rounded-full bg-primary-100 dark:bg-primary-900/30 flex items-center justify-center text-primary-600 dark:text-primary-400 text-4xl mb-4">
                <i class="bi bi-stopwatch"></i>
            </div>
            <h4 class="text-xl font-bold text-slate-900 dark:text-white mb-2">@Model.Description</h4>

            @{
                string badgeClass = Model.Status == "Upcoming" ? "badge-success" :
                                  Model.Status == "Ongoing" ? "badge-warning" : "badge-neutral";
            }
            <span class="badge @badgeClass mb-3">@Model.Status</span>
            <span class="text-xs text-slate-500 dark:text-slate-400">Capacity: @Model.Capacity</span>
        </div>

        <div class="col-span-2 p-8">
            <h4 class="text-base font-semibold text-slate-900 dark:text-white mb-5 flex items-center gap-2">
                <i class="bi bi-info-circle-fill text-primary-600 dark:text-primary-400"></i> Session Information
            </h4>

            <dl class="grid grid-cols-1 sm:grid-cols-2 gap-y-5 gap-x-6">
                <div>
                    <dt class="text-xs font-medium text-slate-500 dark:text-slate-400 uppercase tracking-wider mb-1">Trainer</dt>
                    <dd class="text-sm font-medium text-slate-900 dark:text-slate-200 flex items-center gap-2">
                        <i class="bi bi-person-circle text-slate-400"></i> @Model.TrainerName
                    </dd>
                </div>
                <div>
                    <dt class="text-xs font-medium text-slate-500 dark:text-slate-400 uppercase tracking-wider mb-1">Category</dt>
                    <dd class="text-sm font-medium text-slate-900 dark:text-slate-200 flex items-center gap-2">
                        <span class="w-2 h-2 rounded-full bg-primary-500 inline-block"></span> @Model.CategoryName
                    </dd>
                </div>
                <div>
                    <dt class="text-xs font-medium text-slate-500 dark:text-slate-400 uppercase tracking-wider mb-1">Date</dt>
                    <dd class="text-sm font-medium text-slate-900 dark:text-slate-200">@Model.DateDisplay</dd>
                </div>
                <div>
                    <dt class="text-xs font-medium text-slate-500 dark:text-slate-400 uppercase tracking-wider mb-1">Time</dt>
                    <dd class="text-sm font-medium text-slate-900 dark:text-slate-200">@Model.TimeRangeDisplay</dd>
                </div>
                <div class="sm:col-span-2 border-t border-slate-200 dark:border-slate-700 pt-5 grid grid-cols-2 gap-4">
                    <div>
                        <dt class="text-xs font-medium text-slate-500 dark:text-slate-400 uppercase tracking-wider mb-1">Duration</dt>
                        <dd class="text-lg font-bold text-slate-900 dark:text-white">@Model.Duration.ToString(@"h\h\ m\m")</dd>
                    </div>
                    <div>
                        <dt class="text-xs font-medium text-slate-500 dark:text-slate-400 uppercase tracking-wider mb-1">Available Slots</dt>
                        <dd class="text-lg font-bold @(Model.AvailableSlots > 0 ? "text-emerald-600 dark:text-emerald-400" : "text-red-600 dark:text-red-400")">@Model.AvailableSlots</dd>
                    </div>
                </div>
            </dl>
        </div>
    </div>
</div>
