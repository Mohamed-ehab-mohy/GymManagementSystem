@model GymManagementSystem.PL.ViewModels.ClassSessionViewModel

@{
    ViewData["Title"] = "Class Session Details";
}

<div class="container py-4">
    <header class="d-flex justify-content-between mb-5 align-items-center border-bottom pb-4" style="border-color: var(--border-color) !important;">
        <div>
            <h2 class="display-5 fw-bold mb-2">Session <span class="text-gradient">Details</span></h2>
            <p class="text-secondary fs-5 mb-0">Full information about the class session.</p>
        </div>
        <div>
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-gradient btn-lg me-2"><i class="bi bi-pencil me-1"></i> Edit</a>
            <a asp-action="Index" class="btn btn-outline-secondary btn-lg"><i class="bi bi-arrow-left me-1"></i> Back to List</a>
        </div>
    </header>

    <div class="premium-card p-4">
        <div class="row g-4">
            <div class="col-md-4 text-center">
                <div class="bg-primary text-white rounded-circle d-flex justify-content-center align-items-center mx-auto" style="width: 120px; height: 120px; font-size: 3rem; background: linear-gradient(135deg, var(--primary-color), var(--secondary-color)) !important;">
                    <i class="bi bi-stopwatch"></i>
                </div>
                <h4 class="mt-3 fw-bold">@Model.Name</h4>
                <small class="text-secondary">Capacity: @Model.Capacity</small>
            </div>
            <div class="col-md-8">
                <dl class="row">
                    <dt class="col-sm-4 fw-bold">Trainer</dt>
                    <dd class="col-sm-8">@Model.TrainerName</dd>

                    <dt class="col-sm-4 fw-bold">Category</dt>
                    <dd class="col-sm-8">@Model.CategoryName</dd>

                    <dt class="col-sm-4 fw-bold">Schedule</dt>
                    <dd class="col-sm-8">
                        @Model.StartTime.ToString("MMM dd, yyyy hh:mm tt") – @Model.EndTime.ToString("hh:mm tt")
                    </dd>
                </dl>
            </div>
        </div>
    </div>
</div>
