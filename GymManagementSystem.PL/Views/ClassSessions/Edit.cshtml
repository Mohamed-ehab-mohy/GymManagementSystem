@model GymManagementSystem.PL.ViewModels.ClassSessionViewModel

@{
    ViewData["Title"] = "Edit Session";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-12 col-xl-8">
            <header class="d-flex justify-content-between mb-4 align-items-center border-bottom pb-3" style="border-color: var(--border-color) !important;">
                <div>
                    <h2 class="display-6 fw-bold mb-1">Edit <span class="text-gradient">Session</span></h2>
                    <p class="text-secondary fs-6 mb-0">Update schedule and details for @Model.Name.</p>
                </div>
                <a asp-action="Index" class="btn btn-outline-secondary">
                    <i class="bi bi-arrow-left me-2"></i> Back to Schedule
                </a>
            </header>

            <div class="premium-card p-4 p-md-5">
                <form asp-action="Edit" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-4"></div>
                    
                    <input type="hidden" asp-for="Id" />

                    <div class="row g-4 mb-4">
                        <div class="col-12">
                            <label asp-for="Name" class="form-label text-secondary fw-semibold"></label>
                            <input asp-for="Name" class="form-control form-control-lg premium-input" placeholder="e.g., Morning Yoga, HIIT Training" />
                            <span asp-validation-for="Name" class="text-danger small mt-1"></span>
                        </div>
                        
                        <div class="col-md-6">
                            <label asp-for="StartTime" class="form-label text-secondary fw-semibold"></label>
                            <input asp-for="StartTime" class="form-control form-control-lg premium-input" />
                            <span asp-validation-for="StartTime" class="text-danger small mt-1"></span>
                        </div>
                        
                        <div class="col-md-6">
                            <label asp-for="EndTime" class="form-label text-secondary fw-semibold"></label>
                            <input asp-for="EndTime" class="form-control form-control-lg premium-input" />
                            <span asp-validation-for="EndTime" class="text-danger small mt-1"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Capacity" class="form-label text-secondary fw-semibold"></label>
                            <input asp-for="Capacity" class="form-control form-control-lg premium-input" type="number" min="1" max="100" />
                            <span asp-validation-for="Capacity" class="text-danger small mt-1"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="TrainerId" class="form-label text-secondary fw-semibold"></label>
                            <select asp-for="TrainerId" asp-items="Model.TrainersList" class="form-select form-select-lg premium-input">
                                <option value="">-- Select Trainer --</option>
                            </select>
                            <span asp-validation-for="TrainerId" class="text-danger small mt-1"></span>
                        </div>
                    </div>

                    <div class="d-flex justify-content-end gap-3 mt-5 pt-4 border-top" style="border-color: var(--border-color) !important;">
                        <button type="button" class="btn btn-outline-secondary px-4 py-2" onclick="window.history.back()">Cancel</button>
                        <button type="submit" class="btn btn-gradient px-5 py-2 fw-bold">
                            <i class="bi bi-check-circle me-2"></i> Save Changes
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
