@model GymManagementSystem.PL.ViewModels.UpdateSessionViewModel

@{
    ViewData["Title"] = "Edit Session";
}

<div class="mb-6 flex flex-col md:flex-row md:items-center md:justify-between gap-4">
    <div>
        <h1 class="page-title">Edit Session</h1>
        <p class="page-subtitle mt-1">Update schedule and details.</p>
    </div>
    <a asp-action="Index" class="btn-outline">
        <i class="bi bi-arrow-left mr-1"></i> Back to Schedule
    </a>
</div>

<div class="page-card p-6 md:p-8 max-w-4xl mx-auto">
    <form asp-action="Edit" method="post">
        <div asp-validation-summary="ModelOnly" class="text-red-600 dark:text-red-400 text-sm mb-4 bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 p-3 rounded-lg"></div>
        <input type="hidden" asp-for="Id" />

        <div class="mb-6">
            <h3 class="text-base font-semibold text-slate-900 dark:text-white mb-4 flex items-center gap-2">
                <i class="bi bi-calendar-event text-primary-600 dark:text-primary-400"></i> Session Details
            </h3>

            <div class="mb-4">
                <label asp-for="Description" class="form-label"></label>
                <input asp-for="Description" class="form-input" placeholder="e.g., Morning Yoga, HIIT Training" />
                <span asp-validation-for="Description" class="text-red-500 text-xs mt-1 block"></span>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
                <div>
                    <label asp-for="StartDate" class="form-label"></label>
                    <input asp-for="StartDate" class="form-input" />
                    <span asp-validation-for="StartDate" class="text-red-500 text-xs mt-1 block"></span>
                </div>
                <div>
                    <label asp-for="EndDate" class="form-label"></label>
                    <input asp-for="EndDate" class="form-input" />
                    <span asp-validation-for="EndDate" class="text-red-500 text-xs mt-1 block"></span>
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div>
                    <label asp-for="Capacity" class="form-label"></label>
                    <input asp-for="Capacity" class="form-input" type="number" min="1" max="25" />
                    <span asp-validation-for="Capacity" class="text-red-500 text-xs mt-1 block"></span>
                </div>
                <div>
                    <label asp-for="TrainerId" class="form-label"></label>
                    <select asp-for="TrainerId" asp-items="Model.TrainersList" class="form-select">
                        <option value="">Select trainer</option>
                    </select>
                    <span asp-validation-for="TrainerId" class="text-red-500 text-xs mt-1 block"></span>
                </div>
            </div>
        </div>

        <div class="flex justify-end gap-3 mt-6 pt-6 border-t border-slate-200 dark:border-slate-700">
            <button type="button" class="btn-outline" onclick="window.history.back()">Cancel</button>
            <button type="submit" class="btn-primary">
                <i class="bi bi-check-circle mr-1"></i> Save Changes
            </button>
        </div>
    </form>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
