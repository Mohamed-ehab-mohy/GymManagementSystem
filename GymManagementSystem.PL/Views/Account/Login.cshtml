@model LoginViewModel
@{
    ViewData["Title"] = "Login";
}

<div class="row justify-content-center">
    <div class="col-md-6 col-lg-4">
        <div class="premium-card p-5">
            <h2 class="display-6 fw-bold mb-2 text-center">Welcome <span class="text-gradient">Back</span></h2>
            <p class="text-secondary text-center mb-4 fs-5">Sign in to manage your gym system</p>

            <form method="post" asp-action="Login" asp-controller="Account">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="mb-3">
                    <label asp-for="Email" class="form-label fs-5"></label>
                    <input asp-for="Email" class="form-control form-control-lg" autofocus />
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="Password" class="form-label fs-5"></label>
                    <input asp-for="Password" class="form-control form-control-lg" />
                    <span asp-validation-for="Password" class="text-danger"></span>
                </div>

                <button type="submit" class="btn btn-gradient btn-lg w-100 mb-3 py-3 fs-5">Sign In</button>

                <p class="text-center mb-3">
                    <a asp-action="ForgotPassword" asp-controller="Account" class="text-primary-theme small">Forgot Password?</a>
                </p>

                <div class="text-center mb-3">
                    <span class="text-secondary">or</span>
                </div>

                <a asp-action="GoogleLogin" asp-controller="Account" class="btn btn-outline-light btn-lg w-100 mb-3 py-3 fs-5">
                    <i class="bi bi-google me-2"></i>Sign in with Google
                </a>

                <p class="text-center text-secondary mb-2">
                    Don't have an account? <a asp-action="Register" asp-controller="Account" class="text-primary-theme">Register</a>
                </p>
                <p class="text-center text-secondary mb-0">
                    <a asp-action="Index" asp-controller="Home" class="text-primary-theme">Back to Home</a>
                </p>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
