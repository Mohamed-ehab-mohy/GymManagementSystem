@{
    ViewData["Title"] = "Access Denied";
}

<div class="flex items-center justify-center min-h-[70vh]">
    <div class="page-card p-10 max-w-lg w-full text-center">
        <div class="w-20 h-20 mx-auto rounded-full bg-red-50 dark:bg-red-900/20 flex items-center justify-center text-red-500 dark:text-red-400 text-4xl mb-6 border border-red-200 dark:border-red-800">
            <i class="bi bi-shield-lock-fill"></i>
        </div>

        <h2 class="text-2xl font-bold text-slate-900 dark:text-white mb-2">Access Denied</h2>
        <p class="text-slate-500 dark:text-slate-400 mb-8 text-sm">You don't have permission to access this page. Contact an administrator if you believe this is an error.</p>

        <div class="flex flex-col gap-3">
            <a asp-action="Index" asp-controller="Home" class="btn-primary w-full justify-center py-2.5">
                <i class="bi bi-house mr-2"></i> Go to Dashboard
            </a>
            <a href="javascript:history.back()" class="btn-outline w-full justify-center py-2.5">
                <i class="bi bi-arrow-left mr-2"></i> Go Back
            </a>
        </div>
    </div>
</div>
