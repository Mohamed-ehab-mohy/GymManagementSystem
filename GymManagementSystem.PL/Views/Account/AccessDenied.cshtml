@{
    ViewData["Title"] = "Access Denied";
}

<div class="flex items-center justify-center min-h-[70vh]">
    <div class="glass-card p-10 max-w-lg w-full text-center relative overflow-hidden">
        <div class="absolute top-0 left-0 w-full h-2 bg-gradient-to-r from-red-500 to-red-600"></div>
        
        <div class="w-24 h-24 mx-auto rounded-full bg-red-500/10 flex items-center justify-center text-red-500 text-5xl mb-6 shadow-[0_0_20px_rgba(239,68,68,0.3)] border border-red-500/20">
            <i class="bi bi-shield-lock-fill"></i>
        </div>
        
        <h2 class="text-3xl font-display font-bold text-zinc-900 dark:text-white mb-3">Access Denied</h2>
        <p class="text-lg text-zinc-500 dark:text-zinc-400 mb-8">You do not have permission to access this resource. Please contact an administrator if you believe this is an error.</p>
        
        <div class="flex flex-col gap-3">
            <a asp-action="Index" asp-controller="Home" class="btn-primary w-full justify-center py-3 shadow-[0_0_15px_rgba(57,255,20,0.3)]">
                Return Home
            </a>
            <a href="javascript:history.back()" class="btn-outline border-zinc-300 dark:border-zinc-700 w-full justify-center py-3 text-sm">
                Go Back
            </a>
        </div>
    </div>
</div>
