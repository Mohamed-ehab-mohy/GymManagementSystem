@model ForgotPasswordViewModel
@{
    ViewData["Title"] = "Forgot Password";
}

<div class="flex items-center justify-center min-h-[75vh]">
    <div class="w-full max-w-md p-4">
        <div class="page-card p-8 md:p-10">
            <div class="text-center mb-8">
                <div class="inline-flex items-center justify-center w-14 h-14 rounded-xl bg-primary-100 dark:bg-primary-900/30 mb-4">
                    <i class="bi bi-shield-lock text-2xl text-primary-600 dark:text-primary-400"></i>
                </div>
                <h2 class="text-2xl font-bold text-slate-900 dark:text-white">Forgot password?</h2>
                <p class="text-slate-500 dark:text-slate-400 mt-1.5 text-sm">Enter your email and we'll send you a reset code.</p>
            </div>

            <form method="post" asp-action="ForgotPassword">
                <div asp-validation-summary="ModelOnly" class="text-red-600 dark:text-red-400 text-sm mb-4 bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 p-3 rounded-lg"></div>

                <div class="mb-6">
                    <label asp-for="Email" class="form-label"></label>
                    <input asp-for="Email" class="form-input" autofocus placeholder="you@example.com" />
                    <span asp-validation-for="Email" class="text-red-500 text-xs mt-1 block"></span>
                </div>

                <button type="submit" class="btn-primary w-full py-2.5">
                    Send Reset Code
                </button>

                <div class="mt-6 text-center">
                    <a asp-action="Login" class="text-sm font-medium text-slate-500 dark:text-slate-400 hover:text-slate-700 dark:hover:text-slate-300 transition-colors">
                        <i class="bi bi-arrow-left mr-1"></i> Back to sign in
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
