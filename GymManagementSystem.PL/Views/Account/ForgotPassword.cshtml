@model ForgotPasswordViewModel
@{
    ViewData["Title"] = "Forgot Password";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en" x-data="{ darkMode: localStorage.getItem('gympro-theme') !== 'light' }" x-bind:class="{ 'dark': darkMode }">
<head>
    <script>
        if (localStorage.getItem('gympro-theme') === 'light' || (!('gympro-theme' in localStorage) && !window.matchMedia('(prefers-color-scheme: dark)').matches)) {
            document.documentElement.classList.remove('dark')
        } else {
            document.documentElement.classList.add('dark')
        }
    </script>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Forgot Password — GymPro</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Outfit:wght@500;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/css/style.css" asp-append-version="true" />
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
</head>
<body class="bg-zinc-50 dark:bg-gym-darker text-zinc-900 dark:text-zinc-100 font-sans min-h-screen flex items-center justify-center relative overflow-hidden transition-colors duration-300">
    
    <button @@click="darkMode = !darkMode; localStorage.setItem('gympro-theme', darkMode ? 'dark' : 'light')" class="absolute top-6 right-6 p-2 text-zinc-500 hover:text-zinc-900 dark:text-zinc-400 dark:hover:text-white transition-colors bg-white dark:bg-zinc-800 rounded-full shadow-sm dark:shadow-none border border-zinc-200 dark:border-zinc-700">
        <i class="bi bi-moon-fill" x-show="!darkMode"></i>
        <i class="bi bi-brightness-high-fill text-yellow-400" x-show="darkMode" style="display: none;"></i>
    </button>

    <div class="absolute -top-[20%] -left-[10%] w-[50%] h-[50%] rounded-full bg-neon-orange/10 dark:bg-neon-orange/5 blur-[120px] pointer-events-none"></div>

    <div class="w-full max-w-md p-4 relative z-10">
        <div class="glass-card p-8 md:p-10 border-zinc-200 dark:border-gym-border shadow-lg dark:shadow-glass">
            <div class="text-center mb-8">
                <div class="inline-flex items-center justify-center w-16 h-16 rounded-2xl bg-neon-orange/10 border border-neon-orange/30 shadow-[0_0_15px_rgba(255,94,0,0.2)] mb-4">
                    <i class="bi bi-shield-lock text-3xl text-neon-orange"></i>
                </div>
                <h2 class="text-3xl font-display font-bold text-zinc-900 dark:text-white">Forgot <span class="text-transparent bg-clip-text bg-gradient-to-r from-neon-orange to-red-500">Password</span></h2>
                <p class="text-zinc-500 dark:text-zinc-400 mt-2 font-medium">Enter your email to receive an OTP.</p>
            </div>

            <form method="post" asp-action="ForgotPassword">
                <div asp-validation-summary="ModelOnly" class="text-red-500 text-sm mb-4 bg-red-50 dark:bg-red-500/10 border border-red-200 dark:border-red-500/20 p-3 rounded-lg font-medium"></div>

                <div class="mb-6">
                    <label asp-for="Email" class="form-label"></label>
                    <input asp-for="Email" class="form-input" autofocus placeholder="you@gym.com" />
                    <span asp-validation-for="Email" class="text-red-500 text-xs mt-1 block"></span>
                </div>

                <button type="submit" class="btn-accent w-full py-3 text-lg shadow-[0_0_15px_rgba(255,94,0,0.3)]">
                    Send OTP
                </button>

                <div class="mt-8 text-center">
                    <p class="text-zinc-500 dark:text-zinc-400 text-sm font-medium">
                        <a asp-action="Login" class="text-neon-orange hover:text-[#e65400] font-semibold"><i class="bi bi-arrow-left mr-1"></i> Back to Sign In</a>
                    </p>
                </div>
            </form>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <partial name="_ValidationScriptsPartial" />
</body>
</html>
