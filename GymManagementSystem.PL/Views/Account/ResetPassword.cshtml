@model ResetPasswordViewModel
@{
    ViewData["Title"] = "Reset Password";
}

<div class="flex items-center justify-center min-h-[75vh]">
    <div class="w-full max-w-md p-4">
        <div class="page-card p-8 md:p-10">
            <div class="text-center mb-8">
                <div class="inline-flex items-center justify-center w-14 h-14 rounded-xl bg-primary-100 dark:bg-primary-900/30 mb-4">
                    <i class="bi bi-key text-2xl text-primary-600 dark:text-primary-400"></i>
                </div>
                <h2 class="text-2xl font-bold text-slate-900 dark:text-white">Reset password</h2>
                <p class="text-slate-500 dark:text-slate-400 mt-1.5 text-sm">Enter the code sent to your email and set a new password.</p>
            </div>

            <form method="post" asp-action="ResetPassword">
                <div asp-validation-summary="ModelOnly" class="text-red-600 dark:text-red-400 text-sm mb-4 bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 p-3 rounded-lg"></div>

                <input type="hidden" asp-for="Email" />

                <div class="mb-4">
                    <label asp-for="Otp" class="form-label">Verification Code</label>
                    <input asp-for="Otp" class="form-input text-center tracking-[0.25em] text-lg font-bold" autofocus placeholder="000000" />
                    <span asp-validation-for="Otp" class="text-red-500 text-xs mt-1 block"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="NewPassword" class="form-label"></label>
                    <input asp-for="NewPassword" type="password" class="form-input" placeholder="New password" />
                    <span asp-validation-for="NewPassword" class="text-red-500 text-xs mt-1 block"></span>
                </div>

                <div class="mb-6">
                    <label asp-for="ConfirmPassword" class="form-label"></label>
                    <input asp-for="ConfirmPassword" type="password" class="form-input" placeholder="Confirm password" />
                    <span asp-validation-for="ConfirmPassword" class="text-red-500 text-xs mt-1 block"></span>
                </div>

                <button type="submit" class="btn-primary w-full py-2.5">
                    Reset Password
                </button>

                <div class="mt-6 text-center">
                    <a asp-action="Login" class="text-sm font-medium text-slate-500 dark:text-slate-400 hover:text-slate-700 dark:hover:text-slate-300 transition-colors">
                        <i class="bi bi-arrow-left mr-1"></i> Back to sign in
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
