@model ResetPasswordViewModel
@{
    ViewData["Title"] = "Reset Password";
}

<div class="row justify-content-center">
    <div class="col-md-6 col-lg-4">
        <div class="premium-card p-5">
            <h2 class="display-6 fw-bold mb-2 text-center">Reset <span class="text-gradient">Password</span></h2>
            <p class="text-secondary text-center mb-4">Enter the OTP sent to your email</p>

            <form method="post" asp-action="ResetPassword">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <input type="hidden" asp-for="Email" />

                <div class="mb-3">
                    <label asp-for="Otp" class="form-label fs-5">OTP Code</label>
                    <input asp-for="Otp" class="form-control form-control-lg" autofocus placeholder="000000" />
                    <span asp-validation-for="Otp" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="NewPassword" class="form-label fs-5"></label>
                    <input asp-for="NewPassword" class="form-control form-control-lg" />
                    <span asp-validation-for="NewPassword" class="text-danger"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="ConfirmPassword" class="form-label fs-5"></label>
                    <input asp-for="ConfirmPassword" class="form-control form-control-lg" />
                    <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                </div>

                <button type="submit" class="btn btn-gradient btn-lg w-100 mb-3 py-3 fs-5">Reset Password</button>

                <p class="text-center text-secondary mb-0">
                    <a asp-action="Login" asp-controller="Account" class="text-primary-theme">Back to Sign In</a>
                </p>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
