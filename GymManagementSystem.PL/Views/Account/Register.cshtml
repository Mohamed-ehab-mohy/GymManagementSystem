@model RegisterViewModel
@{
    ViewData["Title"] = "Create Account";
}

<div class="flex items-center justify-center min-h-[75vh]">
    <div class="w-full max-w-xl p-4">
        <div class="page-card p-8 md:p-10 my-8">
            <div class="text-center mb-8">
                <div class="inline-flex items-center justify-center w-14 h-14 rounded-xl bg-primary-100 dark:bg-primary-900/30 mb-4">
                    <i class="bi bi-person-plus-fill text-2xl text-primary-600 dark:text-primary-400"></i>
                </div>
                <h1 class="text-2xl font-bold text-slate-900 dark:text-white">Create your account</h1>
                <p class="text-slate-500 dark:text-slate-400 mt-1.5 text-sm">Join GymPro and start your fitness journey.</p>
            </div>

            <form method="post" asp-action="Register" asp-controller="Account">
                <div asp-validation-summary="ModelOnly" class="text-red-600 dark:text-red-400 text-sm mb-4 bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 p-3 rounded-lg"></div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
                    <div>
                        <label asp-for="FirstName" class="form-label"></label>
                        <input asp-for="FirstName" class="form-input" autofocus placeholder="First name" />
                        <span asp-validation-for="FirstName" class="text-red-500 text-xs mt-1 block"></span>
                    </div>
                    <div>
                        <label asp-for="LastName" class="form-label"></label>
                        <input asp-for="LastName" class="form-input" placeholder="Last name" />
                        <span asp-validation-for="LastName" class="text-red-500 text-xs mt-1 block"></span>
                    </div>
                </div>

                <div class="mb-4">
                    <label asp-for="Email" class="form-label"></label>
                    <input asp-for="Email" class="form-input" placeholder="you@example.com" />
                    <span asp-validation-for="Email" class="text-red-500 text-xs mt-1 block"></span>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
                    <div>
                        <label asp-for="Password" class="form-label"></label>
                        <input asp-for="Password" type="password" class="form-input" placeholder="Min. 8 characters" />
                        <span asp-validation-for="Password" class="text-red-500 text-xs mt-1 block"></span>
                    </div>
                    <div>
                        <label asp-for="ConfirmPassword" class="form-label"></label>
                        <input asp-for="ConfirmPassword" type="password" class="form-input" placeholder="Repeat password" />
                        <span asp-validation-for="ConfirmPassword" class="text-red-500 text-xs mt-1 block"></span>
                    </div>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-6">
                    <div>
                        <label asp-for="DateOfBirth" class="form-label"></label>
                        <input asp-for="DateOfBirth" type="date" class="form-input" />
                        <span asp-validation-for="DateOfBirth" class="text-red-500 text-xs mt-1 block"></span>
                    </div>
                    <div>
                        <label asp-for="Gender" class="form-label"></label>
                        <select asp-for="Gender" class="form-select">
                            <option value="">Select gender</option>
                            <option value="Male">Male</option>
                            <option value="Female">Female</option>
                        </select>
                        <span asp-validation-for="Gender" class="text-red-500 text-xs mt-1 block"></span>
                    </div>
                </div>

                <button type="submit" class="btn-primary w-full py-2.5">
                    Create Account
                </button>

                <div class="mt-6 text-center">
                    <p class="text-slate-500 dark:text-slate-400 text-sm">
                        Already have an account? <a asp-action="Login" class="font-medium text-primary-600 dark:text-primary-400 hover:text-primary-700 dark:hover:text-primary-300">Sign in</a>
                    </p>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
