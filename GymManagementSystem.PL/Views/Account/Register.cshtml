@model RegisterViewModel
@{
    ViewData["Title"] = "Register";
}

<div class="row justify-content-center">
    <div class="col-md-6 col-lg-5">
        <div class="premium-card p-5">
            <h2 class="display-6 fw-bold mb-2 text-center">Create <span class="text-gradient">Account</span></h2>
            <p class="text-secondary text-center mb-4 fs-5">Join the gym management system</p>

            <form method="post" asp-action="Register" asp-controller="Account">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="row mb-3">
                    <div class="col-md-6">
                        <label asp-for="FirstName" class="form-label fs-5"></label>
                        <input asp-for="FirstName" class="form-control form-control-lg" autofocus />
                        <span asp-validation-for="FirstName" class="text-danger"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="LastName" class="form-label fs-5"></label>
                        <input asp-for="LastName" class="form-control form-control-lg" />
                        <span asp-validation-for="LastName" class="text-danger"></span>
                    </div>
                </div>

                <div class="mb-3">
                    <label asp-for="Email" class="form-label fs-5"></label>
                    <input asp-for="Email" class="form-control form-control-lg" />
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Password" class="form-label fs-5"></label>
                    <input asp-for="Password" class="form-control form-control-lg" />
                    <span asp-validation-for="Password" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="ConfirmPassword" class="form-label fs-5"></label>
                    <input asp-for="ConfirmPassword" class="form-control form-control-lg" />
                    <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                </div>

                <div class="row mb-4">
                    <div class="col-md-6">
                        <label asp-for="DateOfBirth" class="form-label fs-5"></label>
                        <input asp-for="DateOfBirth" class="form-control form-control-lg" type="date" />
                        <span asp-validation-for="DateOfBirth" class="text-danger"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Gender" class="form-label fs-5"></label>
                        <select asp-for="Gender" class="form-select form-select-lg">
                            <option value="Male">Male</option>
                            <option value="Female">Female</option>
                        </select>
                        <span asp-validation-for="Gender" class="text-danger"></span>
                    </div>
                </div>

                <button type="submit" class="btn btn-gradient btn-lg w-100 mb-3 py-3 fs-5">Create Account</button>

                <p class="text-center text-secondary mb-0">
                    Already have an account? <a asp-action="Login" asp-controller="Account" class="text-primary-theme">Sign In</a>
                </p>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
