@model CreateBookingViewModel
@{
    ViewData["Title"] = "New Booking";
}

<div class="mb-6 flex flex-col md:flex-row md:items-center md:justify-between gap-4">
    <div>
        <h1 class="page-title">New Booking</h1>
        <p class="page-subtitle mt-1">Manually assign a member to a class session.</p>
    </div>
    <a asp-action="Index" class="btn-outline">
        <i class="bi bi-arrow-left mr-1"></i> Back to Bookings
    </a>
</div>

<div class="max-w-xl mx-auto">
    <div class="page-card p-6 md:p-8">
        <form asp-action="Create" method="post" class="space-y-5">
            <div>
                <label asp-for="MemberId" class="form-label">Member</label>
                <select asp-for="MemberId" asp-items="@(new SelectList(Model.Members, "Id", "FirstName"))" class="form-select">
                    <option value="">Select member</option>
                </select>
                <span asp-validation-for="MemberId" class="text-red-500 text-xs mt-1 block"></span>
            </div>

            <div>
                <label asp-for="ClassSessionId" class="form-label">Session</label>
                <select asp-for="ClassSessionId" asp-items="@(new SelectList(Model.Sessions, "Id", "Name"))" class="form-select">
                    <option value="">Select session</option>
                </select>
                <span asp-validation-for="ClassSessionId" class="text-red-500 text-xs mt-1 block"></span>
            </div>

            <div class="flex gap-3 pt-4 border-t border-slate-200 dark:border-slate-700">
                <a asp-action="Index" class="btn-outline flex-1 justify-center py-2.5">Cancel</a>
                <button type="submit" class="btn-primary flex-1 justify-center py-2.5">
                    <i class="bi bi-check-lg mr-1"></i> Create Booking
                </button>
            </div>
        </form>
    </div>
</div>
