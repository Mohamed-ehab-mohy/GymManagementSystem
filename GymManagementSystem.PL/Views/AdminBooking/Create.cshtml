@model CreateBookingViewModel
@{
    ViewData["Title"] = "New Booking";
}

<div class="mb-8 flex flex-col md:flex-row md:items-end justify-between gap-6 border-b border-zinc-200 dark:border-gym-border pb-6">
    <div>
        <h2 class="text-3xl font-display font-bold text-zinc-900 dark:text-white mb-2">New <span class="text-transparent bg-clip-text bg-gradient-to-r from-neon-green to-neon-cyan">Booking</span></h2>
        <p class="text-zinc-500 dark:text-zinc-400">Manually assign a member to a class session.</p>
    </div>
</div>

<div class="max-w-xl mx-auto">
    <div class="glass-card p-8">
        <form asp-action="Create" method="post" class="space-y-6">
            <div>
                <label asp-for="MemberId" class="block text-sm font-semibold text-zinc-700 dark:text-zinc-300 mb-2">Member</label>
                <div class="relative">
                    <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                        <i class="bi bi-person text-zinc-400"></i>
                    </div>
                    <select asp-for="MemberId" asp-items="@(new SelectList(Model.Members, "Id", "FirstName"))" class="input-field pl-10 w-full appearance-none">
                        <option value="">-- Select Member --</option>
                    </select>
                    <div class="absolute inset-y-0 right-0 pr-3 flex items-center pointer-events-none">
                        <i class="bi bi-chevron-down text-zinc-400"></i>
                    </div>
                </div>
                <span asp-validation-for="MemberId" class="text-red-500 text-xs font-medium mt-1 block"></span>
            </div>

            <div>
                <label asp-for="ClassSessionId" class="block text-sm font-semibold text-zinc-700 dark:text-zinc-300 mb-2">Session</label>
                <div class="relative">
                    <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                        <i class="bi bi-calendar-event text-zinc-400"></i>
                    </div>
                    <select asp-for="ClassSessionId" asp-items="@(new SelectList(Model.Sessions, "Id", "Name"))" class="input-field pl-10 w-full appearance-none">
                        <option value="">-- Select Session --</option>
                    </select>
                    <div class="absolute inset-y-0 right-0 pr-3 flex items-center pointer-events-none">
                        <i class="bi bi-chevron-down text-zinc-400"></i>
                    </div>
                </div>
                <span asp-validation-for="ClassSessionId" class="text-red-500 text-xs font-medium mt-1 block"></span>
            </div>

            <div class="flex gap-4 pt-4 mt-8 border-t border-zinc-200 dark:border-zinc-800">
                <a asp-action="Index" class="btn-outline border-zinc-300 dark:border-zinc-700 flex-1 justify-center py-2.5">
                    <i class="bi bi-x-lg mr-2"></i> Cancel
                </a>
                <button type="submit" class="btn-primary flex-1 justify-center py-2.5 shadow-[0_0_15px_rgba(57,255,20,0.3)]">
                    <i class="bi bi-check-lg mr-2"></i> Create Booking
                </button>
            </div>
        </form>
    </div>
</div>
