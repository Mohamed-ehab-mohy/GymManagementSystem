@model PagedResultDisplay<BookingViewModel>
@{
    ViewData["Title"] = "Bookings";
    var search = ViewBag.Search as string;
}

<div class="mb-6 flex flex-col md:flex-row md:items-center md:justify-between gap-4">
    <div>
        <h1 class="page-title">Bookings</h1>
        <p class="page-subtitle mt-1">View and manage all member bookings.</p>
    </div>
    <div class="flex flex-wrap items-center gap-3">
        <a asp-controller="Attendance" asp-action="Scan" class="btn-outline py-2 text-sm">
            <i class="bi bi-qr-code-scan mr-1"></i> Scan QR
        </a>
        <a asp-action="Create" class="btn-primary py-2 text-sm">
            <i class="bi bi-plus-circle mr-1"></i> New Booking
        </a>
    </div>
</div>

<form method="get" class="mb-6 flex flex-col sm:flex-row gap-3 items-center justify-between">
    <div class="w-full sm:w-80 relative">
        <i class="bi bi-search absolute left-3 top-1/2 -translate-y-1/2 text-slate-400"></i>
        <input type="text" name="search" value="@search" class="form-input pl-10" placeholder="Search by member name..." />
    </div>
    <div class="text-sm text-slate-500 dark:text-slate-400">
        @Model.TotalCount booking(s) found
    </div>
</form>

<div class="page-card">
    <div class="overflow-x-auto">
        <table class="data-table">
            <thead>
                <tr>
                    <th>Member</th>
                    <th>Session</th>
                    <th>Date</th>
                    <th>Status</th>
                    <th class="text-right">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Items.Any())
                {
                    foreach (var item in Model.Items)
                    {
                        <tr>
                            <td class="font-semibold text-slate-900 dark:text-white">@item.MemberName</td>
                            <td>
                                <div class="font-medium text-slate-900 dark:text-slate-200">@item.SessionName</div>
                                <div class="text-xs text-slate-500 dark:text-slate-400 mt-0.5">@(item.ScheduleTime?.ToString("dd MMM yyyy - hh:mm tt") ?? "")</div>
                            </td>
                            <td class="text-slate-600 dark:text-slate-400">@item.BookingDate.ToString("dd MMM yyyy")</td>
                            <td>
                                @if (item.IsAttended)
                                {
                                    <span class="badge badge-success">Attended</span>
                                    <div class="text-[10px] text-slate-500 dark:text-slate-400 mt-0.5">@item.CheckedInAt?.ToString("hh:mm tt")</div>
                                }
                                else
                                {
                                    <span class="badge badge-warning">Pending</span>
                                }
                            </td>
                            <td class="text-right">
                                <div class="flex items-center justify-end gap-2">
                                    <a asp-controller="Attendance" asp-action="MyQr" asp-route-bookingId="@item.Id" class="btn-ghost p-2" title="View QR">
                                        <i class="bi bi-qr-code"></i>
                                    </a>
                                    <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="inline">
                                        <button type="submit" class="btn-ghost p-2 text-red-500 hover:text-red-600" title="Delete" onclick="return confirm('Delete this booking?');">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="5" class="py-12 text-center">
                            <p class="text-slate-500 dark:text-slate-400">No bookings found.</p>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (Model.TotalPages > 1)
    {
        <div class="px-6 py-4 border-t border-slate-200 dark:border-slate-700 flex items-center justify-center">
            <nav class="flex items-center gap-1">
                <a asp-route-page="@(Model.Page - 1)" asp-route-search="@search" class="w-9 h-9 flex items-center justify-center rounded-lg border border-slate-200 dark:border-slate-700 text-slate-500 hover:bg-slate-50 dark:hover:bg-slate-700 transition-colors @(!Model.HasPreviousPage ? "opacity-50 pointer-events-none" : "")">
                    <i class="bi bi-chevron-left text-sm"></i>
                </a>
                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    <a asp-route-page="@i" asp-route-search="@search" class="w-9 h-9 flex items-center justify-center rounded-lg text-sm font-medium transition-colors @(i == Model.Page ? "bg-primary-600 text-white" : "border border-slate-200 dark:border-slate-700 text-slate-600 dark:text-slate-400 hover:bg-slate-50 dark:hover:bg-slate-700")">
                        @i
                    </a>
                }
                <a asp-route-page="@(Model.Page + 1)" asp-route-search="@search" class="w-9 h-9 flex items-center justify-center rounded-lg border border-slate-200 dark:border-slate-700 text-slate-500 hover:bg-slate-50 dark:hover:bg-slate-700 transition-colors @(!Model.HasNextPage ? "opacity-50 pointer-events-none" : "")">
                    <i class="bi bi-chevron-right text-sm"></i>
                </a>
            </nav>
        </div>
    }
</div>
