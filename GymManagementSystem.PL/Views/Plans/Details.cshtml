@model GymManagementSystem.PL.ViewModels.PlanViewModel

@{
    ViewData["Title"] = "Plan Details";
}

<div class="mb-6 flex flex-col md:flex-row md:items-center md:justify-between gap-4">
    <div>
        <h1 class="page-title">Plan Details</h1>
        <p class="page-subtitle mt-1">Membership package configuration.</p>
    </div>
    <div class="flex flex-wrap gap-3">
        <a asp-action="Index" class="btn-outline py-2 text-sm">
            <i class="bi bi-list mr-1"></i> Back to Plans
        </a>
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn-primary py-2 text-sm">
            <i class="bi bi-pencil mr-1"></i> Edit Plan
        </a>
    </div>
</div>

<div class="max-w-4xl mx-auto">
    <div class="page-card overflow-hidden">
        <div class="p-10 text-center border-b border-slate-200 dark:border-slate-700">
            <div class="w-16 h-16 mx-auto rounded-full @(Model.IsActive ? "bg-primary-100 dark:bg-primary-900/30 text-primary-600 dark:text-primary-400" : "bg-slate-100 dark:bg-slate-700 text-slate-400") flex items-center justify-center text-3xl mb-4">
                <i class="bi bi-award"></i>
            </div>
            <h2 class="text-3xl font-bold text-slate-900 dark:text-white mb-3">@Model.Name</h2>
            @if (Model.IsActive)
            {
                <span class="badge badge-success">Active</span>
            }
            else
            {
                <span class="badge badge-neutral">Inactive</span>
            }
        </div>

        <div class="p-8 md:p-10">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-8">
                <div class="bg-slate-50 dark:bg-slate-800/50 rounded-lg p-6 text-center border border-slate-200 dark:border-slate-700">
                    <h5 class="text-xs font-medium text-slate-500 dark:text-slate-400 uppercase tracking-wider mb-2">Price</h5>
                    <div class="text-3xl font-bold text-slate-900 dark:text-white">
                        @Model.Price.ToString("G29") <span class="text-base font-medium text-slate-500">EGP</span>
                    </div>
                </div>
                <div class="bg-slate-50 dark:bg-slate-800/50 rounded-lg p-6 text-center border border-slate-200 dark:border-slate-700">
                    <h5 class="text-xs font-medium text-slate-500 dark:text-slate-400 uppercase tracking-wider mb-2">Duration</h5>
                    <div class="text-3xl font-bold text-slate-900 dark:text-white">
                        @Model.DurationDays <span class="text-base font-medium text-slate-500">Days</span>
                    </div>
                </div>
            </div>

            <div class="bg-slate-50 dark:bg-slate-800/50 rounded-lg p-6 border border-slate-200 dark:border-slate-700">
                <h4 class="text-sm font-semibold text-slate-900 dark:text-white mb-3">Description</h4>
                <p class="text-sm text-slate-600 dark:text-slate-300 leading-relaxed m-0">@Model.Description</p>
            </div>
        </div>
    </div>
</div>
