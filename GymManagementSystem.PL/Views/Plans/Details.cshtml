@model GymManagementSystem.PL.ViewModels.PlanViewModel

@{
    ViewData["Title"] = "Plan Details";
}

<div class="mb-8 flex flex-col md:flex-row md:items-end justify-between gap-6 border-b border-zinc-200 dark:border-gym-border pb-6">
    <div>
        <h2 class="text-3xl font-display font-bold text-zinc-900 dark:text-white mb-1">Plan <span class="text-transparent bg-clip-text bg-gradient-to-r from-neon-orange to-yellow-500">Details</span></h2>
        <p class="text-zinc-500 dark:text-zinc-400">Membership package configuration.</p>
    </div>
    <div class="flex flex-wrap gap-3">
        <a asp-action="Index" class="btn-outline border-zinc-300 dark:border-zinc-700 py-2 text-sm">
            <i class="bi bi-list mr-2"></i> Back to Plans
        </a>
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn-primary py-2 text-sm shadow-[0_0_15px_rgba(57,255,20,0.3)]">
            <i class="bi bi-pencil mr-2"></i> Edit Plan
        </a>
    </div>
</div>

<div class="max-w-4xl mx-auto">
    <div class="glass-card overflow-hidden">
        <div class="p-12 text-center bg-zinc-50/50 dark:bg-zinc-900/30 border-b border-zinc-200 dark:border-zinc-800 relative">
            @if (Model.IsActive)
            {
                <div class="absolute inset-0 bg-gradient-to-b from-neon-green/5 to-transparent pointer-events-none"></div>
            }
            <div class="relative z-10">
                <i class="bi bi-award text-6xl mb-6 inline-block text-zinc-300 dark:text-zinc-600 @(Model.IsActive ? "text-neon-green dark:text-neon-green drop-shadow-[0_0_15px_rgba(57,255,20,0.4)]" : "")"></i>
                <h1 class="text-5xl font-display font-extrabold text-zinc-900 dark:text-white mb-4 tracking-tight">@Model.Name</h1>
                
                @if (Model.IsActive)
                {
                    <span class="inline-flex items-center px-4 py-1.5 rounded-full text-sm font-bold bg-green-500/10 text-green-500 border border-green-500/20 shadow-[0_0_15px_rgba(34,197,94,0.2)]">
                        Active Plan
                    </span>
                }
                else
                {
                    <span class="inline-flex items-center px-4 py-1.5 rounded-full text-sm font-bold bg-zinc-200 dark:bg-zinc-800 text-zinc-500 dark:text-zinc-400 border border-zinc-300 dark:border-zinc-700">
                        Inactive Plan
                    </span>
                }
            </div>
        </div>
        
        <div class="p-8 md:p-12">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-10 text-center">
                <div class="bg-zinc-50 dark:bg-zinc-900/50 rounded-2xl p-8 border border-zinc-200 dark:border-zinc-800">
                    <h5 class="text-sm font-bold text-zinc-500 dark:text-zinc-400 uppercase tracking-wider mb-2">Pricing</h5>
                    <div class="text-4xl font-extrabold text-zinc-900 dark:text-white flex items-baseline justify-center gap-2">
                        @Model.Price.ToString("G29") <span class="text-lg font-medium text-zinc-500">EGP</span>
                    </div>
                </div>
                <div class="bg-zinc-50 dark:bg-zinc-900/50 rounded-2xl p-8 border border-zinc-200 dark:border-zinc-800">
                    <h5 class="text-sm font-bold text-zinc-500 dark:text-zinc-400 uppercase tracking-wider mb-2">Duration</h5>
                    <div class="text-4xl font-extrabold text-zinc-900 dark:text-white flex items-baseline justify-center gap-2">
                        @Model.DurationDays <span class="text-lg font-medium text-zinc-500">Days</span>
                    </div>
                </div>
            </div>

            <div class="bg-zinc-50 dark:bg-zinc-900/50 rounded-2xl p-8 border border-zinc-200 dark:border-zinc-800">
                <h4 class="text-lg font-bold text-zinc-900 dark:text-white mb-4 flex items-center gap-2">
                    <i class="bi bi-card-text text-neon-orange"></i> Description
                </h4>
                <p class="text-lg text-zinc-600 dark:text-zinc-300 leading-relaxed m-0">@Model.Description</p>
            </div>
        </div>
    </div>
</div>
