@model GymManagementSystem.PL.ViewModels.PlanViewModel

@{
    ViewData["Title"] = "Plan Details";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="premium-card border-0">
                <div class="premium-card-header text-center py-5 @(Model.IsActive ? "active-plan" : "")">
                    <i class="bi bi-award display-1 mb-3 d-block text-primary-theme"></i>
                    <h1 class="display-4 fw-bold mb-0">@Model.Name</h1>
                    <div class="mt-3">
                        @if (Model.IsActive)
                        {
                            <span class="badge bg-success fs-5 rounded-pill px-4 py-2">Active Plan</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary fs-5 rounded-pill px-4 py-2">Inactive Plan</span>
                        }
                    </div>
                </div>
                
                <div class="card-body p-5">
                    <div class="row text-center mb-5">
                        <div class="col-md-6 mb-4 mb-md-0">
                            <div class="p-4 rounded-4" style="background: var(--bg-color);">
                                <h5 class="text-secondary mb-2">Pricing</h5>
                                <div class="display-5 fw-bold text-gradient">@Model.Price.ToString("G29") <span class="fs-4 text-secondary">EGP</span></div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="p-4 rounded-4" style="background: var(--bg-color);">
                                <h5 class="text-secondary mb-2">Duration</h5>
                                <div class="display-5 fw-bold text-primary-theme">@Model.DurationDays <span class="fs-4 text-secondary">Days</span></div>
                            </div>
                        </div>
                    </div>

                    <div class="p-4 rounded-4 mb-5" style="background: var(--bg-color);">
                        <h4 class="fw-bold mb-3"><i class="bi bi-card-text text-primary-theme me-2"></i>Description</h4>
                        <p class="fs-5 text-secondary lh-lg mb-0">@Model.Description</p>
                    </div>
                    
                    <div class="d-flex justify-content-between gap-3 flex-wrap border-top pt-4" style="border-color: var(--border-color) !important;">
                        <a asp-action="Index" class="btn btn-glass px-5 py-3 fs-5">
                            <i class="bi bi-arrow-left me-2"></i> Back to Plans
                        </a>
                        <div class="d-flex gap-2">
                            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-gradient px-5 py-3 fs-5">
                                <i class="bi bi-pencil me-2"></i> Edit Plan
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
