@model IEnumerable<GymManagementSystem.PL.ViewModels.PlanViewModel>
@{
    ViewData["Title"] = "Plans";
}

<div class="mb-8 flex flex-col md:flex-row md:items-end justify-between gap-6 border-b border-zinc-200 dark:border-gym-border pb-6">
    <div>
        <h1 class="text-3xl font-display font-bold text-zinc-900 dark:text-white mb-2">Membership <span class="text-transparent bg-clip-text bg-gradient-to-r from-neon-green to-neon-cyan">Plans</span></h1>
        <p class="text-zinc-500 dark:text-zinc-400">Choose the perfect package for your fitness journey.</p>
    </div>
    <div class="flex flex-wrap items-center gap-3">
        <a asp-action="ExportExcel" class="btn-outline border-green-500 text-green-500 hover:bg-green-500 hover:text-white py-2 text-sm transition-colors">
            <i class="bi bi-file-earmark-excel mr-2"></i> Export Excel
        </a>
        <a asp-action="ExportPdf" class="btn-outline border-red-500 text-red-500 hover:bg-red-500 hover:text-white py-2 text-sm transition-colors">
            <i class="bi bi-file-earmark-pdf mr-2"></i> Export PDF
        </a>
        <a asp-action="Create" class="btn-primary py-2 text-sm shadow-[0_0_15px_rgba(57,255,20,0.3)]">
            <i class="bi bi-plus-circle mr-2"></i> Add New Plan
        </a>
    </div>
</div>

<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 pt-8 pb-4 max-w-7xl mx-auto items-center">
    @if (Model != null && Model.Any())
    {
        foreach (var plan in Model)
        {
            <partial name="_PlanCard" model="plan" />
        }
    }
    else
    {
        <div class="col-span-full text-center py-16 glass-card">
            <div class="w-20 h-20 mx-auto rounded-full bg-zinc-100 dark:bg-zinc-800 flex items-center justify-center mb-4 border border-zinc-200 dark:border-zinc-700">
                <i class="bi bi-inbox text-4xl text-zinc-400 dark:text-zinc-500"></i>
            </div>
            <h3 class="text-xl font-bold text-zinc-900 dark:text-white mb-2">No Plans Available</h3>
            <p class="text-zinc-500 dark:text-zinc-400 mb-6">Get started by creating your first membership plan.</p>
            <a asp-action="Create" class="btn-primary">Create Plan</a>
        </div>
    }
</div>
