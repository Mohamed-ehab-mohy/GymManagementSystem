@model IEnumerable<GymManagementSystem.PL.ViewModels.PlanViewModel>
@{
    ViewData["Title"] = "Plans";
}

<div class="mb-6 flex flex-col md:flex-row md:items-center md:justify-between gap-4">
    <div>
        <h1 class="page-title">Membership Plans</h1>
        <p class="page-subtitle mt-1">Manage pricing and membership packages.</p>
    </div>
    <div class="flex flex-wrap items-center gap-3">
        <a asp-action="ExportExcel" class="btn-outline py-2 text-sm">
            <i class="bi bi-file-earmark-excel mr-1"></i> Excel
        </a>
        <a asp-action="ExportPdf" class="btn-outline py-2 text-sm">
            <i class="bi bi-file-earmark-pdf mr-1"></i> PDF
        </a>
        <a asp-action="Create" class="btn-primary py-2 text-sm">
            <i class="bi bi-plus-circle mr-1"></i> Add Plan
        </a>
    </div>
</div>

<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
    @if (Model != null && Model.Any())
    {
        foreach (var plan in Model)
        {
            <partial name="_PlanCard" model="plan" />
        }
    }
    else
    {
        <div class="col-span-full page-card p-12 text-center">
            <div class="w-16 h-16 mx-auto rounded-full bg-slate-100 dark:bg-slate-700 flex items-center justify-center mb-4">
                <i class="bi bi-inbox text-3xl text-slate-400 dark:text-slate-500"></i>
            </div>
            <h3 class="text-lg font-semibold text-slate-900 dark:text-white mb-1">No plans yet</h3>
            <p class="text-sm text-slate-500 dark:text-slate-400 mb-4">Get started by creating your first membership plan.</p>
            <a asp-action="Create" class="btn-primary">Create Plan</a>
        </div>
    }
</div>
