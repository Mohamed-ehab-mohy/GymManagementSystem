@model GymManagementSystem.PL.ViewModels.PlanViewModel

<div class="page-card flex flex-col h-full @(Model.IsActive ? "border-primary-300 dark:border-primary-700 ring-1 ring-primary-200 dark:ring-primary-800" : "")">
    @if (Model.IsActive)
    {
        <div class="px-4 py-2 bg-primary-50 dark:bg-primary-900/20 border-b border-primary-100 dark:border-primary-800">
            <span class="badge badge-info text-[11px]">Active Plan</span>
        </div>
    }

    <div class="p-6 flex-1 flex flex-col">
        <div class="flex items-start justify-between mb-4">
            <h3 class="text-lg font-bold text-slate-900 dark:text-white">@Model.Name</h3>
            @if (!Model.IsActive)
            {
                <span class="badge badge-neutral">Inactive</span>
            }
        </div>

        <div class="flex items-baseline gap-1.5 mb-1">
            <span class="text-3xl font-bold text-slate-900 dark:text-white">@Model.Price.ToString("G29")</span>
            <span class="text-sm font-medium text-slate-500 dark:text-slate-400">EGP</span>
        </div>
        <p class="text-sm text-slate-500 dark:text-slate-400 mb-4">/ @Model.DurationDays days</p>

        <p class="text-sm text-slate-600 dark:text-slate-300 mb-6 flex-1">@Model.Description</p>

        <div class="flex gap-3 mt-auto">
            <a asp-action="Details" asp-route-id="@Model.Id" class="btn-outline flex-1 justify-center py-2 text-sm">
                <i class="bi bi-eye mr-1"></i> Details
            </a>
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn-outline flex-1 justify-center py-2 text-sm">
                <i class="bi bi-pencil mr-1"></i> Edit
            </a>
            <form asp-action="ToggleActive" asp-route-id="@Model.Id" method="post" class="flex-1">
                <button type="submit" class="w-full btn-outline py-2 text-sm @(Model.IsActive ? "text-red-600 dark:text-red-400 hover:bg-red-50 dark:hover:bg-red-900/20 hover:border-red-300 dark:hover:border-red-700" : "text-emerald-600 dark:text-emerald-400 hover:bg-emerald-50 dark:hover:bg-emerald-900/20 hover:border-emerald-300 dark:hover:border-emerald-700")">
                    @if (Model.IsActive)
                    {
                        @:<i class="bi bi-x-circle mr-1"></i> Disable
                    }
                    else
                    {
                        @:<i class="bi bi-check-circle mr-1"></i> Enable
                    }
                </button>
            </form>
        </div>
    </div>
</div>
