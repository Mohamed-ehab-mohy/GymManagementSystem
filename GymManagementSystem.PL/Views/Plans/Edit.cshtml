@model GymManagementSystem.PL.ViewModels.PlanViewModel

@{
    ViewData["Title"] = "Edit Plan";
}

<div class="mb-6 flex flex-col md:flex-row md:items-center md:justify-between gap-4">
    <div>
        <h2 class="text-3xl font-display font-bold text-zinc-900 dark:text-white">Edit <span class="text-transparent bg-clip-text bg-gradient-to-r from-neon-cyan to-neon-green">Plan</span></h2>
        <p class="text-zinc-500 dark:text-zinc-400 mt-1">Update membership plan details.</p>
    </div>
    <a asp-action="Index" class="btn-outline">
        <i class="bi bi-arrow-left mr-2"></i> Back to List
    </a>
</div>

<div class="glass-card p-6 md:p-8 max-w-3xl mx-auto">
    <form asp-action="Edit">
        <div asp-validation-summary="ModelOnly" class="text-red-500 mb-4 bg-red-50 dark:bg-red-500/10 p-3 rounded-lg text-sm border border-red-200 dark:border-red-500/20"></div>
        <input type="hidden" asp-for="Id" />

        <div class="mb-6">
            <label asp-for="Name" class="form-label"></label>
            <input asp-for="Name" class="form-input" />
            <span asp-validation-for="Name" class="text-red-500 text-xs mt-1 block"></span>
        </div>

        <div class="mb-6">
            <label asp-for="Description" class="form-label"></label>
            <textarea asp-for="Description" class="form-input" rows="3"></textarea>
            <span asp-validation-for="Description" class="text-red-500 text-xs mt-1 block"></span>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
            <div>
                <label asp-for="DurationDays" class="form-label">Duration (Days)</label>
                <input asp-for="DurationDays" class="form-input" type="number" />
                <span asp-validation-for="DurationDays" class="text-red-500 text-xs mt-1 block"></span>
            </div>
            <div>
                <label asp-for="Price" class="form-label">Price (EGP)</label>
                <input asp-for="Price" class="form-input" type="number" step="0.01" />
                <span asp-validation-for="Price" class="text-red-500 text-xs mt-1 block"></span>
            </div>
        </div>

        <div class="mb-8">
            <label class="flex items-center cursor-pointer">
                <input type="checkbox" asp-for="IsActive" class="sr-only peer">
                <div class="w-11 h-6 bg-zinc-200 peer-focus:outline-none peer-focus:ring-4 peer-focus:ring-neon-green/30 dark:peer-focus:ring-neon-green/20 rounded-full peer dark:bg-zinc-700 peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-zinc-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all dark:border-zinc-600 peer-checked:bg-neon-green relative"></div>
                <span class="ml-3 text-sm font-medium text-zinc-900 dark:text-zinc-300">Is Active?</span>
            </label>
        </div>

        <div class="flex justify-between items-center mt-8 pt-6 border-t border-zinc-200 dark:border-zinc-800">
            <a asp-action="Index" class="text-zinc-500 hover:text-zinc-900 dark:hover:text-white transition-colors font-medium">
                Cancel
            </a>
            <button type="submit" class="btn-primary px-8">
                <i class="bi bi-check-circle mr-2"></i> Save Changes
            </button>
        </div>
    </form>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
