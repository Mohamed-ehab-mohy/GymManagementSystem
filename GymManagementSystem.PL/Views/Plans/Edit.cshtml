@model GymManagementSystem.PL.ViewModels.PlanViewModel

@{
    ViewData["Title"] = "Edit Plan";
}

<div class="mb-6 flex flex-col md:flex-row md:items-center md:justify-between gap-4">
    <div>
        <h1 class="page-title">Edit Plan</h1>
        <p class="page-subtitle mt-1">Update membership plan details.</p>
    </div>
    <a asp-action="Index" class="btn-outline">
        <i class="bi bi-arrow-left mr-1"></i> Back to Plans
    </a>
</div>

<div class="page-card p-6 md:p-8 max-w-3xl mx-auto">
    <form asp-action="Edit">
        <div asp-validation-summary="ModelOnly" class="text-red-600 dark:text-red-400 text-sm mb-4 bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 p-3 rounded-lg"></div>
        <input type="hidden" asp-for="Id" />

        <div class="mb-4">
            <label asp-for="Name" class="form-label"></label>
            <input asp-for="Name" class="form-input" />
            <span asp-validation-for="Name" class="text-red-500 text-xs mt-1 block"></span>
        </div>

        <div class="mb-4">
            <label asp-for="Description" class="form-label"></label>
            <textarea asp-for="Description" class="form-input" rows="3"></textarea>
            <span asp-validation-for="Description" class="text-red-500 text-xs mt-1 block"></span>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
            <div>
                <label asp-for="DurationDays" class="form-label">Duration (Days)</label>
                <input asp-for="DurationDays" class="form-input" type="number" />
                <span asp-validation-for="DurationDays" class="text-red-500 text-xs mt-1 block"></span>
            </div>
            <div>
                <label asp-for="Price" class="form-label">Price (EGP)</label>
                <input asp-for="Price" class="form-input" type="number" step="0.01" />
                <span asp-validation-for="Price" class="text-red-500 text-xs mt-1 block"></span>
            </div>
        </div>

        <div class="mb-6">
            <label class="flex items-center gap-3 cursor-pointer">
                <input type="checkbox" asp-for="IsActive" class="w-4 h-4 rounded border-slate-300 dark:border-slate-600 text-primary-600 focus:ring-primary-500">
                <span class="text-sm font-medium text-slate-700 dark:text-slate-300">Active</span>
            </label>
        </div>

        <div class="flex justify-end gap-3 mt-6 pt-6 border-t border-slate-200 dark:border-slate-700">
            <button type="button" class="btn-outline" onclick="window.history.back()">Cancel</button>
            <button type="submit" class="btn-primary">
                <i class="bi bi-check-circle mr-1"></i> Save Changes
            </button>
        </div>
    </form>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
