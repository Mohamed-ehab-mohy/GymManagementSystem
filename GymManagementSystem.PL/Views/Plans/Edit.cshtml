@model GymManagementSystem.PL.ViewModels.PlanViewModel

@{
    ViewData["Title"] = "Edit Plan";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-12 col-xl-8">
            <header class="d-flex justify-content-between mb-4 align-items-center border-bottom pb-3" style="border-color: var(--border-color) !important;">
                <div>
                    <h2 class="display-6 fw-bold mb-1">Edit <span class="text-gradient">Plan</span></h2>
                    <p class="text-secondary fs-6 mb-0">Update membership plan details.</p>
                </div>
                <a asp-action="Index" class="btn btn-outline-secondary">
                    <i class="bi bi-arrow-left me-2"></i> Back to List
                </a>
            </header>

            <div class="premium-card p-4 p-md-5">
                <form asp-action="Edit">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                    <input type="hidden" asp-for="Id" />

                    <div class="mb-3">
                        <label asp-for="Name" class="form-label fw-semibold"></label>
                        <input asp-for="Name" class="form-control form-control-lg premium-input" />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Description" class="form-label fw-semibold"></label>
                        <textarea asp-for="Description" class="form-control form-control-lg premium-input" rows="3"></textarea>
                        <span asp-validation-for="Description" class="text-danger"></span>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="DurationDays" class="form-label fw-semibold">Duration (Days)</label>
                            <input asp-for="DurationDays" class="form-control form-control-lg premium-input" type="number" />
                            <span asp-validation-for="DurationDays" class="text-danger"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="Price" class="form-label fw-semibold">Price (EGP)</label>
                            <input asp-for="Price" class="form-control form-control-lg premium-input" type="number" step="0.01" />
                            <span asp-validation-for="Price" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="mb-4 form-check form-switch fs-5">
                        <input class="form-check-input" type="checkbox" asp-for="IsActive">
                        <label class="form-check-label ms-2" asp-for="IsActive">Is Active?</label>
                    </div>

                    <div class="d-flex justify-content-between mt-5 pt-4 border-top" style="border-color: var(--border-color) !important;">
                        <a asp-action="Index" class="btn btn-outline-secondary px-4 py-2">
                            <i class="bi bi-arrow-left me-1"></i> Back to List
                        </a>
                        <button type="submit" class="btn btn-gradient px-5 py-2">
                            <i class="bi bi-check-circle me-1"></i> Save Changes
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
