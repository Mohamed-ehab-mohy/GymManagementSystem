@model AnalyticsDto
@{
    ViewData["Title"] = "Analytics Dashboard";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="display-5 fw-bold">Analytics <span class="text-gradient">Dashboard</span></h1>
    <span class="text-secondary fs-5">@DateTime.Now.ToString("dddd, MMMM dd, yyyy")</span>
</div>

<div class="row g-4 mb-4">
    <div class="col-md-3">
        <div class="premium-card p-4 text-center">
            <div class="display-4 fw-bold text-success mb-2">@Model.MonthlyRevenue.ToString("C")</div>
            <div class="text-secondary fs-5">Revenue This Month</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="premium-card p-4 text-center">
            <div class="display-4 fw-bold text-primary-theme mb-2">@Model.ActiveMemberCount</div>
            <div class="text-secondary fs-5">Active Members</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="premium-card p-4 text-center">
            <div class="display-4 fw-bold text-info mb-2">@Model.TodaySessionsCount</div>
            <div class="text-secondary fs-5">Today's Sessions</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="premium-card p-4 text-center">
            <div class="display-4 fw-bold text-danger mb-2">@Model.ExpiringSoonCount</div>
            <div class="text-secondary fs-5">Expiring (7 days)</div>
        </div>
    </div>
</div>

<div class="row g-4 mb-4">
    <div class="col-md-6">
        <div class="premium-card p-4">
            <h5 class="fw-bold mb-3"><i class="bi bi-people me-2"></i>New Members Per Month</h5>
            <canvas id="membersChart" height="200"></canvas>
        </div>
    </div>
    <div class="col-md-6">
        <div class="premium-card p-4">
            <h5 class="fw-bold mb-3"><i class="bi bi-cash-stack me-2"></i>Revenue Per Month</h5>
            <canvas id="revenueChart" height="200"></canvas>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-md-6">
        <div class="premium-card p-4">
            <h5 class="fw-bold mb-3"><i class="bi bi-pie-chart me-2"></i>Members by Plan</h5>
            <canvas id="planChart" height="200"></canvas>
        </div>
    </div>
    <div class="col-md-6">
        <div class="premium-card p-4">
            <h5 class="fw-bold mb-3"><i class="bi bi-trophy me-2"></i>Top 5 Sessions</h5>
            <table class="table table-dark table-borderless align-middle mb-0">
                <thead>
                    <tr><th>Session</th><th>Bookings</th><th>Capacity</th><th>Fill Rate</th></tr>
                </thead>
                <tbody>
                    @foreach (var s in Model.TopSessions)
                    {
                        <tr>
                            <td>@s.SessionName</td>
                            <td>@s.BookingCount</td>
                            <td>@s.Capacity</td>
                            <td>
                                <div class="progress" style="height:6px">
                                    <div class="progress-bar bg-success" style="width:@(s.Capacity > 0 ? (s.BookingCount * 100 / s.Capacity) : 0)%"></div>
                                </div>
                                <small>@(s.Capacity > 0 ? (s.BookingCount * 100 / s.Capacity) : 0)%</small>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts
{
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <script>
        const textColor = '#e0e0e0';

        new Chart(document.getElementById('membersChart'), {
            type: 'line',
            data: {
                labels: [@Html.Raw(string.Join(",", Model.NewMembersPerMonth.Select(m => $"'{m.Label}'")))],
                datasets: [{
                    label: 'New Members',
                    data: [@string.Join(",", Model.NewMembersPerMonth.Select(m => m.Count))],
                    borderColor: '#6f42c1',
                    backgroundColor: 'rgba(111,66,193,0.1)',
                    fill: true,
                    tension: 0.3
                }]
            },
            options: {
                responsive: true,
                plugins: { legend: { labels: { color: textColor } } },
                scales: { x: { ticks: { color: textColor } }, y: { ticks: { color: textColor } } }
            }
        });

        new Chart(document.getElementById('revenueChart'), {
            type: 'bar',
            data: {
                labels: [@Html.Raw(string.Join(",", Model.RevenuePerMonth.Select(m => $"'{m.Label}'")))],
                datasets: [{
                    label: 'Revenue',
                    data: [@string.Join(",", Model.RevenuePerMonth.Select(r => r.Revenue))],
                    backgroundColor: '#28a745'
                }]
            },
            options: {
                responsive: true,
                plugins: { legend: { labels: { color: textColor } } },
                scales: { x: { ticks: { color: textColor } }, y: { ticks: { color: textColor } } }
            }
        });

        new Chart(document.getElementById('planChart'), {
            type: 'doughnut',
            data: {
                labels: [@Html.Raw(string.Join(",", Model.MembersByPlan.Select(p => $"'{p.PlanName}'")))],
                datasets: [{
                    data: [@string.Join(",", Model.MembersByPlan.Select(p => p.MemberCount))],
                    backgroundColor: ['#6f42c1', '#28a745', '#ffc107', '#dc3545', '#17a2b8', '#fd7e14']
                }]
            },
            options: {
                responsive: true,
                plugins: { legend: { position: 'bottom', labels: { color: textColor } } }
            }
        });
    </script>
}
