@model AnalyticsDto
@{
    ViewData["Title"] = "Analytics Dashboard";
}

<div class="welcome-header">
    <h1>Analytics <span class="text-gradient">Dashboard</span></h1>
    <p>@DateTime.Now.ToString("dddd, MMMM dd, yyyy")</p>
</div>

<div class="row g-4 mb-4">
    <div class="col-md-3">
        <div class="stat-card">
            <div class="stat-icon success">
                <i class="bi bi-currency-dollar"></i>
            </div>
            <div class="stat-value" style="font-size:1.5rem;">@Model.MonthlyRevenue.ToString("C")</div>
            <div class="stat-label">Revenue This Month</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stat-card">
            <div class="stat-icon primary">
                <i class="bi bi-people-fill"></i>
            </div>
            <div class="stat-value">@Model.ActiveMemberCount</div>
            <div class="stat-label">Active Members</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stat-card">
            <div class="stat-icon accent">
                <i class="bi bi-calendar-check-fill"></i>
            </div>
            <div class="stat-value">@Model.TodaySessionsCount</div>
            <div class="stat-label">Today's Sessions</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stat-card">
            <div class="stat-icon danger">
                <i class="bi bi-exclamation-triangle-fill"></i>
            </div>
            <div class="stat-value">@Model.ExpiringSoonCount</div>
            <div class="stat-label">Expiring (7 days)</div>
        </div>
    </div>
</div>

<div class="row g-4 mb-4">
    <div class="col-md-6">
        <div class="premium-card">
            <div class="premium-card-header">
                <h5 class="mb-0"><i class="bi bi-people me-2" style="color: var(--primary);"></i>New Members Per Month</h5>
            </div>
            <div class="premium-card-body">
                <canvas id="membersChart" height="200"></canvas>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="premium-card">
            <div class="premium-card-header">
                <h5 class="mb-0"><i class="bi bi-cash-stack me-2" style="color: var(--success);"></i>Revenue Per Month</h5>
            </div>
            <div class="premium-card-body">
                <canvas id="revenueChart" height="200"></canvas>
            </div>
        </div>
    </div>
</div>

<div class="row g-4 mb-4">
    <div class="col-md-6">
        <div class="premium-card">
            <div class="premium-card-header">
                <h5 class="mb-0"><i class="bi bi-pie-chart me-2" style="color: var(--secondary);"></i>Members by Plan</h5>
            </div>
            <div class="premium-card-body">
                <canvas id="planChart" height="200"></canvas>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="premium-card">
            <div class="premium-card-header">
                <h5 class="mb-0"><i class="bi bi-trophy me-2" style="color: var(--accent);"></i>Top 5 Sessions</h5>
            </div>
            <div class="premium-card-body">
                <table class="table align-middle mb-0">
                    <thead>
                        <tr><th>Session</th><th>Bookings</th><th>Capacity</th><th>Fill Rate</th></tr>
                    </thead>
                    <tbody>
                        @foreach (var s in Model.TopSessions)
                        {
                            <tr>
                                <td class="fw-semibold">@s.SessionName</td>
                                <td>@s.BookingCount</td>
                                <td>@s.Capacity</td>
                                <td>
                                    <div class="d-flex align-items-center gap-2">
                                        <div class="progress flex-grow-1" style="height:6px">
                                            <div class="progress-bar" style="width:@(s.Capacity > 0 ? (s.BookingCount * 100 / s.Capacity) : 0)%"></div>
                                        </div>
                                        <small class="fw-semibold" style="color: var(--primary);">@(s.Capacity > 0 ? (s.BookingCount * 100 / s.Capacity) : 0)%</small>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts
{
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <script>
        const isDark = document.documentElement.getAttribute('data-theme') === 'dark';
        const textColor = isDark ? '#f5f5f4' : '#292524';
        const gridColor = isDark ? 'rgba(255,255,255,0.06)' : 'rgba(0,0,0,0.06)';

        new Chart(document.getElementById('membersChart'), {
            type: 'line',
            data: {
                labels: [@Html.Raw(string.Join(",", Model.NewMembersPerMonth.Select(m => $"'{m.Label}'")))],
                datasets: [{
                    label: 'New Members',
                    data: [@string.Join(",", Model.NewMembersPerMonth.Select(m => m.Count))],
                    borderColor: '#f97316',
                    backgroundColor: 'rgba(249,115,22,0.08)',
                    fill: true,
                    tension: 0.4,
                    pointBackgroundColor: '#f97316',
                    pointRadius: 4
                }]
            },
            options: {
                responsive: true,
                plugins: { legend: { labels: { color: textColor } } },
                scales: {
                    x: { ticks: { color: textColor }, grid: { color: gridColor } },
                    y: { ticks: { color: textColor }, grid: { color: gridColor } }
                }
            }
        });

        new Chart(document.getElementById('revenueChart'), {
            type: 'bar',
            data: {
                labels: [@Html.Raw(string.Join(",", Model.RevenuePerMonth.Select(m => $"'{m.Label}'")))],
                datasets: [{
                    label: 'Revenue',
                    data: [@string.Join(",", Model.RevenuePerMonth.Select(r => r.Revenue))],
                    backgroundColor: isDark ? 'rgba(249,115,22,0.6)' : 'rgba(249,115,22,0.8)',
                    borderColor: '#f97316',
                    borderWidth: 1,
                    borderRadius: 6
                }]
            },
            options: {
                responsive: true,
                plugins: { legend: { labels: { color: textColor } } },
                scales: {
                    x: { ticks: { color: textColor }, grid: { color: gridColor } },
                    y: { ticks: { color: textColor }, grid: { color: gridColor } }
                }
            }
        });

        new Chart(document.getElementById('planChart'), {
            type: 'doughnut',
            data: {
                labels: [@Html.Raw(string.Join(",", Model.MembersByPlan.Select(p => $"'{p.PlanName}'")))],
                datasets: [{
                    data: [@string.Join(",", Model.MembersByPlan.Select(p => p.MemberCount))],
                    backgroundColor: ['#f97316', '#a855f7', '#22c55e', '#06b6d4', '#eab308', '#ef4444'],
                    borderWidth: 0
                }]
            },
            options: {
                responsive: true,
                cutout: '60%',
                plugins: { legend: { position: 'bottom', labels: { color: textColor, padding: 16 } } }
            }
        });
    </script>
}
