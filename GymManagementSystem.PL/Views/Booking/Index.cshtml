@model PagedResultDisplay<BookingViewModel>
@{
    ViewData["Title"] = "Bookings";
    var search = ViewBag.Search as string;
}

<div class="mb-8 flex flex-col md:flex-row md:items-end justify-between gap-6 border-b border-zinc-200 dark:border-gym-border pb-6">
    <div>
        <h2 class="text-3xl font-display font-bold text-zinc-900 dark:text-white mb-2">Gym <span class="text-transparent bg-clip-text bg-gradient-to-r from-neon-green to-neon-cyan">Bookings</span></h2>
        <p class="text-zinc-500 dark:text-zinc-400">View and manage all member bookings with QR check-in.</p>
    </div>
    <div class="flex flex-wrap items-center gap-3">
        <a asp-controller="Attendance" asp-action="Scan" class="btn-outline border-blue-500 text-blue-500 hover:bg-blue-50 dark:hover:bg-blue-500/10 py-2 text-sm transition-colors shadow-sm">
            <i class="bi bi-qr-code-scan mr-2"></i> Scan QR
        </a>
        <a asp-action="Create" class="btn-primary py-2 text-sm shadow-[0_0_15px_rgba(57,255,20,0.3)]">
            <i class="bi bi-plus-circle mr-2"></i> New Booking
        </a>
    </div>
</div>

<form method="get" class="mb-6 flex flex-col sm:flex-row gap-4 items-center justify-between">
    <div class="w-full sm:w-96 flex relative">
        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
            <i class="bi bi-search text-zinc-400"></i>
        </div>
        <input type="text" name="search" value="@search" class="input-field pl-10 w-full" placeholder="Search by member name..." />
        <button type="submit" class="absolute inset-y-0 right-0 px-4 text-sm font-medium text-white bg-zinc-800 dark:bg-zinc-700 hover:bg-zinc-700 dark:hover:bg-zinc-600 rounded-r-lg transition-colors">
            Search
        </button>
    </div>
    <div class="text-sm font-medium text-zinc-500 dark:text-zinc-400 bg-zinc-100 dark:bg-zinc-800 px-4 py-2 rounded-full border border-zinc-200 dark:border-zinc-700">
        @Model.TotalCount booking(s) found
    </div>
</form>

<div class="glass-card overflow-hidden">
    <div class="overflow-x-auto w-full">
        <table class="w-full text-left border-collapse whitespace-nowrap">
            <thead>
                <tr class="border-b border-zinc-200 dark:border-zinc-800 bg-zinc-50 dark:bg-zinc-900/30">
                    <th class="py-4 px-6 font-semibold text-xs text-zinc-500 dark:text-zinc-400 uppercase tracking-wider">Member</th>
                    <th class="py-4 px-6 font-semibold text-xs text-zinc-500 dark:text-zinc-400 uppercase tracking-wider">Session</th>
                    <th class="py-4 px-6 font-semibold text-xs text-zinc-500 dark:text-zinc-400 uppercase tracking-wider">Date</th>
                    <th class="py-4 px-6 font-semibold text-xs text-zinc-500 dark:text-zinc-400 uppercase tracking-wider">Status</th>
                    <th class="py-4 px-6 font-semibold text-xs text-zinc-500 dark:text-zinc-400 uppercase tracking-wider text-right">Actions</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-zinc-200 dark:divide-zinc-800 text-zinc-700 dark:text-zinc-300">
                @if (Model.Items.Any())
                {
                    foreach (var item in Model.Items)
                    {
                        <tr class="hover:bg-zinc-50 dark:hover:bg-zinc-800/40 transition-colors">
                            <td class="py-4 px-6">
                                <div class="font-bold text-zinc-900 dark:text-white">@item.MemberName</div>
                            </td>
                            <td class="py-4 px-6">
                                <div class="font-medium text-zinc-900 dark:text-zinc-200">@item.SessionName</div>
                                <div class="text-xs text-zinc-500 dark:text-zinc-400 mt-1">@(item.ScheduleTime?.ToString("dd MMM yyyy - hh:mm tt") ?? "")</div>
                            </td>
                            <td class="py-4 px-6 font-medium">@item.BookingDate.ToString("dd MMM yyyy")</td>
                            <td class="py-4 px-6">
                                @if (item.IsAttended)
                                {
                                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-500/10 text-green-600 dark:text-green-400 border border-green-500/20 mb-1">Attended</span>
                                    <div class="text-[10px] text-zinc-500 dark:text-zinc-400 font-medium">@item.CheckedInAt?.ToString("hh:mm tt")</div>
                                }
                                else
                                {
                                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-yellow-500/10 text-yellow-600 dark:text-yellow-400 border border-yellow-500/20">Pending</span>
                                }
                            </td>
                            <td class="py-4 px-6 text-right">
                                <div class="flex items-center justify-end gap-2">
                                    <a asp-controller="Attendance" asp-action="MyQr" asp-route-bookingId="@item.Id" class="p-2 text-zinc-400 hover:text-blue-500 bg-white dark:bg-zinc-800 border border-zinc-200 dark:border-zinc-700 rounded-lg transition-colors shadow-sm" title="View QR">
                                        <i class="bi bi-qr-code"></i>
                                    </a>
                                    <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="inline">
                                        <button type="submit" class="p-2 text-zinc-400 hover:text-red-500 bg-white dark:bg-zinc-800 border border-zinc-200 dark:border-zinc-700 rounded-lg transition-colors shadow-sm" title="Delete" onclick="return confirm('Are you sure you want to delete this booking?');">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="5" class="py-12 text-center">
                            <div class="w-16 h-16 mx-auto rounded-full bg-zinc-100 dark:bg-zinc-800 flex items-center justify-center mb-4 border border-zinc-200 dark:border-zinc-700">
                                <i class="bi bi-calendar-x text-3xl text-zinc-400 dark:text-zinc-500"></i>
                            </div>
                            <h3 class="text-lg font-bold text-zinc-900 dark:text-white mb-2">No bookings found</h3>
                            <p class="text-zinc-500 dark:text-zinc-400">There are no bookings matching your criteria.</p>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (Model.TotalPages > 1)
    {
        <div class="px-6 py-4 border-t border-zinc-200 dark:border-zinc-800 bg-zinc-50 dark:bg-zinc-900/30 flex items-center justify-center">
            <nav class="flex items-center gap-1">
                <a asp-route-page="@(Model.Page - 1)" asp-route-search="@search" class="w-10 h-10 flex items-center justify-center rounded-lg border border-zinc-200 dark:border-zinc-700 bg-white dark:bg-zinc-800 text-zinc-500 hover:bg-zinc-50 dark:hover:bg-zinc-700 transition-colors @(!Model.HasPreviousPage ? "opacity-50 pointer-events-none" : "")">
                    <i class="bi bi-chevron-left"></i>
                </a>
                
                <div class="flex gap-1 mx-2">
                    @for (int i = 1; i <= Model.TotalPages; i++)
                    {
                        <a asp-route-page="@i" asp-route-search="@search" class="w-10 h-10 flex items-center justify-center rounded-lg font-medium transition-colors @(i == Model.Page ? "bg-neon-cyan text-black shadow-[0_0_10px_rgba(0,255,255,0.3)]" : "bg-white dark:bg-zinc-800 text-zinc-700 dark:text-zinc-300 border border-zinc-200 dark:border-zinc-700 hover:bg-zinc-50 dark:hover:bg-zinc-700")">
                            @i
                        </a>
                    }
                </div>
                
                <a asp-route-page="@(Model.Page + 1)" asp-route-search="@search" class="w-10 h-10 flex items-center justify-center rounded-lg border border-zinc-200 dark:border-zinc-700 bg-white dark:bg-zinc-800 text-zinc-500 hover:bg-zinc-50 dark:hover:bg-zinc-700 transition-colors @(!Model.HasNextPage ? "opacity-50 pointer-events-none" : "")">
                    <i class="bi bi-chevron-right"></i>
                </a>
            </nav>
        </div>
    }
</div>
