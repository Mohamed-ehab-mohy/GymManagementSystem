@model GymManagementSystem.PL.Models.ErrorViewModel
@{
    ViewData["Title"] = $"Error {Model.StatusCode}";
    Layout = "_Layout";
}

<div class="flex items-center justify-center min-h-[70vh]">
    <div class="page-card p-10 max-w-lg w-full text-center">
        <div class="w-20 h-20 mx-auto rounded-full flex items-center justify-center text-4xl mb-5" style="background: @(Model.StatusColor)15; color: @(Model.StatusColor);">
            <i class="bi @Model.StatusIcon"></i>
        </div>

        <div class="text-5xl font-bold text-slate-900 dark:text-white mb-2 tracking-tight" style="color: @(Model.StatusColor);">
            @Model.StatusCode
        </div>
        <h1 class="text-xl font-semibold text-slate-900 dark:text-white mb-2">@Model.Title</h1>
        <p class="text-sm text-slate-500 dark:text-slate-400 mb-6">@Model.Message</p>

        <div class="flex gap-3 justify-center">
            <a href="/" class="btn-primary py-2.5 px-6">
                <i class="bi bi-house mr-1"></i> Go Home
            </a>
            <a href="javascript:history.back()" class="btn-outline py-2.5 px-6">
                <i class="bi bi-arrow-left mr-1"></i> Go Back
            </a>
        </div>

        @if (Model.ShowRequestId)
        {
            <div class="mt-6 text-xs text-slate-400 dark:text-slate-500 font-mono">
                Request ID: @Model.RequestId
            </div>
        }

        @if (!string.IsNullOrEmpty(Model.ExceptionDetails))
        {
            <div class="mt-4 bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 rounded-lg p-3 text-left font-mono text-xs text-red-600 dark:text-red-400 whitespace-pre-wrap max-h-48 overflow-y-auto">
                @Model.ExceptionDetails
            </div>
        }
    </div>
</div>
