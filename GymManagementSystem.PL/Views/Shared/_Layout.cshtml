<!DOCTYPE html>
<html lang="en" x-data="{ darkMode: localStorage.getItem('gympro-theme') !== 'light' }" x-bind:class="{ 'dark': darkMode }">
<head>
    <script>
        if (localStorage.getItem('gympro-theme') === 'light' || (!('gympro-theme' in localStorage) && !window.matchMedia('(prefers-color-scheme: dark)').matches)) {
            document.documentElement.classList.remove('dark')
        } else {
            document.documentElement.classList.add('dark')
        }
    </script>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — GymPro</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />

    <link rel="stylesheet" href="~/css/style.css" asp-append-version="true" />

    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
    <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'%3E%3Crect width='32' height='32' rx='8' fill='%232563eb'/%3E%3Ctext x='16' y='22' text-anchor='middle' fill='white' font-size='18' font-weight='bold' font-family='sans-serif'%3EG%3C/text%3E%3C/svg%3E" />
</head>
<body class="bg-slate-50 dark:bg-slate-900 text-slate-900 dark:text-slate-100 font-sans antialiased min-h-screen flex items-center justify-center">
    <div class="w-full max-w-md px-4">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="mb-6 rounded-lg bg-emerald-50 dark:bg-emerald-900/20 p-4 border border-emerald-200 dark:border-emerald-800 text-emerald-700 dark:text-emerald-400 flex items-start gap-3 text-sm">
                <i class="bi bi-check-circle-fill mt-0.5"></i>
                <div>@TempData["SuccessMessage"]</div>
            </div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="mb-6 rounded-lg bg-red-50 dark:bg-red-900/20 p-4 border border-red-200 dark:border-red-800 text-red-700 dark:text-red-400 flex items-start gap-3 text-sm">
                <i class="bi bi-exclamation-triangle-fill mt-0.5"></i>
                <div>@TempData["ErrorMessage"]</div>
            </div>
        }

        @RenderBody()

        <div class="mt-8 text-center">
            <button @@click="darkMode = !darkMode; localStorage.setItem('gympro-theme', darkMode ? 'dark' : 'light')" type="button" class="btn-ghost p-2 text-slate-400">
                <i class="bi bi-moon" x-show="!darkMode"></i>
                <i class="bi bi-sun" x-show="darkMode" style="display: none;"></i>
            </button>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
