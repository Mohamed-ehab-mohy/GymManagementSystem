<!DOCTYPE html>
<html lang="en" x-data="{ darkMode: localStorage.getItem('gympro-theme') !== 'light' }" x-bind:class="{ 'dark': darkMode }">
<head>
    <script>
        if (localStorage.getItem('gympro-theme') === 'light' || (!('gympro-theme' in localStorage) && !window.matchMedia('(prefers-color-scheme: dark)').matches)) {
            document.documentElement.classList.remove('dark')
        } else {
            document.documentElement.classList.add('dark')
        }
    </script>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — GymPro Management</title>
    
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Outfit:wght@500;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />
    
    <link rel="stylesheet" href="~/css/style.css" asp-append-version="true" />
    
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
    <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'%3E%3Crect width='32' height='32' rx='8' fill='%2339ff14'/%3E%3Ctext x='16' y='22' text-anchor='middle' fill='black' font-size='18' font-weight='bold' font-family='sans-serif'%3EG%3C/text%3E%3C/svg%3E" />
</head>
<body class="bg-zinc-50 dark:bg-gym-darker text-zinc-900 dark:text-zinc-100 font-sans antialiased selection:bg-neon-green selection:text-black min-h-screen flex flex-col transition-colors duration-300">
    <header x-data="{ mobileMenuOpen: false, profileMenuOpen: false, notificationsOpen: false }" class="sticky top-0 z-50 w-full glass-card overflow-visible border-x-0 border-t-0 rounded-none bg-white/80 dark:bg-gym-card/80">
        <nav class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8" aria-label="Top">
            <div class="flex h-16 items-center justify-between">
                <div class="flex items-center">
                    <a asp-area="" asp-controller="Home" asp-action="Index" class="flex items-center gap-3 group">
                        <div class="w-10 h-10 rounded-xl bg-neon-green/10 flex items-center justify-center border border-neon-green/30 group-hover:shadow-[0_0_15px_rgba(57,255,20,0.4)] transition-all duration-300">
                            <i class="bi bi-dumbbell text-neon-green text-xl"></i>
                        </div>
                        <span class="font-display font-bold text-xl tracking-tight text-zinc-900 dark:text-white group-hover:text-neon-green transition-colors">GymPro</span>
                    </a>
                </div>
                
                <!-- Desktop Navigation -->
                <div class="hidden md:flex items-center space-x-1">
                    @if (User.IsInRole("Member"))
                    {
                        <a asp-controller="Dashboard" asp-action="Index" class="px-3 py-2 rounded-lg text-sm font-medium text-zinc-500 dark:text-zinc-300 hover:text-zinc-900 dark:hover:text-white hover:bg-zinc-100 dark:hover:bg-zinc-800 transition-colors @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Dashboard" ? "text-neon-cyan dark:text-neon-green bg-neon-cyan/10 dark:bg-neon-green/10 font-semibold" : "")">Dashboard</a>
                        <a asp-controller="Bookings" asp-action="Index" class="px-3 py-2 rounded-lg text-sm font-medium text-zinc-500 dark:text-zinc-300 hover:text-zinc-900 dark:hover:text-white hover:bg-zinc-100 dark:hover:bg-zinc-800 transition-colors @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Bookings" && ViewContext.RouteData.Values["Action"]?.ToString() == "Index" ? "text-neon-cyan dark:text-neon-green bg-neon-cyan/10 dark:bg-neon-green/10 font-semibold" : "")">Book Session</a>
                        <a asp-controller="Bookings" asp-action="Mine" class="px-3 py-2 rounded-lg text-sm font-medium text-zinc-500 dark:text-zinc-300 hover:text-zinc-900 dark:hover:text-white hover:bg-zinc-100 dark:hover:bg-zinc-800 transition-colors @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Bookings" && ViewContext.RouteData.Values["Action"]?.ToString() == "Mine" ? "text-neon-cyan dark:text-neon-green bg-neon-cyan/10 dark:bg-neon-green/10 font-semibold" : "")">My Bookings</a>
                    }
                    else
                    {
                        <a asp-controller="Dashboard" asp-action="Index" class="px-3 py-2 rounded-lg text-sm font-medium text-zinc-500 dark:text-zinc-300 hover:text-zinc-900 dark:hover:text-white hover:bg-zinc-100 dark:hover:bg-zinc-800 transition-colors @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Dashboard" ? "text-neon-cyan dark:text-neon-green bg-neon-cyan/10 dark:bg-neon-green/10 font-semibold" : "")">Dashboard</a>
                        <a asp-controller="Members" asp-action="Index" class="px-3 py-2 rounded-lg text-sm font-medium text-zinc-500 dark:text-zinc-300 hover:text-zinc-900 dark:hover:text-white hover:bg-zinc-100 dark:hover:bg-zinc-800 transition-colors @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Members" ? "text-neon-cyan dark:text-neon-green bg-neon-cyan/10 dark:bg-neon-green/10 font-semibold" : "")">Members</a>
                        <a asp-controller="Trainers" asp-action="Index" class="px-3 py-2 rounded-lg text-sm font-medium text-zinc-500 dark:text-zinc-300 hover:text-zinc-900 dark:hover:text-white hover:bg-zinc-100 dark:hover:bg-zinc-800 transition-colors @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Trainers" ? "text-neon-cyan dark:text-neon-green bg-neon-cyan/10 dark:bg-neon-green/10 font-semibold" : "")">Trainers</a>
                        <a asp-controller="ClassSessions" asp-action="Index" class="px-3 py-2 rounded-lg text-sm font-medium text-zinc-500 dark:text-zinc-300 hover:text-zinc-900 dark:hover:text-white hover:bg-zinc-100 dark:hover:bg-zinc-800 transition-colors @(ViewContext.RouteData.Values["Controller"]?.ToString() == "ClassSessions" ? "text-neon-cyan dark:text-neon-green bg-neon-cyan/10 dark:bg-neon-green/10 font-semibold" : "")">Sessions</a>
                        <a asp-controller="Plans" asp-action="Index" class="px-3 py-2 rounded-lg text-sm font-medium text-zinc-500 dark:text-zinc-300 hover:text-zinc-900 dark:hover:text-white hover:bg-zinc-100 dark:hover:bg-zinc-800 transition-colors @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Plans" ? "text-neon-cyan dark:text-neon-green bg-neon-cyan/10 dark:bg-neon-green/10 font-semibold" : "")">Plans</a>
                        <a asp-controller="Bookings" asp-action="Index" class="px-3 py-2 rounded-lg text-sm font-medium text-zinc-500 dark:text-zinc-300 hover:text-zinc-900 dark:hover:text-white hover:bg-zinc-100 dark:hover:bg-zinc-800 transition-colors @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Bookings" ? "text-neon-cyan dark:text-neon-green bg-neon-cyan/10 dark:bg-neon-green/10 font-semibold" : "")">Bookings</a>
                        <a asp-controller="Analytics" asp-action="Index" class="px-3 py-2 rounded-lg text-sm font-medium text-zinc-500 dark:text-zinc-300 hover:text-zinc-900 dark:hover:text-white hover:bg-zinc-100 dark:hover:bg-zinc-800 transition-colors @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Analytics" ? "text-neon-cyan dark:text-neon-green bg-neon-cyan/10 dark:bg-neon-green/10 font-semibold" : "")">Analytics</a>
                    }
                </div>

                <div class="hidden md:flex items-center gap-4">
                    <!-- Theme Toggle -->
                    <button @@click="darkMode = !darkMode; localStorage.setItem('gympro-theme', darkMode ? 'dark' : 'light')" type="button" class="p-2 text-zinc-400 hover:text-zinc-900 dark:hover:text-white transition-colors bg-zinc-100 dark:bg-zinc-800 rounded-full border border-zinc-200 dark:border-zinc-700 w-10 h-10 flex items-center justify-center mr-2">
                        <i class="bi bi-moon-fill" x-show="!darkMode"></i>
                        <i class="bi bi-brightness-high-fill text-yellow-400" x-show="darkMode" style="display: none;"></i>
                    </button>

                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <!-- Notifications -->
                        <div class="relative" @@click.outside="notificationsOpen = false">
                            <button @@click="notificationsOpen = !notificationsOpen" type="button" class="relative p-2 text-zinc-500 dark:text-zinc-400 hover:text-zinc-900 dark:hover:text-white transition-colors">
                                <i class="bi bi-bell text-xl"></i>
                                <span id="notificationBadge" class="absolute top-1 right-1 flex h-4 w-4 items-center justify-center rounded-full bg-neon-orange text-[10px] font-bold text-white shadow-[0_0_10px_rgba(255,94,0,0.5)]">0</span>
                            </button>
                            
                            <div x-show="notificationsOpen" x-transition.opacity.duration.200ms class="absolute right-0 mt-2 w-80 origin-top-right rounded-xl bg-white dark:bg-gym-card border border-zinc-200 dark:border-gym-border shadow-lg dark:shadow-glass focus:outline-none overflow-hidden z-[100]" style="display: none;">
                                <div class="px-4 py-3 border-b border-zinc-200 dark:border-gym-border bg-zinc-50 dark:bg-zinc-900/50">
                                    <p class="text-sm font-bold text-zinc-900 dark:text-white">Notifications</p>
                                </div>
                                <ul id="notificationList" class="max-h-72 overflow-y-auto py-1">
                                    <li class="px-4 py-6 text-center text-sm text-zinc-500" id="noNotifications">No notifications</li>
                                </ul>
                            </div>
                        </div>

                        <!-- Profile dropdown -->
                        <div class="relative ml-3" @@click.outside="profileMenuOpen = false">
                            <button @@click="profileMenuOpen = !profileMenuOpen" type="button" class="flex items-center gap-2 rounded-full text-sm focus:outline-none focus:ring-2 focus:ring-neon-cyan focus:ring-offset-2 focus:ring-offset-white dark:focus:ring-offset-gym-darker">
                                <div class="h-8 w-8 rounded-full bg-gradient-to-tr from-neon-cyan to-neon-green flex items-center justify-center text-black font-bold shadow-[0_0_10px_rgba(0,255,255,0.3)]">
                                    @(User.Identity.Name?.Substring(0,1).ToUpper() ?? "U")
                                </div>
                                <span class="text-zinc-700 dark:text-zinc-300 hidden lg:block font-medium">@User.Identity.Name</span>
                                <i class="bi bi-chevron-down text-zinc-400 text-xs"></i>
                            </button>

                            <div x-show="profileMenuOpen" x-transition.opacity.duration.200ms class="absolute right-0 mt-2 w-48 origin-top-right rounded-xl bg-white dark:bg-gym-card py-1 shadow-lg dark:shadow-glass border border-zinc-200 dark:border-gym-border focus:outline-none z-[100]" style="display: none;">
                                <form asp-controller="Account" asp-action="Logout" method="post" class="block w-full">
                                    <button type="submit" class="block w-full px-4 py-2 text-left text-sm font-medium text-zinc-700 dark:text-zinc-300 hover:bg-zinc-50 dark:hover:bg-zinc-800 hover:text-zinc-900 dark:hover:text-white transition-colors">Sign out</button>
                                </form>
                            </div>
                        </div>
                    }
                    else
                    {
                        <a asp-controller="Account" asp-action="Login" class="btn-primary py-2 px-6 text-sm shadow-[0_0_15px_rgba(57,255,20,0.3)]">Sign In</a>
                    }
                </div>

                <!-- Mobile menu button -->
                <div class="flex items-center md:hidden gap-3">
                    <button @@click="darkMode = !darkMode; localStorage.setItem('gympro-theme', darkMode ? 'dark' : 'light')" type="button" class="p-2 text-zinc-500 dark:text-zinc-400">
                        <i class="bi bi-moon-fill" x-show="!darkMode"></i>
                        <i class="bi bi-brightness-high-fill text-yellow-400" x-show="darkMode" style="display: none;"></i>
                    </button>
                    
                    <button @@click="mobileMenuOpen = !mobileMenuOpen" type="button" class="inline-flex items-center justify-center rounded-md p-2 text-zinc-500 dark:text-zinc-400 hover:bg-zinc-100 dark:hover:bg-zinc-800 hover:text-zinc-900 dark:hover:text-white focus:outline-none focus:ring-2 focus:ring-inset focus:ring-neon-cyan" aria-expanded="false">
                        <span class="sr-only">Open main menu</span>
                        <i class="bi bi-list text-2xl" x-show="!mobileMenuOpen"></i>
                        <i class="bi bi-x-lg text-xl" x-show="mobileMenuOpen" style="display: none;"></i>
                    </button>
                </div>
            </div>
        </nav>

        <!-- Mobile menu -->
        <div x-show="mobileMenuOpen" x-transition class="md:hidden border-t border-zinc-200 dark:border-gym-border bg-white/95 dark:bg-gym-card/95 backdrop-blur-md" style="display: none;">
            <div class="space-y-1 px-2 pb-3 pt-2">
                @if (User.IsInRole("Member"))
                {
                    <a asp-controller="Dashboard" asp-action="Index" class="block rounded-md px-3 py-2 text-base font-medium text-zinc-700 dark:text-white hover:bg-zinc-100 dark:hover:bg-zinc-800 @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Dashboard" ? "text-neon-cyan dark:text-neon-green bg-neon-cyan/10 dark:bg-neon-green/10" : "")">Dashboard</a>
                    <a asp-controller="Bookings" asp-action="Index" class="block rounded-md px-3 py-2 text-base font-medium text-zinc-700 dark:text-white hover:bg-zinc-100 dark:hover:bg-zinc-800 @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Bookings" && ViewContext.RouteData.Values["Action"]?.ToString() == "Index" ? "text-neon-cyan dark:text-neon-green bg-neon-cyan/10 dark:bg-neon-green/10" : "")">Book Session</a>
                    <a asp-controller="Bookings" asp-action="Mine" class="block rounded-md px-3 py-2 text-base font-medium text-zinc-700 dark:text-white hover:bg-zinc-100 dark:hover:bg-zinc-800 @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Bookings" && ViewContext.RouteData.Values["Action"]?.ToString() == "Mine" ? "text-neon-cyan dark:text-neon-green bg-neon-cyan/10 dark:bg-neon-green/10" : "")">My Bookings</a>
                }
                else
                {
                    <a asp-controller="Dashboard" asp-action="Index" class="block rounded-md px-3 py-2 text-base font-medium text-zinc-700 dark:text-white hover:bg-zinc-100 dark:hover:bg-zinc-800 @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Dashboard" ? "text-neon-cyan dark:text-neon-green bg-neon-cyan/10 dark:bg-neon-green/10" : "")">Dashboard</a>
                    <a asp-controller="Members" asp-action="Index" class="block rounded-md px-3 py-2 text-base font-medium text-zinc-700 dark:text-white hover:bg-zinc-100 dark:hover:bg-zinc-800 @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Members" ? "text-neon-cyan dark:text-neon-green bg-neon-cyan/10 dark:bg-neon-green/10" : "")">Members</a>
                    <a asp-controller="Trainers" asp-action="Index" class="block rounded-md px-3 py-2 text-base font-medium text-zinc-700 dark:text-white hover:bg-zinc-100 dark:hover:bg-zinc-800 @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Trainers" ? "text-neon-cyan dark:text-neon-green bg-neon-cyan/10 dark:bg-neon-green/10" : "")">Trainers</a>
                    <a asp-controller="ClassSessions" asp-action="Index" class="block rounded-md px-3 py-2 text-base font-medium text-zinc-700 dark:text-white hover:bg-zinc-100 dark:hover:bg-zinc-800 @(ViewContext.RouteData.Values["Controller"]?.ToString() == "ClassSessions" ? "text-neon-cyan dark:text-neon-green bg-neon-cyan/10 dark:bg-neon-green/10" : "")">Sessions</a>
                    <a asp-controller="Plans" asp-action="Index" class="block rounded-md px-3 py-2 text-base font-medium text-zinc-700 dark:text-white hover:bg-zinc-100 dark:hover:bg-zinc-800 @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Plans" ? "text-neon-cyan dark:text-neon-green bg-neon-cyan/10 dark:bg-neon-green/10" : "")">Plans</a>
                    <a asp-controller="Bookings" asp-action="Index" class="block rounded-md px-3 py-2 text-base font-medium text-zinc-700 dark:text-white hover:bg-zinc-100 dark:hover:bg-zinc-800 @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Bookings" ? "text-neon-cyan dark:text-neon-green bg-neon-cyan/10 dark:bg-neon-green/10" : "")">Bookings</a>
                    <a asp-controller="Analytics" asp-action="Index" class="block rounded-md px-3 py-2 text-base font-medium text-zinc-700 dark:text-white hover:bg-zinc-100 dark:hover:bg-zinc-800 @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Analytics" ? "text-neon-cyan dark:text-neon-green bg-neon-cyan/10 dark:bg-neon-green/10" : "")">Analytics</a>
                }
                
                @if (!User.Identity?.IsAuthenticated == true)
                {
                    <div class="mt-4 border-t border-zinc-200 dark:border-gym-border pt-4 px-3">
                        <a asp-controller="Account" asp-action="Login" class="btn-primary w-full justify-center">Sign In</a>
                    </div>
                }
            </div>
            
            @if (User.Identity?.IsAuthenticated == true)
            {
                <div class="border-t border-zinc-200 dark:border-gym-border pb-3 pt-4">
                    <div class="flex items-center px-5 gap-3">
                        <div class="h-10 w-10 rounded-full bg-gradient-to-tr from-neon-cyan to-neon-green flex items-center justify-center text-black font-bold shadow-[0_0_10px_rgba(0,255,255,0.3)]">
                            @(User.Identity.Name?.Substring(0,1).ToUpper() ?? "U")
                        </div>
                        <div class="ml-3">
                            <div class="text-base font-bold text-zinc-900 dark:text-white">@User.Identity.Name</div>
                        </div>
                    </div>
                    <div class="mt-3 space-y-1 px-2">
                        <form asp-controller="Account" asp-action="Logout" method="post" class="block w-full">
                            <button type="submit" class="block w-full rounded-md px-3 py-2 text-base font-medium text-zinc-600 dark:text-zinc-400 hover:bg-zinc-100 dark:hover:bg-zinc-800 hover:text-zinc-900 dark:hover:text-white text-left transition-colors">Sign out</button>
                        </form>
                    </div>
                </div>
            }
        </div>
    </header>

    <main class="flex-grow w-full max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="mb-6 rounded-lg bg-green-50 dark:bg-green-500/10 p-4 border border-green-200 dark:border-green-500/20 text-green-700 dark:text-green-400 flex items-start gap-3 font-medium">
                <i class="bi bi-check-circle-fill mt-0.5"></i>
                <div>@TempData["SuccessMessage"]</div>
            </div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="mb-6 rounded-lg bg-red-50 dark:bg-red-500/10 p-4 border border-red-200 dark:border-red-500/20 text-red-700 dark:text-red-400 flex items-start gap-3 font-medium">
                <i class="bi bi-exclamation-triangle-fill mt-0.5"></i>
                <div>@TempData["ErrorMessage"]</div>
            </div>
        }
        @if (TempData["WarningMessage"] != null)
        {
            <div class="mb-6 rounded-lg bg-yellow-50 dark:bg-yellow-500/10 p-4 border border-yellow-200 dark:border-yellow-500/20 text-yellow-700 dark:text-yellow-400 flex items-start gap-3 font-medium">
                <i class="bi bi-exclamation-circle-fill mt-0.5"></i>
                <div>@TempData["WarningMessage"]</div>
            </div>
        }
        
        @RenderBody()
    </main>

    <footer class="mt-auto border-t border-zinc-200 dark:border-gym-border pt-12 pb-8 bg-white/80 dark:bg-gym-card/80 backdrop-blur-md">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="grid grid-cols-1 md:grid-cols-4 gap-8 mb-8">
                <!-- Brand & Description -->
                <div class="md:col-span-2">
                    <a asp-area="" asp-controller="Home" asp-action="Index" class="flex items-center gap-3 mb-4 group inline-flex">
                        <div class="w-10 h-10 rounded-xl bg-neon-green/10 flex items-center justify-center border border-neon-green/30 group-hover:shadow-[0_0_15px_rgba(57,255,20,0.4)] transition-all duration-300">
                            <i class="bi bi-dumbbell text-neon-green text-xl"></i>
                        </div>
                        <span class="font-display font-bold text-xl tracking-tight text-zinc-900 dark:text-white group-hover:text-neon-green transition-colors">GymPro</span>
                    </a>
                    <p class="text-zinc-500 dark:text-zinc-400 text-sm leading-relaxed max-w-sm mb-4">
                        The ultimate fitness management platform. Streamline your gym operations, engage your members, and scale your business with modern tools.
                    </p>
                    <div class="flex gap-3">
                        <a href="#" class="w-8 h-8 rounded-full bg-zinc-100 dark:bg-zinc-800 flex items-center justify-center text-zinc-500 hover:text-neon-cyan hover:bg-neon-cyan/10 transition-colors">
                            <i class="bi bi-facebook"></i>
                        </a>
                        <a href="#" class="w-8 h-8 rounded-full bg-zinc-100 dark:bg-zinc-800 flex items-center justify-center text-zinc-500 hover:text-neon-cyan hover:bg-neon-cyan/10 transition-colors">
                            <i class="bi bi-twitter-x"></i>
                        </a>
                        <a href="#" class="w-8 h-8 rounded-full bg-zinc-100 dark:bg-zinc-800 flex items-center justify-center text-zinc-500 hover:text-neon-cyan hover:bg-neon-cyan/10 transition-colors">
                            <i class="bi bi-instagram"></i>
                        </a>
                    </div>
                </div>

                <!-- Quick Links -->
                <div>
                    <h3 class="text-zinc-900 dark:text-white font-bold mb-4 uppercase tracking-wider text-xs">Quick Links</h3>
                    <ul class="space-y-2">
                        <li><a asp-controller="Dashboard" asp-action="Index" class="text-zinc-500 dark:text-zinc-400 hover:text-neon-cyan transition-colors text-sm">Dashboard</a></li>
                        <li><a asp-controller="Members" asp-action="Index" class="text-zinc-500 dark:text-zinc-400 hover:text-neon-cyan transition-colors text-sm">Members Directory</a></li>
                        <li><a asp-controller="Plans" asp-action="Index" class="text-zinc-500 dark:text-zinc-400 hover:text-neon-cyan transition-colors text-sm">Plans & Pricing</a></li>
                        <li><a asp-controller="ClassSessions" asp-action="Index" class="text-zinc-500 dark:text-zinc-400 hover:text-neon-cyan transition-colors text-sm">Class Schedule</a></li>
                    </ul>
                </div>

                <!-- Legal & Support -->
                <div>
                    <h3 class="text-zinc-900 dark:text-white font-bold mb-4 uppercase tracking-wider text-xs">Support</h3>
                    <ul class="space-y-2">
                        <li><a href="#" class="text-zinc-500 dark:text-zinc-400 hover:text-neon-cyan transition-colors text-sm">Help Center</a></li>
                        <li><a href="#" class="text-zinc-500 dark:text-zinc-400 hover:text-neon-cyan transition-colors text-sm">Privacy Policy</a></li>
                        <li><a href="#" class="text-zinc-500 dark:text-zinc-400 hover:text-neon-cyan transition-colors text-sm">Terms of Service</a></li>
                        <li><a href="#" class="text-zinc-500 dark:text-zinc-400 hover:text-neon-cyan transition-colors text-sm">Contact Us</a></li>
                    </ul>
                </div>
            </div>
            
            <div class="border-t border-zinc-200 dark:border-zinc-800 pt-8 flex flex-col md:flex-row items-center justify-between gap-4">
                <div class="text-sm font-medium text-zinc-500">
                    &copy; @DateTime.Now.Year GymPro Management. All rights reserved.
                </div>
                <div class="flex items-center gap-1 text-sm text-zinc-500">
                    Made with <i class="bi bi-heart-fill text-red-500 mx-1"></i> by Mohamed Ehab
                </div>
            </div>
        </div>
    </footer>

    <!-- Scripts -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
    
    <script>
        // Notification Logic
        (function () {
            const connection = new signalR.HubConnectionBuilder()
                .withUrl("/hubs/notifications")
                .withAutomaticReconnect()
                .build();

            connection.on("ReceiveNotification", function (message) {
                const badge = document.getElementById("notificationBadge");
                const list = document.getElementById("notificationList");
                const noMsg = document.getElementById("noNotifications");
                if (noMsg) noMsg.remove();

                const current = parseInt(badge.textContent) || 0;
                badge.textContent = current + 1;

                const item = document.createElement("li");
                item.className = "px-4 py-3 hover:bg-zinc-50 dark:hover:bg-zinc-800 transition-colors border-b border-zinc-100 dark:border-gym-border/50";
                item.innerHTML = `<a class="block text-sm text-zinc-700 dark:text-zinc-300 font-medium" href="/Notifications">${message}</a>`;
                list.insertBefore(item, list.firstChild);

                // Toast Notification using Tailwind
                const toast = document.createElement("div");
                toast.className = "fixed bottom-4 right-4 z-[9999] bg-white dark:bg-gym-card border border-neon-cyan rounded-lg shadow-lg dark:shadow-neon-cyan p-4 flex items-center gap-3 transition-opacity duration-300";
                toast.innerHTML = `
                    <div class="w-8 h-8 rounded-full bg-neon-cyan/20 flex items-center justify-center text-neon-cyan shrink-0">
                        <i class="bi bi-bell-fill"></i>
                    </div>
                    <div class="text-sm font-medium text-zinc-800 dark:text-zinc-200">${message}</div>
                    <button type="button" class="ml-2 text-zinc-400 hover:text-zinc-900 dark:text-zinc-500 dark:hover:text-white" onclick="this.parentElement.remove()">
                        <i class="bi bi-x-lg"></i>
                    </button>
                `;
                document.body.appendChild(toast);
                setTimeout(() => { toast.style.opacity = '0'; setTimeout(() => toast.remove(), 300); }, 5000);
            });

            connection.start().then(function () {
                fetch('/Notifications/GetUnreadCount')
                    .then(r => r.json())
                    .then(d => { if (d.count > 0) document.getElementById("notificationBadge").textContent = d.count; });
            }).catch(function () {});
        })();
    </script>

    @await RenderSectionAsync("Scripts", required: false)

    <!-- Chatbot Widget using Tailwind & Alpine -->
    <div x-data="{ chatOpen: false }" class="fixed bottom-6 right-6 z-[9999] flex flex-col items-end">
        <!-- Chat Panel -->
        <div x-show="chatOpen" 
             x-transition:enter="transition ease-out duration-200"
             x-transition:enter-start="opacity-0 translate-y-4 scale-95"
             x-transition:enter-end="opacity-100 translate-y-0 scale-100"
             x-transition:leave="transition ease-in duration-150"
             x-transition:leave-start="opacity-100 translate-y-0 scale-100"
             x-transition:leave-end="opacity-0 translate-y-4 scale-95"
             class="mb-4 w-[340px] rounded-2xl glass-card overflow-hidden flex flex-col h-[460px]" 
             style="display:none;">
            
            <!-- Header -->
            <div class="bg-gradient-to-r from-neon-cyan to-neon-green p-4 flex justify-between items-center shrink-0">
                <strong class="text-black font-display text-lg font-bold">Gym Assistant</strong>
                <button @@click="chatOpen = false" class="text-black/70 hover:text-black transition-colors">
                    <i class="bi bi-x-lg text-lg"></i>
                </button>
            </div>
            
            <!-- Messages Area -->
            <div id="chatbot-messages" class="flex-1 overflow-y-auto p-4 space-y-3 bg-zinc-50/90 dark:bg-gym-card/50">
                <!-- Messages will be injected here -->
                <div id="chatbot-suggestions" class="flex flex-wrap gap-2 mt-auto"></div>
            </div>
            
            <!-- Input Area -->
            <div class="p-3 bg-white dark:bg-zinc-900 border-t border-zinc-200 dark:border-gym-border flex gap-2 shrink-0">
                <input id="chatbot-input" type="text" class="flex-1 bg-zinc-50 dark:bg-zinc-800 border border-zinc-200 dark:border-zinc-700 rounded-lg px-3 py-2 text-sm text-zinc-900 dark:text-white placeholder-zinc-400 dark:placeholder-zinc-500 focus:outline-none focus:border-neon-cyan focus:ring-1 focus:ring-neon-cyan transition-colors" placeholder="Type a message..." @@keydown.enter="window.ask()" />
                <button id="chatbot-send" onclick="window.ask()" class="btn-secondary px-3 py-2 rounded-lg shadow-[0_0_10px_rgba(0,255,255,0.3)]">
                    <i class="bi bi-send-fill text-black"></i>
                </button>
            </div>
        </div>

        <!-- Chat Toggle Button -->
        <button @@click="chatOpen = !chatOpen" class="w-14 h-14 rounded-full bg-neon-green flex items-center justify-center text-black shadow-[0_0_15px_rgba(57,255,20,0.5)] hover:bg-[#32e011] hover:scale-105 transition-all duration-300 focus:outline-none">
            <i class="bi bi-chat-dots-fill text-2xl" x-show="!chatOpen"></i>
            <i class="bi bi-x-lg text-2xl" x-show="chatOpen" style="display:none;"></i>
        </button>
    </div>

    <!-- Chatbot Logic -->
    <script>
        (function () {
            var input = document.getElementById('chatbot-input');
            var messages = document.getElementById('chatbot-messages');
            var suggestions = document.getElementById('chatbot-suggestions');
            var hasStarted = false;

            var chips = [
                'What are your opening hours?',
                'What plans do you have?',
                'Do you have a free trial?',
                'What classes are available?',
                'مواعيد العمل؟',
                'الخطط المتاحة؟',
                'هل يوجد تجربة مجانية؟',
                'ما هي الحصص المتاحة؟'
            ];

            function showSuggestions() {
                suggestions.innerHTML = '';
                chips.forEach(function (text) {
                    var chip = document.createElement('button');
                    chip.className = 'px-3 py-1.5 rounded-full border border-neon-cyan/50 text-zinc-700 dark:text-neon-cyan text-xs font-semibold hover:bg-neon-cyan hover:text-black transition-colors text-left bg-white dark:bg-transparent';
                    chip.textContent = text;
                    chip.onclick = function () { window.askMessage(text); };
                    suggestions.appendChild(chip);
                });
            }

            function hideSuggestions() {
                suggestions.innerHTML = '';
            }

            function addMessage(text, isUser) {
                var div = document.createElement('div');
                div.className = 'max-w-[85%] rounded-2xl px-4 py-2 text-sm font-medium ' + (isUser ? 'bg-neon-cyan text-black ml-auto rounded-br-sm shadow-sm' : 'bg-white dark:bg-zinc-800 text-zinc-800 dark:text-zinc-200 mr-auto rounded-bl-sm border border-zinc-200 dark:border-zinc-700 shadow-sm');
                div.textContent = text;
                messages.insertBefore(div, suggestions);
                messages.scrollTop = messages.scrollHeight;
            }

            window.askMessage = function(msg) {
                if (!msg) return;
                addMessage(msg, true);
                hideSuggestions();
                
                var typing = document.createElement('div');
                typing.className = 'bg-white dark:bg-zinc-800 text-zinc-400 rounded-2xl rounded-bl-sm px-4 py-2 text-sm mr-auto w-16 border border-zinc-200 dark:border-zinc-700 shadow-sm';
                typing.innerHTML = '<span class="animate-pulse">...</span>';
                typing.id = 'typing-indicator';
                messages.insertBefore(typing, suggestions);
                messages.scrollTop = messages.scrollHeight;

                fetch('/Chatbot/Ask', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                    body: 'message=' + encodeURIComponent(msg)
                })
                .then(function (r) { return r.json(); })
                .then(function (d) {
                    var t = document.getElementById('typing-indicator');
                    if (t) t.remove();
                    addMessage(d.response, false);
                    showSuggestions();
                })
                .catch(function () {
                    var t = document.getElementById('typing-indicator');
                    if (t) t.remove();
                    addMessage('Sorry, something went wrong.', false);
                    showSuggestions();
                });
            };

            window.ask = function() {
                window.askMessage(input.value.trim());
                input.value = '';
            };

            // Initialize chat on first open
            document.querySelector('[x-data="{ chatOpen: false }"]').addEventListener('click', function(e) {
                if(!hasStarted) {
                    addMessage('Ask me anything!', false);
                    showSuggestions();
                    hasStarted = true;
                }
            });
        })();
    </script>
</body>
</html>
