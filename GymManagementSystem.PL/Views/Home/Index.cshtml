@{
    ViewData["Title"] = "Home";
}

@if (User.Identity?.IsAuthenticated == true)
{
    <div class="mb-6">
        <h1 class="page-title">Welcome back, @User.Identity.Name</h1>
        <p class="page-subtitle mt-1">Here's your gym overview for today.</p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
        <div class="stat-card">
            <div class="flex items-center justify-between mb-3">
                <div class="w-10 h-10 rounded-lg bg-primary-50 dark:bg-primary-900/20 flex items-center justify-center">
                    <i class="bi bi-people-fill text-primary-600 dark:text-primary-400"></i>
                </div>
            </div>
            <div class="text-2xl font-bold text-slate-900 dark:text-white mb-0.5" id="totalMembers">&mdash;</div>
            <div class="text-xs text-slate-500 dark:text-slate-400">Total Members</div>
        </div>

        <div class="stat-card">
            <div class="flex items-center justify-between mb-3">
                <div class="w-10 h-10 rounded-lg bg-purple-50 dark:bg-purple-900/20 flex items-center justify-center">
                    <i class="bi bi-calendar-check-fill text-purple-600 dark:text-purple-400"></i>
                </div>
            </div>
            <div class="text-2xl font-bold text-slate-900 dark:text-white mb-0.5" id="todaySessions">&mdash;</div>
            <div class="text-xs text-slate-500 dark:text-slate-400">Today's Sessions</div>
        </div>

        <div class="stat-card">
            <div class="flex items-center justify-between mb-3">
                <div class="w-10 h-10 rounded-lg bg-emerald-50 dark:bg-emerald-900/20 flex items-center justify-center">
                    <i class="bi bi-graph-up-arrow text-emerald-600 dark:text-emerald-400"></i>
                </div>
            </div>
            <div class="text-2xl font-bold text-slate-900 dark:text-white mb-0.5" id="activeMemberships">&mdash;</div>
            <div class="text-xs text-slate-500 dark:text-slate-400">Active Plans</div>
        </div>

        <div class="stat-card">
            <div class="flex items-center justify-between mb-3">
                <div class="w-10 h-10 rounded-lg bg-amber-50 dark:bg-amber-900/20 flex items-center justify-center">
                    <i class="bi bi-currency-dollar text-amber-600 dark:text-amber-400"></i>
                </div>
            </div>
            <div class="text-2xl font-bold text-slate-900 dark:text-white mb-0.5" id="monthlyRevenue">&mdash;</div>
            <div class="text-xs text-slate-500 dark:text-slate-400">Revenue (Month)</div>
        </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="page-card">
            <div class="px-5 py-4 border-b border-slate-200 dark:border-slate-700">
                <h5 class="text-sm font-semibold text-slate-900 dark:text-white flex items-center gap-2">
                    <i class="bi bi-lightning-charge-fill text-primary-600 dark:text-primary-400"></i> Quick Actions
                </h5>
            </div>
            <div class="p-5">
                <div class="grid grid-cols-2 gap-3">
                    <a asp-controller="Members" asp-action="Index" class="btn-outline flex flex-col items-center justify-center py-5 hover:border-primary-300 hover:text-primary-600 dark:hover:border-primary-700 dark:hover:text-primary-400 transition-colors">
                        <i class="bi bi-people text-2xl mb-2 text-slate-400 dark:text-slate-500"></i>
                        <span class="text-sm">Members</span>
                    </a>
                    <a asp-controller="Bookings" asp-action="Index" class="btn-outline flex flex-col items-center justify-center py-5 hover:border-primary-300 hover:text-primary-600 dark:hover:border-primary-700 dark:hover:text-primary-400 transition-colors">
                        <i class="bi bi-calendar-check text-2xl mb-2 text-slate-400 dark:text-slate-500"></i>
                        <span class="text-sm">Bookings</span>
                    </a>
                    <a asp-controller="Analytics" asp-action="Index" class="btn-outline flex flex-col items-center justify-center py-5 hover:border-primary-300 hover:text-primary-600 dark:hover:border-primary-700 dark:hover:text-primary-400 transition-colors">
                        <i class="bi bi-graph-up text-2xl mb-2 text-slate-400 dark:text-slate-500"></i>
                        <span class="text-sm">Analytics</span>
                    </a>
                    <a asp-controller="Plans" asp-action="Index" class="btn-outline flex flex-col items-center justify-center py-5 hover:border-primary-300 hover:text-primary-600 dark:hover:border-primary-700 dark:hover:text-primary-400 transition-colors">
                        <i class="bi bi-box-seam text-2xl mb-2 text-slate-400 dark:text-slate-500"></i>
                        <span class="text-sm">Plans</span>
                    </a>
                </div>
            </div>
        </div>
        <div class="page-card">
            <div class="px-5 py-4 border-b border-slate-200 dark:border-slate-700">
                <h5 class="text-sm font-semibold text-slate-900 dark:text-white flex items-center gap-2">
                    <i class="bi bi-clock-fill text-primary-600 dark:text-primary-400"></i> Today's Schedule
                </h5>
            </div>
            <div class="p-5 flex flex-col items-center justify-center h-[250px] text-center">
                <div class="w-14 h-14 rounded-full bg-slate-100 dark:bg-slate-700 flex items-center justify-center mb-3">
                    <i class="bi bi-calendar2-x text-2xl text-slate-400 dark:text-slate-500"></i>
                </div>
                <p class="text-sm text-slate-500 dark:text-slate-400 mb-3">Session schedule will appear here.</p>
                <a asp-controller="ClassSessions" asp-action="Index" class="btn-primary py-2 px-5 text-sm">Go to Sessions</a>
            </div>
        </div>
    </div>

    @section Scripts {
        <script>
            (async function() {
                try {
                    const r = await fetch('/Analytics/GetStats');
                    if (!r.ok) return;
                    const d = await r.json();
                    document.getElementById('totalMembers').textContent = d.activeMembers ?? '\u2014';
                    document.getElementById('todaySessions').textContent = d.todaySessions ?? '\u2014';
                    document.getElementById('activeMemberships').textContent = d.activePlans ?? '\u2014';
                    document.getElementById('monthlyRevenue').textContent = d.revenue != null ? '$' + d.revenue.toLocaleString() : '\u2014';
                } catch(e) {}
            })();
        </script>
    }
}
else
{
    <!-- Landing Page for Unauthenticated Users -->
    <div class="flex flex-col items-center justify-center py-16 text-center">
        <div class="w-20 h-20 rounded-2xl bg-primary-600 flex items-center justify-center text-white text-4xl mb-6">
            <i class="bi bi-bezier2"></i>
        </div>

        <h1 class="text-4xl md:text-5xl font-bold text-slate-900 dark:text-white mb-4 tracking-tight">
            The Ultimate<br/>Gym Management Platform
        </h1>

        <p class="text-lg text-slate-500 dark:text-slate-400 mb-10 max-w-xl leading-relaxed">
            Streamline your fitness business. Manage members, schedule classes, and track analytics effortlessly.
        </p>

        <div class="flex flex-col sm:flex-row gap-4">
            <a asp-controller="Account" asp-action="Register" class="btn-primary py-3 px-8 text-base">
                <i class="bi bi-rocket-takeoff mr-2"></i> Get Started Free
            </a>
            <a asp-controller="Account" asp-action="Login" class="btn-outline py-3 px-8 text-base">
                <i class="bi bi-box-arrow-in-right mr-2"></i> Sign In
            </a>
        </div>
    </div>

    <div class="border-t border-slate-200 dark:border-slate-700 my-12"></div>

    <div class="mb-12">
        <div class="text-center mb-10">
            <h2 class="text-2xl font-bold text-slate-900 dark:text-white mb-2">Everything you need</h2>
            <p class="text-slate-500 dark:text-slate-400">Powerful features for modern gyms.</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            <div class="page-card p-6 text-center">
                <div class="w-12 h-12 rounded-xl bg-primary-50 dark:bg-primary-900/20 flex items-center justify-center mx-auto mb-4">
                    <i class="bi bi-people-fill text-primary-600 dark:text-primary-400 text-xl"></i>
                </div>
                <h3 class="text-base font-semibold text-slate-900 dark:text-white mb-2">Member Management</h3>
                <p class="text-sm text-slate-500 dark:text-slate-400">Register, track, and manage members with profiles and QR scanning.</p>
            </div>

            <div class="page-card p-6 text-center">
                <div class="w-12 h-12 rounded-xl bg-purple-50 dark:bg-purple-900/20 flex items-center justify-center mx-auto mb-4">
                    <i class="bi bi-calendar-week-fill text-purple-600 dark:text-purple-400 text-xl"></i>
                </div>
                <h3 class="text-base font-semibold text-slate-900 dark:text-white mb-2">Session Scheduling</h3>
                <p class="text-sm text-slate-500 dark:text-slate-400">Create and manage sessions with trainers and capacity tracking.</p>
            </div>

            <div class="page-card p-6 text-center">
                <div class="w-12 h-12 rounded-xl bg-emerald-50 dark:bg-emerald-900/20 flex items-center justify-center mx-auto mb-4">
                    <i class="bi bi-graph-up-arrow text-emerald-600 dark:text-emerald-400 text-xl"></i>
                </div>
                <h3 class="text-base font-semibold text-slate-900 dark:text-white mb-2">Analytics & Reports</h3>
                <p class="text-sm text-slate-500 dark:text-slate-400">Real-time dashboards with revenue tracking and beautiful charts.</p>
            </div>
        </div>
    </div>
}
