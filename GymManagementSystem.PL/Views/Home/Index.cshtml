@{
    ViewData["Title"] = "Dashboard";
}

@if (User.Identity?.IsAuthenticated == true)
{
    <div class="welcome-header">
        <h1>Welcome back, <span class="text-gradient">@User.Identity.Name</span></h1>
        <p>Here's your gym overview for today.</p>
    </div>

    <div class="row g-4 mt-2">
        <div class="col-md-3">
            <div class="stat-card">
                <div class="stat-icon primary">
                    <i class="bi bi-people-fill"></i>
                </div>
                <div class="stat-value" id="totalMembers">—</div>
                <div class="stat-label">Total Members</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="stat-card">
                <div class="stat-icon secondary">
                    <i class="bi bi-calendar-check-fill"></i>
                </div>
                <div class="stat-value" id="todaySessions">—</div>
                <div class="stat-label">Today's Sessions</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="stat-card">
                <div class="stat-icon success">
                    <i class="bi bi-graph-up-arrow"></i>
                </div>
                <div class="stat-value" id="activeMemberships">—</div>
                <div class="stat-label">Active Plans</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="stat-card">
                <div class="stat-icon accent">
                    <i class="bi bi-currency-dollar"></i>
                </div>
                <div class="stat-value" id="monthlyRevenue">—</div>
                <div class="stat-label">Revenue (Month)</div>
            </div>
        </div>
    </div>

    <hr class="section-divider" />

    <div class="row g-4">
        <div class="col-md-6">
            <div class="premium-card">
                <div class="premium-card-header">
                    <h5 class="mb-0"><i class="bi bi-lightning-charge-fill me-2" style="color: var(--primary);"></i>Quick Actions</h5>
                </div>
                <div class="premium-card-body">
                    <div class="d-grid gap-3">
                        <a asp-controller="Members" asp-action="Index" class="btn btn-glass"><i class="bi bi-people"></i> Manage Members</a>
                        <a asp-controller="Bookings" asp-action="Index" class="btn btn-glass"><i class="bi bi-calendar-check"></i> View Bookings</a>
                        <a asp-controller="Analytics" asp-action="Index" class="btn btn-glass"><i class="bi bi-graph-up"></i> Analytics</a>
                        <a asp-controller="Plans" asp-action="Index" class="btn btn-glass"><i class="bi bi-box-seam"></i> Plans & Pricing</a>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="premium-card">
                <div class="premium-card-header">
                    <h5 class="mb-0"><i class="bi bi-clock-fill me-2" style="color: var(--secondary);"></i>Today's Schedule</h5>
                </div>
                <div class="premium-card-body">
                    <p class="text-muted mb-0">Session schedule will appear here. Navigate to <a asp-controller="ClassSessions" asp-action="Index">Sessions</a> to manage.</p>
                </div>
            </div>
        </div>
    </div>

    @section Scripts {
        <script>
            (async function() {
                try {
                    const r = await fetch('/Analytics/GetStats');
                    if (!r.ok) return;
                    const d = await r.json();
                    document.getElementById('totalMembers').textContent = d.activeMembers ?? '—';
                    document.getElementById('todaySessions').textContent = d.todaySessions ?? '—';
                    document.getElementById('activeMemberships').textContent = d.activePlans ?? '—';
                    document.getElementById('monthlyRevenue').textContent = d.revenue != null ? '$' + d.revenue.toLocaleString() : '—';
                } catch(e) {}
            })();
        </script>
    }
}
else
{
    <div class="text-center py-5">
        <div class="row align-items-center justify-content-center" style="min-height: 60vh;">
            <div class="col-lg-8 mx-auto">
                <div class="mb-4">
                    <span class="brand-icon-lg d-inline-flex mx-auto" style="width:72px;height:72px;border-radius:20px;background:var(--gradient);color:#fff;font-size:2rem;align-items:center;justify-content:center;box-shadow:0 12px 32px var(--primary-glow);">
                        <i class="bi bi-dumbbell"></i>
                    </span>
                </div>
                <h1 class="display-4 fw-bold mb-3">
                    <span class="text-gradient">GymPro</span> Management
                </h1>
                <p class="lead mb-4 text-muted fs-5" style="max-width: 600px; margin: 0 auto;">
                    Complete gym management platform — members, plans, sessions, payments, and analytics, all in one place.
                </p>
                <div class="d-flex gap-3 justify-content-center flex-wrap mt-4">
                    <a asp-controller="Account" asp-action="Login" class="btn btn-gradient btn-lg px-5 py-3">
                        <i class="bi bi-box-arrow-in-right"></i> Sign In
                    </a>
                    <a asp-controller="Account" asp-action="Register" class="btn btn-glass btn-lg px-5 py-3">
                        <i class="bi bi-person-plus"></i> Register
                    </a>
                </div>
            </div>
        </div>
    </div>

    <hr class="section-divider" />

    <div class="row g-4 pb-5">
        <div class="col-md-4">
            <div class="premium-card p-4 text-center h-100">
                <div class="stat-icon primary mx-auto" style="width:56px;height:56px;border-radius:14px;display:flex;align-items:center;justify-content:center;font-size:1.5rem;margin-bottom:1rem;">
                    <i class="bi bi-people-fill"></i>
                </div>
                <h5 class="fw-bold mb-2">Member Management</h5>
                <p class="text-muted small mb-0">Register, track, and manage all gym members with detailed profiles and history.</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="premium-card p-4 text-center h-100">
                <div class="stat-icon secondary mx-auto" style="width:56px;height:56px;border-radius:14px;display:flex;align-items:center;justify-content:center;font-size:1.5rem;margin-bottom:1rem;">
                    <i class="bi bi-calendar-week-fill"></i>
                </div>
                <h5 class="fw-bold mb-2">Session Scheduling</h5>
                <p class="text-muted small mb-0">Create and manage group sessions with trainer assignments and capacity tracking.</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="premium-card p-4 text-center h-100">
                <div class="stat-icon success mx-auto" style="width:56px;height:56px;border-radius:14px;display:flex;align-items:center;justify-content:center;font-size:1.5rem;margin-bottom:1rem;">
                    <i class="bi bi-graph-up-arrow"></i>
                </div>
                <h5 class="fw-bold mb-2">Analytics & Reports</h5>
                <p class="text-muted small mb-0">Real-time dashboard with revenue tracking, attendance metrics, and exportable reports.</p>
            </div>
        </div>
    </div>
}
