@model GymManagementSystem.PL.ViewModels.MemberViewModel

@{
    ViewData["Title"] = "Member Details";
}

<div class="mb-6 flex flex-col md:flex-row md:items-center md:justify-between gap-4">
    <div>
        <h1 class="page-title">Member Profile</h1>
        <p class="page-subtitle mt-1">Detailed information and status.</p>
    </div>
    <div class="flex flex-wrap gap-3">
        <a asp-action="Index" class="btn-outline py-2 text-sm">
            <i class="bi bi-list mr-1"></i> Back to List
        </a>
        <a asp-action="Edit" asp-route-id="@Model?.Id" class="btn-primary py-2 text-sm">
            <i class="bi bi-pencil mr-1"></i> Edit Member
        </a>
    </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6 items-start">
    <!-- Profile Card -->
    <div class="page-card p-6 flex flex-col items-center text-center">
        @if (!string.IsNullOrEmpty(Model?.Photo))
        {
            <img src="@Model.Photo" alt="@Model.FirstName @Model.LastName" class="w-28 h-28 rounded-full object-cover mb-4 border-4 border-white dark:border-slate-800" />
        }
        else
        {
            <div class="w-28 h-28 rounded-full bg-primary-100 dark:bg-primary-900/30 flex items-center justify-center text-primary-700 dark:text-primary-400 text-4xl font-bold mb-4">
                @Model?.FirstName?.Substring(0, 1)@Model?.LastName?.Substring(0, 1)
            </div>
        }

        <h3 class="text-xl font-bold text-slate-900 dark:text-white mb-1">@Model?.FirstName @Model?.LastName</h3>
        <p class="badge-info mb-3">Gym Member</p>
        <span class="text-xs text-slate-500 dark:text-slate-400 mb-4">
            Joined @Model?.JoinDate.ToString("MMM dd, yyyy")
        </span>

        <div class="w-full space-y-2 mt-2">
            <button class="w-full btn-outline py-2 text-sm">
                <i class="bi bi-envelope mr-1"></i> Send Email
            </button>
            <button class="w-full btn-outline py-2 text-sm">
                <i class="bi bi-whatsapp mr-1"></i> Message
            </button>
        </div>
    </div>

    <!-- Details Card -->
    <div class="lg:col-span-2 page-card overflow-hidden">
        <div class="p-6">
            <h4 class="text-base font-semibold text-slate-900 dark:text-white mb-4 flex items-center gap-2">
                <i class="bi bi-person-lines-fill text-primary-600 dark:text-primary-400"></i> Personal Information
            </h4>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-y-5 gap-x-8">
                <div>
                    <label class="block text-xs font-medium text-slate-500 dark:text-slate-400 uppercase tracking-wider mb-1">Email</label>
                    <p class="text-sm text-slate-900 dark:text-slate-200">@Model?.Email</p>
                </div>
                <div>
                    <label class="block text-xs font-medium text-slate-500 dark:text-slate-400 uppercase tracking-wider mb-1">Phone</label>
                    <p class="text-sm text-slate-900 dark:text-slate-200">@Model?.PhoneNumber</p>
                </div>
                <div>
                    <label class="block text-xs font-medium text-slate-500 dark:text-slate-400 uppercase tracking-wider mb-1">Date of Birth</label>
                    <p class="text-sm text-slate-900 dark:text-slate-200">@Model?.DateOfBirth.ToString("MMM dd, yyyy")</p>
                </div>
                <div>
                    <label class="block text-xs font-medium text-slate-500 dark:text-slate-400 uppercase tracking-wider mb-1">Gender</label>
                    <p class="text-sm text-slate-900 dark:text-slate-200">@Model?.Gender</p>
                </div>
                <div class="md:col-span-2">
                    <label class="block text-xs font-medium text-slate-500 dark:text-slate-400 uppercase tracking-wider mb-1">Address</label>
                    <p class="text-sm text-slate-900 dark:text-slate-200">@Model?.Street, @Model?.City, @Model?.State @Model?.ZipCode</p>
                </div>
            </div>

            <div class="border-t border-slate-200 dark:border-slate-700 my-6"></div>

            <h4 class="text-base font-semibold text-slate-900 dark:text-white mb-4 flex items-center gap-2">
                <i class="bi bi-shield-plus text-primary-600 dark:text-primary-400"></i> Emergency Contact
            </h4>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-y-5 gap-x-8">
                <div>
                    <label class="block text-xs font-medium text-slate-500 dark:text-slate-400 uppercase tracking-wider mb-1">Name</label>
                    <p class="text-sm text-slate-900 dark:text-slate-200">@(string.IsNullOrEmpty(Model?.EmergencyContactName) ? "N/A" : Model.EmergencyContactName)</p>
                </div>
                <div>
                    <label class="block text-xs font-medium text-slate-500 dark:text-slate-400 uppercase tracking-wider mb-1">Phone</label>
                    <p class="text-sm text-slate-900 dark:text-slate-200">@(string.IsNullOrEmpty(Model?.EmergencyContactPhone) ? "N/A" : Model.EmergencyContactPhone)</p>
                </div>
            </div>

            <div class="border-t border-slate-200 dark:border-slate-700 my-6"></div>

            <!-- Health Data -->
            <div x-data="{ open: false }" class="border border-slate-200 dark:border-slate-700 rounded-lg overflow-hidden">
                <button @@click="open = !open" class="w-full px-5 py-3 flex items-center justify-between focus:outline-none hover:bg-slate-50 dark:hover:bg-slate-700/30 transition-colors">
                    <div class="flex items-center gap-3">
                        <i class="bi bi-heart-pulse-fill text-primary-600 dark:text-primary-400"></i>
                        <span class="font-semibold text-sm text-slate-900 dark:text-white">Health Data</span>
                    </div>
                    <i class="bi text-slate-400 transition-transform duration-200" :class="open ? 'bi-chevron-up' : 'bi-chevron-down'"></i>
                </button>

                <div x-show="open" x-collapse>
                    <div class="p-5 border-t border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-800/50">
                        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                            <div>
                                <label class="block text-xs font-medium text-slate-500 dark:text-slate-400 uppercase tracking-wider mb-1">Height</label>
                                <p class="text-sm text-slate-900 dark:text-slate-200">@Model?.Height cm</p>
                            </div>
                            <div>
                                <label class="block text-xs font-medium text-slate-500 dark:text-slate-400 uppercase tracking-wider mb-1">Weight</label>
                                <p class="text-sm text-slate-900 dark:text-slate-200">@Model?.Weight kg</p>
                            </div>
                            <div>
                                <label class="block text-xs font-medium text-slate-500 dark:text-slate-400 uppercase tracking-wider mb-1">Blood Type</label>
                                <p class="text-sm text-slate-900 dark:text-slate-200">@Model?.BloodType</p>
                            </div>
                            <div class="md:col-span-3">
                                <label class="block text-xs font-medium text-slate-500 dark:text-slate-400 uppercase tracking-wider mb-1">Notes</label>
                                <p class="text-sm text-slate-700 dark:text-slate-300">@(string.IsNullOrEmpty(Model?.Note) ? "No health notes recorded." : Model.Note)</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
