@model GymManagementSystem.PL.ViewModels.MemberViewModel

@{
    ViewData["Title"] = "Member Details";
}

<div class="mb-8 flex flex-col md:flex-row md:items-end justify-between gap-6 border-b border-zinc-200 dark:border-gym-border pb-6">
    <div>
        <h2 class="text-3xl font-display font-bold text-zinc-900 dark:text-white mb-1">Member <span class="text-transparent bg-clip-text bg-gradient-to-r from-neon-cyan to-blue-500">Profile</span></h2>
        <p class="text-zinc-500 dark:text-zinc-400">Detailed information and status.</p>
    </div>
    <div class="flex flex-wrap gap-3">
        <a asp-action="Index" class="btn-outline border-zinc-300 dark:border-zinc-700 py-2 text-sm">
            <i class="bi bi-list mr-2"></i> Back to List
        </a>
        <a asp-action="Edit" asp-route-id="@Model?.Id" class="btn-primary py-2 text-sm shadow-[0_0_15px_rgba(0,255,255,0.3)]">
            <i class="bi bi-pencil mr-2"></i> Edit Member
        </a>
    </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-8 items-start">
    <!-- Profile Card -->
    <div class="glass-card p-8 flex flex-col items-center text-center">
        @if (!string.IsNullOrEmpty(Model?.Photo))
        {
            <img src="@Model.Photo" alt="@Model.FirstName @Model.LastName" class="w-32 h-32 rounded-full object-cover shadow-lg border-4 border-white dark:border-zinc-800 mb-6" />
        }
        else
        {
            <div class="w-32 h-32 rounded-full bg-gradient-to-tr from-neon-cyan to-blue-500 flex items-center justify-center text-white text-5xl font-bold shadow-[0_0_20px_rgba(0,255,255,0.4)] mb-6 border-4 border-white dark:border-zinc-800">
                @Model?.FirstName?.Substring(0, 1)@Model?.LastName?.Substring(0, 1)
            </div>
        }
        
        <h3 class="text-2xl font-bold text-zinc-900 dark:text-white mb-1">@Model?.FirstName @Model?.LastName</h3>
        <p class="text-neon-cyan font-semibold mb-3">Gym Member</p>
        <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium bg-zinc-100 dark:bg-zinc-800 text-zinc-600 dark:text-zinc-400 mb-6">
            Joined @Model?.JoinDate.ToString("MMM dd, yyyy")
        </span>

        <div class="w-full space-y-3 mt-4">
            <button class="w-full btn-outline border-zinc-300 dark:border-zinc-700 py-2.5 text-sm hover:border-blue-500 hover:text-blue-500 dark:hover:border-blue-500 dark:hover:text-blue-500 group transition-colors">
                <i class="bi bi-envelope mr-2 text-zinc-400 group-hover:text-blue-500 transition-colors"></i> Send Email
            </button>
            <button class="w-full btn-outline border-zinc-300 dark:border-zinc-700 py-2.5 text-sm hover:border-green-500 hover:text-green-500 dark:hover:border-green-500 dark:hover:text-green-500 group transition-colors">
                <i class="bi bi-whatsapp mr-2 text-zinc-400 group-hover:text-green-500 transition-colors"></i> Message
            </button>
        </div>
    </div>

    <!-- Details Card -->
    <div class="lg:col-span-2 glass-card overflow-hidden">
        <div class="p-8">
            <h4 class="text-lg font-bold text-zinc-900 dark:text-white mb-6 flex items-center gap-2">
                <i class="bi bi-person-lines-fill text-neon-cyan"></i> Personal Information
            </h4>
            
            <div class="grid grid-cols-1 md:grid-cols-2 gap-y-6 gap-x-8">
                <div>
                    <label class="block text-xs font-bold text-zinc-500 dark:text-zinc-400 uppercase tracking-wider mb-1">Email Address</label>
                    <p class="text-zinc-900 dark:text-zinc-200 font-medium">@Model?.Email</p>
                </div>
                <div>
                    <label class="block text-xs font-bold text-zinc-500 dark:text-zinc-400 uppercase tracking-wider mb-1">Phone Number</label>
                    <p class="text-zinc-900 dark:text-zinc-200 font-medium">@Model?.PhoneNumber</p>
                </div>
                <div>
                    <label class="block text-xs font-bold text-zinc-500 dark:text-zinc-400 uppercase tracking-wider mb-1">Date of Birth</label>
                    <p class="text-zinc-900 dark:text-zinc-200 font-medium">@Model?.DateOfBirth.ToString("MMM dd, yyyy")</p>
                </div>
                <div>
                    <label class="block text-xs font-bold text-zinc-500 dark:text-zinc-400 uppercase tracking-wider mb-1">Gender</label>
                    <p class="text-zinc-900 dark:text-zinc-200 font-medium">@Model?.Gender</p>
                </div>
                <div class="md:col-span-2">
                    <label class="block text-xs font-bold text-zinc-500 dark:text-zinc-400 uppercase tracking-wider mb-1">Address</label>
                    <p class="text-zinc-900 dark:text-zinc-200 font-medium">@Model?.Street, @Model?.City, @Model?.State @Model?.ZipCode</p>
                </div>
            </div>

            <div class="border-t border-zinc-200 dark:border-zinc-800 my-8"></div>

            <h4 class="text-lg font-bold text-zinc-900 dark:text-white mb-6 flex items-center gap-2">
                <i class="bi bi-shield-plus text-neon-orange"></i> Emergency Contact
            </h4>
            
            <div class="grid grid-cols-1 md:grid-cols-2 gap-y-6 gap-x-8">
                <div>
                    <label class="block text-xs font-bold text-zinc-500 dark:text-zinc-400 uppercase tracking-wider mb-1">Contact Name</label>
                    <p class="text-zinc-900 dark:text-zinc-200 font-medium">@(string.IsNullOrEmpty(Model?.EmergencyContactName) ? "N/A" : Model.EmergencyContactName)</p>
                </div>
                <div>
                    <label class="block text-xs font-bold text-zinc-500 dark:text-zinc-400 uppercase tracking-wider mb-1">Contact Phone</label>
                    <p class="text-zinc-900 dark:text-zinc-200 font-medium">@(string.IsNullOrEmpty(Model?.EmergencyContactPhone) ? "N/A" : Model.EmergencyContactPhone)</p>
                </div>
            </div>
            
            <div class="border-t border-zinc-200 dark:border-zinc-800 my-8"></div>

            <!-- Health Data (Alpine Accordion) -->
            <div x-data="{ open: false }" class="border border-zinc-200 dark:border-zinc-800 rounded-xl overflow-hidden bg-zinc-50 dark:bg-zinc-900/30">
                <button @@click="open = !open" class="w-full px-6 py-4 flex items-center justify-between focus:outline-none hover:bg-zinc-100 dark:hover:bg-zinc-800/50 transition-colors">
                    <div class="flex items-center gap-3">
                        <div class="w-8 h-8 rounded-lg bg-red-500/10 flex items-center justify-center text-red-500">
                            <i class="bi bi-heart-pulse-fill"></i>
                        </div>
                        <h5 class="font-bold text-red-500 m-0">Health Data</h5>
                    </div>
                    <i class="bi text-zinc-400 transition-transform duration-300" :class="open ? 'bi-chevron-up' : 'bi-chevron-down'"></i>
                </button>
                
                <div x-show="open" x-collapse>
                    <div class="p-6 border-t border-zinc-200 dark:border-zinc-800 bg-white dark:bg-transparent">
                        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                            <div>
                                <label class="block text-xs font-bold text-zinc-500 dark:text-zinc-400 uppercase tracking-wider mb-1">Height</label>
                                <p class="text-zinc-900 dark:text-zinc-200 font-medium">@Model?.Height cm</p>
                            </div>
                            <div>
                                <label class="block text-xs font-bold text-zinc-500 dark:text-zinc-400 uppercase tracking-wider mb-1">Weight</label>
                                <p class="text-zinc-900 dark:text-zinc-200 font-medium">@Model?.Weight kg</p>
                            </div>
                            <div>
                                <label class="block text-xs font-bold text-zinc-500 dark:text-zinc-400 uppercase tracking-wider mb-1">Blood Type</label>
                                <p class="text-zinc-900 dark:text-zinc-200 font-medium">@Model?.BloodType</p>
                            </div>
                            <div class="md:col-span-3">
                                <label class="block text-xs font-bold text-zinc-500 dark:text-zinc-400 uppercase tracking-wider mb-1">Health Notes</label>
                                <div class="bg-zinc-50 dark:bg-zinc-800/50 p-4 rounded-lg border border-zinc-200 dark:border-zinc-700">
                                    <p class="text-zinc-700 dark:text-zinc-300 m-0">@(string.IsNullOrEmpty(Model?.Note) ? "No health notes recorded." : Model.Note)</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>
