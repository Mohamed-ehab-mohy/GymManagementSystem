@model GymManagementSystem.PL.ViewModels.CreateMemberViewModel

@{
    ViewData["Title"] = "Add New Member";
}

<div class="mb-6 flex flex-col md:flex-row md:items-center md:justify-between gap-4">
    <div>
        <h1 class="page-title">Add New Member</h1>
        <p class="page-subtitle mt-1">Register a new member to the gym system.</p>
    </div>
    <a asp-action="Index" class="btn-outline">
        <i class="bi bi-arrow-left mr-1"></i> Back to List
    </a>
</div>

<div class="page-card p-6 md:p-8">
    <form asp-action="Create" method="post" enctype="multipart/form-data">
        <div asp-validation-summary="ModelOnly" class="text-red-600 dark:text-red-400 text-sm mb-4 bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 p-3 rounded-lg"></div>

        <div class="mb-6">
            <h3 class="text-base font-semibold text-slate-900 dark:text-white mb-4 flex items-center gap-2">
                <i class="bi bi-person text-primary-600 dark:text-primary-400"></i> Personal Details
            </h3>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div>
                    <label asp-for="Name" class="form-label"></label>
                    <input asp-for="Name" class="form-input" placeholder="Full name" />
                    <span asp-validation-for="Name" class="text-red-500 text-xs mt-1 block"></span>
                </div>
                <div>
                    <label asp-for="PhotoFile" class="form-label"></label>
                    <input asp-for="PhotoFile" type="file" class="form-input" accept="image/*" />
                    <span asp-validation-for="PhotoFile" class="text-red-500 text-xs mt-1 block"></span>
                </div>
                <div>
                    <label asp-for="Email" class="form-label"></label>
                    <input asp-for="Email" class="form-input" placeholder="example@email.com" />
                    <span asp-validation-for="Email" class="text-red-500 text-xs mt-1 block"></span>
                </div>
                <div>
                    <label asp-for="PhoneNumber" class="form-label"></label>
                    <input asp-for="PhoneNumber" class="form-input" placeholder="01xxxxxxxxx" />
                    <span asp-validation-for="PhoneNumber" class="text-red-500 text-xs mt-1 block"></span>
                </div>
                <div>
                    <label asp-for="DateOfBirth" class="form-label"></label>
                    <input asp-for="DateOfBirth" type="date" class="form-input" />
                    <span asp-validation-for="DateOfBirth" class="text-red-500 text-xs mt-1 block"></span>
                </div>
                <div>
                    <label asp-for="Gender" class="form-label"></label>
                    <select asp-for="Gender" class="form-select">
                        <option value="">Select gender</option>
                        <option value="Male">Male</option>
                        <option value="Female">Female</option>
                    </select>
                    <span asp-validation-for="Gender" class="text-red-500 text-xs mt-1 block"></span>
                </div>
            </div>
        </div>

        <div class="mb-6">
            <h3 class="text-base font-semibold text-slate-900 dark:text-white mb-4 flex items-center gap-2">
                <i class="bi bi-geo-alt text-primary-600 dark:text-primary-400"></i> Address
            </h3>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                <div>
                    <label asp-for="BuildingNumber" class="form-label"></label>
                    <input asp-for="BuildingNumber" class="form-input" placeholder="Building" />
                    <span asp-validation-for="BuildingNumber" class="text-red-500 text-xs mt-1 block"></span>
                </div>
                <div>
                    <label asp-for="Street" class="form-label"></label>
                    <input asp-for="Street" class="form-input" placeholder="Street" />
                    <span asp-validation-for="Street" class="text-red-500 text-xs mt-1 block"></span>
                </div>
                <div>
                    <label asp-for="City" class="form-label"></label>
                    <input asp-for="City" class="form-input" placeholder="City" />
                    <span asp-validation-for="City" class="text-red-500 text-xs mt-1 block"></span>
                </div>
            </div>
        </div>

        <div class="mb-6" x-data="{ expanded: false }">
            <div @@click="expanded = !expanded" class="flex items-center justify-between pb-2 mb-4 border-b border-slate-200 dark:border-slate-700 cursor-pointer">
                <h3 class="text-base font-semibold text-slate-900 dark:text-white flex items-center gap-2">
                    <i class="bi bi-heart-pulse text-primary-600 dark:text-primary-400"></i> Health Data
                </h3>
                <i class="bi text-slate-400 transition-transform duration-200" :class="expanded ? 'bi-chevron-up' : 'bi-chevron-down'"></i>
            </div>

            <div x-show="expanded" x-collapse style="display: none;">
                <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-4">
                    <div>
                        <label asp-for="HealthRecord.Height" class="form-label"></label>
                        <input asp-for="HealthRecord.Height" type="number" step="0.1" class="form-input" placeholder="e.g. 175" />
                        <span asp-validation-for="HealthRecord.Height" class="text-red-500 text-xs mt-1 block"></span>
                    </div>
                    <div>
                        <label asp-for="HealthRecord.Weight" class="form-label"></label>
                        <input asp-for="HealthRecord.Weight" type="number" step="0.1" class="form-input" placeholder="e.g. 70" />
                        <span asp-validation-for="HealthRecord.Weight" class="text-red-500 text-xs mt-1 block"></span>
                    </div>
                    <div>
                        <label asp-for="HealthRecord.BloodType" class="form-label"></label>
                        <select asp-for="HealthRecord.BloodType" class="form-select">
                            <option value="">Select blood type</option>
                            <option value="A+">A+</option>
                            <option value="A-">A-</option>
                            <option value="B+">B+</option>
                            <option value="B-">B-</option>
                            <option value="AB+">AB+</option>
                            <option value="AB-">AB-</option>
                            <option value="O+">O+</option>
                            <option value="O-">O-</option>
                        </select>
                        <span asp-validation-for="HealthRecord.BloodType" class="text-red-500 text-xs mt-1 block"></span>
                    </div>
                </div>
                <div>
                    <label asp-for="HealthRecord.Note" class="form-label"></label>
                    <textarea asp-for="HealthRecord.Note" class="form-input" rows="3" placeholder="Health notes or medical conditions..."></textarea>
                    <span asp-validation-for="HealthRecord.Note" class="text-red-500 text-xs mt-1 block"></span>
                </div>
            </div>
        </div>

        <div class="flex justify-end gap-3 mt-6 pt-6 border-t border-slate-200 dark:border-slate-700">
            <button type="button" class="btn-outline" onclick="window.history.back()">Cancel</button>
            <button type="submit" class="btn-primary">
                <i class="bi bi-check-circle mr-1"></i> Save Member
            </button>
        </div>
    </form>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
