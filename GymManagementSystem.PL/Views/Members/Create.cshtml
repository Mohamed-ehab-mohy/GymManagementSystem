@model GymManagementSystem.PL.ViewModels.CreateMemberViewModel

@{
    ViewData["Title"] = "Add New Member";
}

<div class="mb-6 flex flex-col md:flex-row md:items-center md:justify-between gap-4">
    <div>
        <h2 class="text-3xl font-display font-bold text-zinc-900 dark:text-white">Add <span class="text-transparent bg-clip-text bg-gradient-to-r from-neon-cyan to-neon-green">Member</span></h2>
        <p class="text-zinc-500 dark:text-zinc-400 mt-1">Register a new member to the gym system.</p>
    </div>
    <a asp-action="Index" class="btn-outline">
        <i class="bi bi-arrow-left mr-2"></i> Back to List
    </a>
</div>

<div class="glass-card p-6 md:p-8">
    <form asp-action="Create" method="post" enctype="multipart/form-data">
        <div asp-validation-summary="ModelOnly" class="text-red-500 mb-4 bg-red-50 dark:bg-red-500/10 p-3 rounded-lg text-sm border border-red-200 dark:border-red-500/20"></div>

        <div class="mb-8">
            <h5 class="flex items-center text-lg font-bold text-zinc-900 dark:text-white mb-4 pb-2 border-b border-zinc-200 dark:border-zinc-800">
                <i class="bi bi-person-badge text-neon-cyan mr-2"></i> Personal Details
            </h5>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div>
                    <label asp-for="Name" class="form-label"></label>
                    <input asp-for="Name" class="form-input" placeholder="Enter full name" />
                    <span asp-validation-for="Name" class="text-red-500 text-xs mt-1 block"></span>
                </div>
                <div>
                    <label asp-for="PhotoFile" class="form-label"></label>
                    <input asp-for="PhotoFile" type="file" class="form-input p-1.5" accept="image/*" />
                    <span asp-validation-for="PhotoFile" class="text-red-500 text-xs mt-1 block"></span>
                </div>
                <div>
                    <label asp-for="Email" class="form-label"></label>
                    <input asp-for="Email" class="form-input" placeholder="example@email.com" />
                    <span asp-validation-for="Email" class="text-red-500 text-xs mt-1 block"></span>
                </div>
                <div>
                    <label asp-for="PhoneNumber" class="form-label"></label>
                    <input asp-for="PhoneNumber" class="form-input" placeholder="01xxxxxxxxx" />
                    <span asp-validation-for="PhoneNumber" class="text-red-500 text-xs mt-1 block"></span>
                </div>
                <div>
                    <label asp-for="DateOfBirth" class="form-label"></label>
                    <input asp-for="DateOfBirth" type="date" class="form-input" />
                    <span asp-validation-for="DateOfBirth" class="text-red-500 text-xs mt-1 block"></span>
                </div>
                <div>
                    <label asp-for="Gender" class="form-label"></label>
                    <select asp-for="Gender" class="form-input">
                        <option value="">-- Select Gender --</option>
                        <option value="Male">Male</option>
                        <option value="Female">Female</option>
                    </select>
                    <span asp-validation-for="Gender" class="text-red-500 text-xs mt-1 block"></span>
                </div>
            </div>
        </div>

        <div class="mb-8">
            <h5 class="flex items-center text-lg font-bold text-zinc-900 dark:text-white mb-4 pb-2 border-b border-zinc-200 dark:border-zinc-800">
                <i class="bi bi-geo-alt text-neon-cyan mr-2"></i> Address Information
            </h5>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                <div>
                    <label asp-for="BuildingNumber" class="form-label"></label>
                    <input asp-for="BuildingNumber" class="form-input" placeholder="Building number" />
                    <span asp-validation-for="BuildingNumber" class="text-red-500 text-xs mt-1 block"></span>
                </div>
                <div>
                    <label asp-for="Street" class="form-label"></label>
                    <input asp-for="Street" class="form-input" placeholder="Street name" />
                    <span asp-validation-for="Street" class="text-red-500 text-xs mt-1 block"></span>
                </div>
                <div>
                    <label asp-for="City" class="form-label"></label>
                    <input asp-for="City" class="form-input" placeholder="City" />
                    <span asp-validation-for="City" class="text-red-500 text-xs mt-1 block"></span>
                </div>
            </div>
        </div>

        <div class="mb-8" x-data="{ expanded: false }">
            <div @@click="expanded = !expanded" class="flex items-center justify-between pb-2 mb-4 border-b border-zinc-200 dark:border-zinc-800 cursor-pointer group">
                <h5 class="flex items-center text-lg font-bold text-red-500 dark:text-red-400">
                    <i class="bi bi-heart-pulse mr-2"></i> Health Data
                </h5>
                <div class="text-sm text-zinc-500 group-hover:text-zinc-900 dark:group-hover:text-white transition-colors">
                    <span x-show="!expanded">Click to expand <i class="bi bi-chevron-down ml-1"></i></span>
                    <span x-show="expanded" style="display: none;">Click to collapse <i class="bi bi-chevron-up ml-1"></i></span>
                </div>
            </div>
            
            <div x-show="expanded" x-collapse style="display: none;">
                <p class="text-zinc-500 dark:text-zinc-400 mb-4 text-sm">Health records are required during registration.</p>
                <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-4">
                    <div>
                        <label asp-for="HealthRecord.Height" class="form-label"></label>
                        <input asp-for="HealthRecord.Height" type="number" step="0.1" class="form-input" placeholder="e.g. 175" />
                        <span asp-validation-for="HealthRecord.Height" class="text-red-500 text-xs mt-1 block"></span>
                    </div>
                    <div>
                        <label asp-for="HealthRecord.Weight" class="form-label"></label>
                        <input asp-for="HealthRecord.Weight" type="number" step="0.1" class="form-input" placeholder="e.g. 70" />
                        <span asp-validation-for="HealthRecord.Weight" class="text-red-500 text-xs mt-1 block"></span>
                    </div>
                    <div>
                        <label asp-for="HealthRecord.BloodType" class="form-label"></label>
                        <select asp-for="HealthRecord.BloodType" class="form-input">
                            <option value="">-- Select Blood Type --</option>
                            <option value="A+">A+</option>
                            <option value="A-">A-</option>
                            <option value="B+">B+</option>
                            <option value="B-">B-</option>
                            <option value="AB+">AB+</option>
                            <option value="AB-">AB-</option>
                            <option value="O+">O+</option>
                            <option value="O-">O-</option>
                        </select>
                        <span asp-validation-for="HealthRecord.BloodType" class="text-red-500 text-xs mt-1 block"></span>
                    </div>
                </div>
                <div>
                    <label asp-for="HealthRecord.Note" class="form-label"></label>
                    <textarea asp-for="HealthRecord.Note" class="form-input" rows="3" placeholder="Any health notes or medical conditions..."></textarea>
                    <span asp-validation-for="HealthRecord.Note" class="text-red-500 text-xs mt-1 block"></span>
                </div>
            </div>
        </div>

        <div class="flex justify-end gap-3 mt-8 pt-6 border-t border-zinc-200 dark:border-zinc-800">
            <button type="button" class="btn-outline" onclick="window.history.back()">Cancel</button>
            <button type="submit" class="btn-primary">
                <i class="bi bi-check-circle mr-2"></i> Save Member
            </button>
        </div>
    </form>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
