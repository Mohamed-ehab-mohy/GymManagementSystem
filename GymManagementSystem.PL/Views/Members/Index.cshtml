@{
    ViewData["Title"] = "Members";
}

<div class="container py-4">
    <header class="d-flex justify-content-between mb-5 align-items-center flex-wrap gap-3 border-bottom pb-4" style="border-color: var(--border-color) !important;">
        <div>
            <h2 class="display-5 fw-bold mb-2">Gym <span class="text-gradient">Members</span></h2>
            <p class="text-secondary fs-5 mb-0">Manage and track all gym members.</p>
        </div>
        <div class="d-flex gap-2 align-items-center flex-wrap">
            <a asp-controller="Attendance" asp-action="Scan" class="btn btn-outline-primary">
                <i class="bi bi-qr-code-scan me-2"></i> Scan QR
            </a>
            <a asp-action="ExportExcel" class="btn btn-outline-success">
                <i class="bi bi-file-earmark-excel me-2"></i> Export Excel
            </a>
            <a asp-action="ExportPdf" class="btn btn-outline-danger">
                <i class="bi bi-file-earmark-pdf me-2"></i> Export PDF
            </a>
            <a asp-action="Create" class="btn btn-gradient">
                <i class="bi bi-person-plus me-2"></i> Add New Member
            </a>
        </div>
    </header>

    <div class="premium-card p-4">
        <div class="table-responsive">
            <table id="dataTable" class="table table-hover align-middle mb-0">
                <thead>
                    <tr style="border-bottom: 2px solid var(--border-color);">
                        <th class="py-3 px-4 fw-bold">Name</th>
                        <th class="py-3 px-4 fw-bold">Contact</th>
                        <th class="py-3 px-4 fw-bold">Address</th>
                        <th class="py-3 px-4 fw-bold text-end">Actions</th>
                    </tr>
                </thead>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#dataTable').DataTable({
                processing: true,
                serverSide: true,
                ajax: { url: '@Url.Action("DataTableData", "Members")', type: 'POST' },
                pageLength: 10,
                lengthMenu: [10, 25, 50, 100],
                columns: [
                    { data: 'name', name: 'FirstName', orderable: true },
                    { data: 'contact', name: '', orderable: false },
                    { data: 'city', name: '', orderable: false },
                    { data: 'actions', name: '', orderable: false }
                ],
                language: { search: "Search:" }
            });
        });
    </script>
}
