@model IEnumerable<GymManagementSystem.PL.ViewModels.MemberViewModel>

@{
    ViewData["Title"] = "Members";
}

<div class="container py-4">
    <header class="d-flex justify-content-between mb-5 align-items-center flex-wrap gap-3 border-bottom pb-4" style="border-color: var(--border-color) !important;">
        <div>
            <h2 class="display-5 fw-bold mb-2">Gym <span class="text-gradient">Members</span></h2>
            <p class="text-secondary fs-5 mb-0">Manage and track all gym members.</p>
        </div>
        <div class="d-flex gap-2 align-items-center flex-wrap">
            <a asp-controller="Attendance" asp-action="Scan" class="btn btn-outline-primary btn-lg">
                <i class="bi bi-qr-code-scan me-2"></i> Scan QR
            </a>
            <a asp-action="ExportExcel" class="btn btn-outline-success btn-lg">
                <i class="bi bi-file-earmark-excel me-2"></i> Export Excel
            </a>
            <a asp-action="ExportPdf" class="btn btn-outline-danger btn-lg">
                <i class="bi bi-file-earmark-pdf me-2"></i> Export PDF
            </a>
            <a asp-action="Create" class="btn btn-gradient btn-lg">
                <i class="bi bi-person-plus me-2"></i> Add New Member
            </a>
        </div>
    </header>

    <div class="premium-card p-4">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead>
                    <tr style="border-bottom: 2px solid var(--border-color);">
                        <th class="py-3 px-4 fw-bold">Name</th>
                        <th class="py-3 px-4 fw-bold">Contact</th>
                        <th class="py-3 px-4 fw-bold">Address</th>
                        <th class="py-3 px-4 fw-bold text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr style="border-bottom: 1px solid var(--border-color);">
                                <td class="py-3 px-4">
                                    <div class="d-flex align-items-center">
                                        @if (!string.IsNullOrEmpty(item.Photo))
                                        {
                                            <img src="@item.Photo" alt="@item.FirstName @item.LastName" class="rounded-circle me-3" style="width: 40px; height: 40px; object-fit: cover;" />
                                        }
                                        else
                                        {
                                            <div class="bg-primary text-white rounded-circle d-flex justify-content-center align-items-center me-3" style="width: 40px; height: 40px; font-weight: bold; background: linear-gradient(135deg, var(--primary-color), var(--secondary-color)) !important;">
                                                @item.FirstName.Substring(0, 1)@item.LastName.Substring(0, 1)
                                            </div>
                                        }
                                        <div>
                                            <h6 class="mb-0 fw-bold">@item.FirstName @item.LastName</h6>
                                        </div>
                                    </div>
                                </td>
                                <td class="py-3 px-4">
                                    <div class="d-flex flex-column">
                                        <span class="text-secondary mb-1"><i class="bi bi-envelope me-2"></i>@item.Email</span>
                                        <span class="text-secondary"><i class="bi bi-telephone me-2"></i>@item.PhoneNumber</span>
                                    </div>
                                </td>
                                <td class="py-3 px-4">
                                    <span class="text-secondary">@item.City, @item.State</span>
                                </td>
                                <td class="py-3 px-4 text-end">
                                    <div class="btn-group" role="group">
                                        <a asp-controller="Attendance" asp-action="MyQr" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning" title="View Check-In QR">
                                            <i class="bi bi-qr-code"></i>
                                        </a>
                                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info" title="Details">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning" title="Edit">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <form asp-action="Delete" asp-route-id="@item.Id" method="post" style="display:inline;">
                                            <button type="submit" class="btn btn-sm btn-outline-danger" title="Delete" onclick="return confirm('Are you sure you want to delete this member?');">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="4" class="text-center py-5">
                                <i class="bi bi-people display-4 text-secondary mb-3 d-block"></i>
                                <h5 class="text-secondary">No members found</h5>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
