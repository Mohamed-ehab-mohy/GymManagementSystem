@model PagedResultDisplay<MemberViewModel>
@{
    ViewData["Title"] = "Members";
    var search = ViewBag.Search as string;
    var sortBy = ViewBag.SortBy as string;
    var ascending = ViewBag.Ascending;
}

<div class="container py-4">
    <header class="d-flex justify-content-between mb-5 align-items-center flex-wrap gap-3 border-bottom pb-4" style="border-color: var(--border-color) !important;">
        <div>
            <h2 class="display-5 fw-bold mb-2">Gym <span class="text-gradient">Members</span></h2>
            <p class="text-secondary fs-5 mb-0">Manage and track all gym members.</p>
        </div>
        <div class="d-flex gap-2 align-items-center flex-wrap">
            <a asp-controller="Attendance" asp-action="Scan" class="btn btn-outline-primary">
                <i class="bi bi-qr-code-scan me-2"></i> Scan QR
            </a>
            <a asp-action="ExportExcel" class="btn btn-outline-success">
                <i class="bi bi-file-earmark-excel me-2"></i> Export Excel
            </a>
            <a asp-action="ExportPdf" class="btn btn-outline-danger">
                <i class="bi bi-file-earmark-pdf me-2"></i> Export PDF
            </a>
            <a asp-action="Create" class="btn btn-gradient">
                <i class="bi bi-person-plus me-2"></i> Add New Member
            </a>
        </div>
    </header>

    <form method="get" class="mb-4">
        <div class="row g-2 align-items-center">
            <div class="col-md-6">
                <div class="input-group">
                    <input type="text" name="search" value="@search" class="form-control form-control-lg" placeholder="Search by name, email, or phone..." />
                    <button type="submit" class="btn btn-gradient btn-lg"><i class="bi bi-search"></i> Search</button>
                </div>
            </div>
            <div class="col-md-auto">
                <span class="text-secondary">@Model.TotalCount member(s) found</span>
            </div>
        </div>
    </form>

    <div class="premium-card p-4">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead>
                    <tr style="border-bottom: 2px solid var(--border-color);">
                        <th class="py-3 px-4 fw-bold">
                            <a asp-route-search="@search" asp-route-sortBy="FirstName" asp-route-ascending="@(sortBy == "FirstName" && ascending ? "false" : "true")" class="text-decoration-none text-light">
                                Name <i class="bi bi-arrow-down-up"></i>
                            </a>
                        </th>
                        <th class="py-3 px-4 fw-bold">Contact</th>
                        <th class="py-3 px-4 fw-bold">Address</th>
                        <th class="py-3 px-4 fw-bold text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Items.Any())
                    {
                        foreach (var item in Model.Items)
                        {
                            <tr style="border-bottom: 1px solid var(--border-color);">
                                <td class="py-3 px-4">
                                    <div class="d-flex align-items-center">
                                        @if (!string.IsNullOrEmpty(item.Photo))
                                        {
                                            <img src="@item.Photo" alt="@item.FirstName @item.LastName" class="rounded-circle me-3" style="width: 40px; height: 40px; object-fit: cover;" />
                                        }
                                        else
                                        {
                                            <div class="rounded-circle d-flex justify-content-center align-items-center me-3 text-white fw-bold" style="width: 40px; height: 40px; background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));">
                                                @item.FirstName.Substring(0, 1)@item.LastName.Substring(0, 1)
                                            </div>
                                        }
                                        <div>
                                            <h6 class="mb-0 fw-bold">@item.FirstName @item.LastName</h6>
                                        </div>
                                    </div>
                                </td>
                                <td class="py-3 px-4">
                                    <div class="d-flex flex-column">
                                        <span class="text-secondary mb-1"><i class="bi bi-envelope me-2"></i>@item.Email</span>
                                        <span class="text-secondary"><i class="bi bi-telephone me-2"></i>@item.PhoneNumber</span>
                                    </div>
                                </td>
                                <td class="py-3 px-4">
                                    <span class="text-secondary">@item.City</span>
                                </td>
                                <td class="py-3 px-4 text-end">
                                    <div class="btn-group" role="group">
                                        <a asp-controller="Attendance" asp-action="MyQr" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning" title="View QR">
                                            <i class="bi bi-qr-code"></i>
                                        </a>
                                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info" title="Details">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning" title="Edit">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <form asp-action="Delete" asp-route-id="@item.Id" method="post" style="display:inline;">
                                            <button type="submit" class="btn btn-sm btn-outline-danger" title="Delete" onclick="return confirm('Are you sure?');">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="4" class="text-center py-5">
                                <i class="bi bi-people display-4 text-secondary mb-3 d-block"></i>
                                <h5 class="text-secondary">No members found</h5>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @if (Model.TotalPages > 1)
        {
            <nav class="mt-4">
                <ul class="pagination justify-content-center mb-0">
                    <li class="page-item @(Model.HasPreviousPage ? "" : "disabled")">
                        <a class="page-link" asp-route-page="@(Model.Page - 1)" asp-route-search="@search" asp-route-sortBy="@sortBy" asp-route-ascending="@ascending"><i class="bi bi-chevron-left"></i></a>
                    </li>
                    @for (int i = 1; i <= Model.TotalPages; i++)
                    {
                        <li class="page-item @(i == Model.Page ? "active" : "")">
                            <a class="page-link" asp-route-page="@i" asp-route-search="@search" asp-route-sortBy="@sortBy" asp-route-ascending="@ascending">@i</a>
                        </li>
                    }
                    <li class="page-item @(Model.HasNextPage ? "" : "disabled")">
                        <a class="page-link" asp-route-page="@(Model.Page + 1)" asp-route-search="@search" asp-route-sortBy="@sortBy" asp-route-ascending="@ascending"><i class="bi bi-chevron-right"></i></a>
                    </li>
                </ul>
            </nav>
        }
    </div>
</div>
