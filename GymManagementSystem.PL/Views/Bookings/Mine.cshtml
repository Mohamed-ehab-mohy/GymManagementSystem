@model IEnumerable<MyBookingViewModel>
@{
    ViewData["Title"] = "My Bookings";
}

<div class="mb-6 flex flex-col md:flex-row md:items-center md:justify-between gap-4">
    <div>
        <h1 class="page-title">My Bookings</h1>
        <p class="page-subtitle mt-1">Track your upcoming and past sessions.</p>
    </div>
    <a asp-action="Index" class="btn-primary py-2 text-sm">
        <i class="bi bi-search mr-1"></i> Browse Sessions
    </a>
</div>

@if (!Model.Any())
{
    <div class="page-card p-12 text-center">
        <div class="w-16 h-16 mx-auto rounded-full bg-slate-100 dark:bg-slate-700 flex items-center justify-center mb-4">
            <i class="bi bi-calendar2-check text-3xl text-slate-400 dark:text-slate-500"></i>
        </div>
        <h3 class="text-lg font-semibold text-slate-900 dark:text-white mb-1">No bookings yet</h3>
        <p class="text-sm text-slate-500 dark:text-slate-400 mb-4">Start by booking a session.</p>
        <a asp-action="Index" class="btn-primary">Find a Session</a>
    </div>
}
else
{
    <div class="page-card">
        <div class="overflow-x-auto">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Session</th>
                        <th>Category</th>
                        <th>Date & Time</th>
                        <th>Trainer</th>
                        <th>Status</th>
                        <th class="text-right">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var booking in Model)
                    {
                        <tr>
                            <td class="font-semibold text-slate-900 dark:text-white">@booking.SessionName</td>
                            <td><span class="badge badge-info">@booking.CategoryName</span></td>
                            <td class="text-slate-600 dark:text-slate-400">@booking.ScheduleTime.ToString("dd MMM yyyy, HH:mm")</td>
                            <td class="text-slate-600 dark:text-slate-400">@booking.TrainerName</td>
                            <td>
                                @if (booking.IsAttended)
                                {
                                    <span class="badge badge-success">Attended</span>
                                }
                                else if (booking.ScheduleTime < DateTime.Now)
                                {
                                    <span class="badge badge-neutral">Past</span>
                                }
                                else
                                {
                                    <span class="badge badge-info">Upcoming</span>
                                }
                            </td>
                            <td class="text-right">
                                @if (!booking.IsAttended && booking.ScheduleTime > DateTime.Now)
                                {
                                    <form asp-action="Cancel" method="post" class="inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="bookingId" value="@booking.Id" />
                                        <button type="submit" class="btn-danger text-xs py-1.5 px-3" onclick="return confirm('Cancel this booking?');">
                                            Cancel
                                        </button>
                                    </form>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
