@model IEnumerable<MyBookingViewModel>

@{
    ViewData["Title"] = "My Bookings";
}

<h1 class="mb-4">My Bookings</h1>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success">@TempData["SuccessMessage"]</div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
}

@if (!Model.Any())
{
    <div class="alert alert-info">You have no bookings yet. <a asp-action="Index">Browse available sessions</a></div>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Session</th>
                <th>Date & Time</th>
                <th>Trainer</th>
                <th>Category</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var booking in Model)
            {
                <tr>
                    <td>@booking.SessionName</td>
                    <td>@booking.ScheduleTime.ToString("dd MMM yyyy HH:mm")</td>
                    <td>@booking.TrainerName</td>
                    <td>@booking.CategoryName</td>
                    <td>
                        @if (booking.IsAttended)
                        {
                            <span class="badge bg-success">Attended</span>
                        }
                        else if (booking.ScheduleTime < DateTime.Now)
                        {
                            <span class="badge bg-secondary">Past</span>
                        }
                        else
                        {
                            <span class="badge bg-primary">Upcoming</span>
                        }
                    </td>
                    <td>
                        @if (!booking.IsAttended && booking.ScheduleTime > DateTime.Now)
                        {
                            <form asp-action="Cancel" method="post" style="display:inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="bookingId" value="@booking.Id" />
                                <button type="submit" class="btn btn-sm btn-danger">Cancel</button>
                            </form>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

<div class="mt-3">
    <a asp-action="Index" class="btn btn-outline-primary">Browse Sessions</a>
</div>
