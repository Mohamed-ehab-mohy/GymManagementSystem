@model IEnumerable<AvailableSessionViewModel>

@{
    ViewData["Title"] = "Available Sessions";
}

<h1 class="mb-4">Available Sessions</h1>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success">@TempData["SuccessMessage"]</div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
}

@if (!Model.Any())
{
    <div class="alert alert-info">No upcoming sessions available for booking.</div>
}
else
{
    <div class="row">
        @foreach (var session in Model)
        {
            <div class="col-md-6 col-lg-4 mb-4">
                <div class="card h-100">
                    <div class="card-body">
                        <h5 class="card-title">@session.Name</h5>
                        <p class="card-text">
                            <strong>Date:</strong> @session.ScheduleTime.ToString("dd MMM yyyy HH:mm")<br />
                            <strong>Trainer:</strong> @session.TrainerName<br />
                            <strong>Category:</strong> @session.CategoryName<br />
                            <strong>Capacity:</strong> @session.AvailableSlots / @session.Capacity spots left
                        </p>
                        <form asp-action="Book" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="sessionId" value="@session.Id" />
                            <button type="submit" class="btn btn-primary w-100">Book Now</button>
                        </form>
                    </div>
                </div>
            </div>
        }
    </div>
}

<div class="mt-3">
    <a asp-action="Mine" class="btn btn-outline-secondary">My Bookings</a>
</div>
