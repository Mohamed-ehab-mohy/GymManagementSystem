@model IEnumerable<AvailableSessionViewModel>
@{
    ViewData["Title"] = "Available Sessions";
}

<div class="mb-6 flex flex-col md:flex-row md:items-center md:justify-between gap-4">
    <div>
        <h1 class="page-title">Available Sessions</h1>
        <p class="page-subtitle mt-1">Book your next workout session.</p>
    </div>
    <a asp-action="Mine" class="btn-outline py-2 text-sm">
        <i class="bi bi-calendar2-check mr-1"></i> My Bookings
    </a>
</div>

@if (!Model.Any())
{
    <div class="page-card p-12 text-center">
        <div class="w-16 h-16 mx-auto rounded-full bg-slate-100 dark:bg-slate-700 flex items-center justify-center mb-4">
            <i class="bi bi-calendar-x text-3xl text-slate-400 dark:text-slate-500"></i>
        </div>
        <h3 class="text-lg font-semibold text-slate-900 dark:text-white mb-1">No upcoming sessions</h3>
        <p class="text-sm text-slate-500 dark:text-slate-400">Check back later for available sessions.</p>
    </div>
}
else
{
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        @foreach (var session in Model)
        {
            <div class="page-card flex flex-col">
                <div class="p-5 border-b border-slate-200 dark:border-slate-700">
                    <div class="flex justify-between items-start">
                        <h5 class="text-lg font-semibold text-slate-900 dark:text-white">@session.Name</h5>
                        <span class="badge badge-info">@session.CategoryName</span>
                    </div>
                </div>
                <div class="p-5 flex-1 flex flex-col">
                    <div class="space-y-3 mb-5 flex-1">
                        <div class="flex items-center gap-3 text-sm text-slate-600 dark:text-slate-300">
                            <i class="bi bi-calendar-event text-slate-400 w-4 text-center"></i>
                            <span>@session.ScheduleTime.ToString("dd MMM yyyy, HH:mm")</span>
                        </div>
                        <div class="flex items-center gap-3 text-sm">
                            <i class="bi bi-person-badge text-slate-400 w-4 text-center"></i>
                            <span class="font-medium text-primary-600 dark:text-primary-400">@session.TrainerName</span>
                        </div>
                        <div class="flex items-center gap-3 text-sm">
                            <i class="bi bi-people text-slate-400 w-4 text-center"></i>
                            <span class="font-medium @(session.AvailableSlots < 3 ? "text-red-600 dark:text-red-400" : "text-emerald-600 dark:text-emerald-400")">
                                @session.AvailableSlots / @session.Capacity spots left
                            </span>
                        </div>
                    </div>

                    <form asp-action="Book" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="sessionId" value="@session.Id" />
                        <button type="submit" class="w-full @(session.AvailableSlots == 0 ? "bg-slate-100 dark:bg-slate-700 text-slate-400 cursor-not-allowed" : "btn-primary") py-2.5" @(session.AvailableSlots == 0 ? "disabled" : "")>
                            @(session.AvailableSlots == 0 ? "Fully Booked" : "Book Now")
                        </button>
                    </form>
                </div>
            </div>
        }
    </div>
}
