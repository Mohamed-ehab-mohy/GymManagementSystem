@model IEnumerable<GymManagementSystem.BLL.Interfaces.NotificationDto>
@{
    ViewData["Title"] = "Notifications";
}

<div class="mb-8 flex flex-col md:flex-row md:items-end justify-between gap-6 border-b border-zinc-200 dark:border-gym-border pb-6">
    <div>
        <h2 class="text-3xl font-display font-bold text-zinc-900 dark:text-white mb-2">My <span class="text-transparent bg-clip-text bg-gradient-to-r from-neon-orange to-yellow-500">Notifications</span></h2>
        <p class="text-zinc-500 dark:text-zinc-400">Stay updated with your latest alerts and messages.</p>
    </div>
    @if (Model.Any())
    {
        <button id="markAllRead" class="btn-outline border-zinc-300 dark:border-zinc-700 py-2 text-sm hover:text-green-500 dark:hover:text-green-400 hover:border-green-500 dark:hover:border-green-500 transition-colors">
            <i class="bi bi-check2-all mr-2"></i> Mark All as Read
        </button>
    }
</div>

<div class="glass-card overflow-hidden">
    @if (!Model.Any())
    {
        <div class="py-16 text-center">
            <div class="w-20 h-20 mx-auto rounded-full bg-zinc-100 dark:bg-zinc-800 flex items-center justify-center mb-6 border border-zinc-200 dark:border-zinc-700">
                <i class="bi bi-bell-slash text-4xl text-zinc-400 dark:text-zinc-500"></i>
            </div>
            <h3 class="text-xl font-bold text-zinc-900 dark:text-white mb-2">No notifications yet</h3>
            <p class="text-zinc-500 dark:text-zinc-400 max-w-md mx-auto">You're all caught up! We'll notify you when there's something new.</p>
        </div>
    }
    else
    {
        <div class="divide-y divide-zinc-200 dark:divide-zinc-800">
            @foreach (var notif in Model)
            {
                <div class="p-6 transition-colors hover:bg-zinc-50 dark:hover:bg-zinc-800/40 flex flex-col sm:flex-row sm:items-center justify-between gap-4 group @(notif.IsRead ? "opacity-75" : "")" data-id="@notif.Id">
                    <div class="flex items-start gap-4">
                        <div class="shrink-0 mt-1">
                            @if (!notif.IsRead)
                            {
                                <div class="w-3 h-3 rounded-full bg-neon-orange shadow-[0_0_8px_rgba(255,165,0,0.6)]"></div>
                            }
                            else
                            {
                                <div class="w-3 h-3 rounded-full bg-zinc-300 dark:bg-zinc-600"></div>
                            }
                        </div>
                        <div>
                            <p class="text-base text-zinc-800 dark:text-zinc-200 mb-1 @(notif.IsRead ? "font-medium" : "font-bold")">@notif.Message</p>
                            <span class="text-xs text-zinc-500 dark:text-zinc-400 font-medium flex items-center gap-1.5">
                                <i class="bi bi-clock"></i> @notif.CreatedAt.ToString("MMM dd, yyyy - hh:mm tt")
                            </span>
                        </div>
                    </div>
                    
                    <div class="shrink-0 sm:ml-4">
                        @if (!notif.IsRead)
                        {
                            <button class="mark-read text-xs font-semibold px-3 py-1.5 rounded-full border border-zinc-200 dark:border-zinc-700 text-zinc-600 dark:text-zinc-400 hover:bg-neon-orange/10 hover:text-neon-orange hover:border-neon-orange/20 transition-colors" data-id="@notif.Id">
                                Mark Read
                            </button>
                        }
                    </div>
                </div>
            }
        </div>
    }
</div>

@section Scripts {
    <script>
        document.querySelectorAll('.mark-read').forEach(btn => {
            btn.addEventListener('click', function () {
                const id = this.dataset.id;
                fetch('/Notifications/MarkAsRead', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                    body: `id=${id}`
                }).then(() => {
                    const row = this.closest('[data-id]');
                    this.remove();
                    row.classList.add('opacity-75');
                    row.querySelector('.bg-neon-orange').className = 'w-3 h-3 rounded-full bg-zinc-300 dark:bg-zinc-600';
                    row.querySelector('p').classList.remove('font-bold');
                    row.querySelector('p').classList.add('font-medium');
                    
                    // Update badge logic if present in layout
                    const badge = document.getElementById("notificationBadge");
                    if(badge) {
                        const current = parseInt(badge.textContent) || 0;
                        if(current > 1) badge.textContent = current - 1;
                        else badge.remove();
                    }
                });
            });
        });

        document.getElementById('markAllRead')?.addEventListener('click', function () {
            fetch('/Notifications/MarkAllAsRead', { method: 'POST' })
                .then(() => location.reload());
        });
    </script>
}
