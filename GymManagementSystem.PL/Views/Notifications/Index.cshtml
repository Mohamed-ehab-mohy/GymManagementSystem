@model IEnumerable<GymManagementSystem.BLL.Interfaces.NotificationDto>
@{
    ViewData["Title"] = "Notifications";
}

<div class="mb-6 flex flex-col md:flex-row md:items-center md:justify-between gap-4">
    <div>
        <h1 class="page-title">Notifications</h1>
        <p class="page-subtitle mt-1">Stay updated with your latest alerts.</p>
    </div>
    @if (Model.Any())
    {
        <button id="markAllRead" class="btn-outline py-2 text-sm">
            <i class="bi bi-check2-all mr-1"></i> Mark All as Read
        </button>
    }
</div>

<div class="page-card">
    @if (!Model.Any())
    {
        <div class="py-16 text-center">
            <div class="w-16 h-16 mx-auto rounded-full bg-slate-100 dark:bg-slate-700 flex items-center justify-center mb-4">
                <i class="bi bi-bell-slash text-3xl text-slate-400 dark:text-slate-500"></i>
            </div>
            <h3 class="text-lg font-semibold text-slate-900 dark:text-white mb-1">No notifications</h3>
            <p class="text-sm text-slate-500 dark:text-slate-400">You're all caught up.</p>
        </div>
    }
    else
    {
        <div class="divide-y divide-slate-200 dark:divide-slate-700">
            @foreach (var notif in Model)
            {
                <div class="p-5 hover:bg-slate-50 dark:hover:bg-slate-700/30 transition-colors flex flex-col sm:flex-row sm:items-center justify-between gap-3 @(notif.IsRead ? "opacity-60" : "")" data-id="@notif.Id">
                    <div class="flex items-start gap-3">
                        <div class="shrink-0 mt-1">
                            @if (!notif.IsRead)
                            {
                                <div class="w-2.5 h-2.5 rounded-full bg-primary-600"></div>
                            }
                            else
                            {
                                <div class="w-2.5 h-2.5 rounded-full bg-slate-300 dark:bg-slate-600"></div>
                            }
                        </div>
                        <div>
                            <p class="text-sm text-slate-800 dark:text-slate-200 @(notif.IsRead ? "font-medium" : "font-semibold")">@notif.Message</p>
                            <span class="text-xs text-slate-500 dark:text-slate-400 mt-0.5 block">
                                <i class="bi bi-clock mr-1"></i>@notif.CreatedAt.ToString("MMM dd, yyyy - hh:mm tt")
                            </span>
                        </div>
                    </div>

                    @if (!notif.IsRead)
                    {
                        <button class="mark-read btn-outline text-xs py-1.5 px-3 shrink-0" data-id="@notif.Id">
                            Mark Read
                        </button>
                    }
                </div>
            }
        </div>
    }
</div>

@section Scripts {
    <script>
        document.querySelectorAll('.mark-read').forEach(btn => {
            btn.addEventListener('click', function () {
                const id = this.dataset.id;
                fetch('/Notifications/MarkAsRead', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                    body: `id=${id}`
                }).then(() => {
                    const row = this.closest('[data-id]');
                    this.remove();
                    row.classList.add('opacity-60');
                    const dot = row.querySelector('.bg-primary-600');
                    if (dot) dot.className = 'w-2.5 h-2.5 rounded-full bg-slate-300 dark:bg-slate-600';
                    row.querySelector('p').classList.remove('font-semibold');
                    row.querySelector('p').classList.add('font-medium');

                    const badge = document.getElementById("notificationBadge");
                    if(badge) {
                        const current = parseInt(badge.textContent) || 0;
                        if(current > 1) badge.textContent = current - 1;
                        else badge.remove();
                    }
                });
            });
        });

        document.getElementById('markAllRead')?.addEventListener('click', function () {
            fetch('/Notifications/MarkAllAsRead', { method: 'POST' })
                .then(() => location.reload());
        });
    </script>
}
