@model IEnumerable<GymManagementSystem.BLL.Interfaces.NotificationDto>
@{
    ViewData["Title"] = "Notifications";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="display-6 fw-bold">Notifications</h1>
        <button id="markAllRead" class="btn btn-glass px-4">Mark All as Read</button>
    </div>

    @if (!Model.Any())
    {
        <div class="text-center text-muted py-5">
            <i class="bi bi-bell-slash fs-1"></i>
            <p class="mt-2">No notifications</p>
        </div>
    }
    else
    {
        <div class="list-group">
            @foreach (var notif in Model)
            {
                <div class="list-group-item list-group-item-action d-flex justify-content-between align-items-center @(notif.IsRead ? "" : "fw-bold")" data-id="@notif.Id">
                    <span>@notif.Message</span>
                    <div>
                        <small class="text-muted me-2">@notif.CreatedAt.ToString("g")</small>
                        @if (!notif.IsRead)
                        {
                            <button class="btn btn-sm btn-glass mark-read" data-id="@notif.Id">Mark Read</button>
                        }
                    </div>
                </div>
            }
        </div>
    }
</div>

@section Scripts {
    <script>
        document.querySelectorAll('.mark-read').forEach(btn => {
            btn.addEventListener('click', function () {
                const id = this.dataset.id;
                fetch('/Notifications/MarkAsRead', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                    body: `id=${id}`
                }).then(() => location.reload());
            });
        });

        document.getElementById('markAllRead')?.addEventListener('click', function () {
            fetch('/Notifications/MarkAllAsRead', { method: 'POST' })
                .then(() => location.reload());
        });
    </script>
}
