@model MemberDashboardViewModel
@{
    ViewData["Title"] = "My Dashboard";
}

<div class="mb-8">
    <h1 class="page-title mb-1">Welcome back, <span class="text-primary-600 dark:text-primary-400">@Model.MemberName</span></h1>
    <p class="page-subtitle">Member since @Model.JoinDate.ToString("MMMM yyyy")</p>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-8">
    <!-- Membership -->
    <div class="page-card p-6">
        <div class="flex items-center gap-3 mb-4">
            <div class="w-10 h-10 rounded-lg bg-emerald-50 dark:bg-emerald-900/20 flex items-center justify-center">
                <i class="bi bi-card-text text-emerald-600 dark:text-emerald-400"></i>
            </div>
            <h3 class="text-sm font-semibold text-slate-900 dark:text-white">Membership</h3>
        </div>

        @if (Model.HasActiveMembership)
        {
            <div class="mb-4">
                <span class="badge badge-success mb-2">Active</span>
                <h4 class="text-lg font-bold text-slate-900 dark:text-white">@Model.PlanName</h4>
                <p class="text-sm text-slate-500 dark:text-slate-400 mt-1">
                    @Model.MembershipStart?.ToString("dd MMM") — @Model.MembershipEnd?.ToString("dd MMM yyyy")
                </p>
            </div>
            <div class="mt-auto">
                <div class="flex justify-between items-center mb-1.5 text-sm">
                    <span class="text-slate-500 dark:text-slate-400">Days Remaining</span>
                    <span class="font-semibold @(Model.DaysRemaining <= 7 ? "text-red-600" : "text-emerald-600 dark:text-emerald-400")">@Model.DaysRemaining</span>
                </div>
                <div class="w-full bg-slate-100 dark:bg-slate-700 rounded-full h-2">
                    <div class="bg-emerald-500 h-2 rounded-full transition-all" style="width: @Math.Min(100, Model.DaysRemaining * 100 / 365)%"></div>
                </div>
            </div>
        }
        else
        {
            <div class="flex flex-col items-center justify-center py-6">
                <i class="bi bi-exclamation-circle text-3xl text-slate-400 mb-3"></i>
                <p class="text-sm text-slate-500 dark:text-slate-400 mb-4">No active membership</p>
                <a asp-controller="Plans" asp-action="Index" class="btn-primary text-sm">Browse Plans</a>
            </div>
        }
    </div>

    <!-- Health Stats -->
    <div class="page-card p-6">
        <div class="flex items-center gap-3 mb-4">
            <div class="w-10 h-10 rounded-lg bg-violet-50 dark:bg-violet-900/20 flex items-center justify-center">
                <i class="bi bi-heart-pulse text-violet-600 dark:text-violet-400"></i>
            </div>
            <h3 class="text-sm font-semibold text-slate-900 dark:text-white">Health Stats</h3>
        </div>

        @if (Model.Bmi.HasValue)
        {
            <div class="text-center">
                <div class="w-32 h-32 mx-auto relative">
                    <canvas id="bmiChart"></canvas>
                    <div class="absolute inset-0 flex flex-col items-center justify-center">
                        <span class="text-xl font-bold text-slate-900 dark:text-white">@Model.Bmi.Value.ToString("F1", null)</span>
                        <span class="text-[10px] uppercase tracking-wider text-slate-500">BMI</span>
                    </div>
                </div>
                <span class="badge badge-info mt-2">@Model.BmiCategory</span>
            </div>
            <div class="grid grid-cols-2 gap-3 mt-4">
                <div class="bg-slate-50 dark:bg-slate-700/50 rounded-lg p-3 text-center">
                    <div class="text-[10px] uppercase tracking-wider text-slate-500 dark:text-slate-400 mb-1">Weight</div>
                    <div class="font-semibold text-slate-900 dark:text-white text-sm">@Model.Weight kg</div>
                </div>
                <div class="bg-slate-50 dark:bg-slate-700/50 rounded-lg p-3 text-center">
                    <div class="text-[10px] uppercase tracking-wider text-slate-500 dark:text-slate-400 mb-1">Height</div>
                    <div class="font-semibold text-slate-900 dark:text-white text-sm">@Model.Height cm</div>
                </div>
            </div>
        }
        else
        {
            <div class="flex flex-col items-center justify-center py-6">
                <i class="bi bi-clipboard-data text-3xl text-slate-400 mb-3"></i>
                <p class="text-sm text-slate-500 dark:text-slate-400">No health data recorded</p>
            </div>
        }
    </div>

    <!-- Attendance -->
    <div class="page-card p-6">
        <div class="flex items-center gap-3 mb-4">
            <div class="w-10 h-10 rounded-lg bg-blue-50 dark:bg-blue-900/20 flex items-center justify-center">
                <i class="bi bi-bar-chart text-blue-600 dark:text-blue-400"></i>
            </div>
            <h3 class="text-sm font-semibold text-slate-900 dark:text-white">Attendance</h3>
        </div>

        <div class="text-center">
            <div class="w-32 h-32 mx-auto relative">
                <canvas id="attendanceChart"></canvas>
            </div>
            <div class="grid grid-cols-2 gap-3 mt-4">
                <div class="bg-slate-50 dark:bg-slate-700/50 rounded-lg p-3 text-center">
                    <div class="text-[10px] uppercase tracking-wider text-slate-500 dark:text-slate-400 mb-1">Booked</div>
                    <div class="font-semibold text-slate-900 dark:text-white text-sm">@Model.TotalBooked</div>
                </div>
                <div class="bg-slate-50 dark:bg-slate-700/50 rounded-lg p-3 text-center">
                    <div class="text-[10px] uppercase tracking-wider text-slate-500 dark:text-slate-400 mb-1">Attended</div>
                    <div class="font-semibold text-emerald-600 dark:text-emerald-400 text-sm">@Model.TotalAttended</div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Upcoming Sessions -->
<div class="page-card">
    <div class="px-5 py-4 border-b border-slate-200 dark:border-slate-700 flex items-center justify-between">
        <h2 class="text-sm font-semibold text-slate-900 dark:text-white">Upcoming Sessions</h2>
        <a asp-controller="Bookings" asp-action="Index" class="btn-primary text-sm py-1.5 px-3">Book a Session</a>
    </div>

    @if (Model.UpcomingSessions.Count == 0)
    {
        <div class="flex flex-col items-center justify-center py-12">
            <div class="w-12 h-12 rounded-full bg-slate-100 dark:bg-slate-700 flex items-center justify-center mb-3">
                <i class="bi bi-calendar-plus text-xl text-slate-400"></i>
            </div>
            <p class="text-sm font-medium text-slate-900 dark:text-white mb-1">No upcoming sessions</p>
            <p class="text-sm text-slate-500 dark:text-slate-400">Book your first session to get started.</p>
        </div>
    }
    else
    {
        <div class="overflow-x-auto">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Session</th>
                        <th>Date & Time</th>
                        <th>Trainer</th>
                        <th>Category</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var session in Model.UpcomingSessions)
                    {
                        <tr>
                            <td class="font-medium text-slate-900 dark:text-white">@session.SessionName</td>
                            <td>@session.ScheduleTime.ToString("dd MMM yyyy HH:mm")</td>
                            <td>@session.TrainerName</td>
                            <td><span class="badge badge-info">@session.CategoryName</span></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <script>
        document.addEventListener('alpine:init', () => {
            Alpine.effect(() => {
                const isDark = document.documentElement.classList.contains('dark');
                const emptyColor = isDark ? '#334155' : '#e2e8f0';

                Chart.helpers.each(Chart.instances, function(instance){ instance.destroy(); });

                @if (Model.Bmi.HasValue)
                {
                    <text>
                    new Chart(document.getElementById('bmiChart'), {
                        type: 'doughnut',
                        data: {
                            labels: ['BMI', 'Remaining'],
                            datasets: [{ data: [@Model.Bmi.Value.ToString("F1", null), Math.max(0, 40 - @Model.Bmi.Value.ToString("F1", null))], backgroundColor: ['#3b82f6', emptyColor], borderWidth: 0 }]
                        },
                        options: { cutout: '78%', responsive: true, maintainAspectRatio: false, plugins: { legend: { display: false }, tooltip: { enabled: false } } }
                    });
                    </text>
                }

                new Chart(document.getElementById('attendanceChart'), {
                    type: 'doughnut',
                    data: {
                        labels: ['Attended', 'Missed'],
                        datasets: [{ data: [@Model.TotalAttended, Math.max(0, @Model.TotalBooked - @Model.TotalAttended)], backgroundColor: ['#10b981', emptyColor], borderWidth: 0 }]
                    },
                    options: { cutout: '78%', responsive: true, maintainAspectRatio: false, plugins: { legend: { display: false }, tooltip: { callbacks: { label: ctx => ctx.label + ': ' + ctx.parsed + ' sessions' } } } }
                });
            });
        });

        const observer = new MutationObserver((mutations) => {
            mutations.forEach((m) => { if (m.attributeName === 'class') window.dispatchEvent(new Event('theme-changed')); });
        });
        observer.observe(document.documentElement, { attributes: true });
    </script>
}
