@model MemberDashboardViewModel
@{
    ViewData["Title"] = "My Dashboard";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="display-5 fw-bold">Welcome, <span class="text-gradient">@Model.MemberName</span></h1>
    <span class="text-secondary fs-5">Member since @Model.JoinDate.ToString("MMM yyyy")</span>
</div>

<div class="row g-4">
    <div class="col-lg-4">
        <div class="premium-card p-4 h-100">
            <h5 class="fw-bold mb-3"><i class="bi bi-card-text me-2"></i>Membership</h5>
            @if (Model.HasActiveMembership)
            {
                <div class="mb-3">
                    <span class="badge bg-success fs-6 mb-2">Active</span>
                    <h4 class="fw-bold">@Model.PlanName</h4>
                    <p class="text-secondary mb-1">
                        <i class="bi bi-calendar-check me-1"></i>@Model.MembershipStart?.ToString("dd MMM yyyy") - @Model.MembershipEnd?.ToString("dd MMM yyyy")
                    </p>
                    <div class="mt-3">
                        <div class="d-flex justify-content-between mb-1">
                            <span>Days Remaining</span>
                            <span class="fw-bold @(Model.DaysRemaining <= 7 ? "text-danger" : "text-success")">@Model.DaysRemaining</span>
                        </div>
                        <div class="progress" style="height:8px">
                            <div class="progress-bar @(Model.DaysRemaining <= 7 ? "bg-danger" : "bg-success")" 
                                 style="width:@Math.Min(100, Model.DaysRemaining * 100 / 365)%"></div>
                        </div>
                    </div>
                </div>
            }
            else
            {
                <div class="text-center py-4">
                    <i class="bi bi-exclamation-circle display-4 text-warning"></i>
                    <p class="mt-2 text-secondary">No active membership</p>
                    <a asp-controller="Members" asp-action="Index" class="btn btn-gradient">Browse Plans</a>
                </div>
            }
        </div>
    </div>

    <div class="col-lg-4">
        <div class="premium-card p-4 h-100">
            <h5 class="fw-bold mb-3"><i class="bi bi-heart-pulse me-2"></i>Health Stats</h5>
            @if (Model.Bmi.HasValue)
            {
                <div class="text-center">
                    <canvas id="bmiChart" width="160" height="160" style="max-width:160px;margin:0 auto"></canvas>
                    <h3 class="fw-bold mt-2">@Model.Bmi <small class="text-secondary fs-6">BMI</small></h3>
                    <span class="badge bg-info fs-6">@Model.BmiCategory</span>
                </div>
                <div class="row mt-3 text-center g-2">
                    <div class="col-6">
                        <div class="p-2 rounded-3 bg-dark">
                            <small class="text-secondary">Weight</small>
                            <div class="fw-bold">@Model.Weight kg</div>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="p-2 rounded-3 bg-dark">
                            <small class="text-secondary">Height</small>
                            <div class="fw-bold">@Model.Height cm</div>
                        </div>
                    </div>
                </div>
            }
            else
            {
                <div class="text-center py-4">
                    <i class="bi bi-clipboard-data display-4 text-secondary"></i>
                    <p class="mt-2 text-secondary">No health data recorded</p>
                </div>
            }
        </div>
    </div>

    <div class="col-lg-4">
        <div class="premium-card p-4 h-100">
            <h5 class="fw-bold mb-3"><i class="bi bi-bar-chart me-2"></i>Attendance</h5>
            <div class="text-center">
                <canvas id="attendanceChart" width="160" height="160" style="max-width:160px;margin:0 auto"></canvas>
                <div class="row mt-3 text-center g-2">
                    <div class="col-6">
                        <div class="p-2 rounded-3 bg-dark">
                            <small class="text-secondary">Booked</small>
                            <div class="fw-bold">@Model.TotalBooked</div>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="p-2 rounded-3 bg-dark">
                            <small class="text-secondary">Attended</small>
                            <div class="fw-bold text-success">@Model.TotalAttended</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="premium-card p-4 mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h5 class="fw-bold mb-0"><i class="bi bi-calendar-event me-2"></i>Upcoming Sessions</h5>
        <a asp-controller="Bookings" asp-action="Index" class="btn btn-sm btn-gradient">Book a Session</a>
    </div>
    @if (Model.UpcomingSessions.Count == 0)
    {
        <div class="text-center py-4">
            <i class="bi bi-calendar-plus display-4 text-secondary"></i>
            <p class="mt-2 text-secondary">No upcoming sessions</p>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-dark table-borderless align-middle mb-0">
                <thead>
                    <tr>
                        <th>Session</th>
                        <th>Date & Time</th>
                        <th>Trainer</th>
                        <th>Category</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var session in Model.UpcomingSessions)
                    {
                        <tr>
                            <td class="fw-semibold">@session.SessionName</td>
                            <td>@session.ScheduleTime.ToString("dd MMM yyyy HH:mm")</td>
                            <td>@session.TrainerName</td>
                            <td><span class="badge bg-primary">@session.CategoryName</span></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@section Scripts
{
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <script>
        const isDark = document.documentElement.getAttribute('data-theme') === 'dark';
        const textColor = isDark ? '#e0e0e0' : '#333';

        @if (Model.Bmi.HasValue)
        {
            <text>
            new Chart(document.getElementById('bmiChart'), {
                type: 'doughnut',
                data: {
                    labels: ['BMI', 'Remaining'],
                    datasets: [{
                        data: [@Model.Bmi, 40 - @Model.Bmi],
                        backgroundColor: ['#6f42c1', '#2a2a3a'],
                        borderWidth: 0
                    }]
                },
                options: {
                    cutout: '75%',
                    responsive: false,
                    plugins: {
                        legend: { display: false },
                        tooltip: { enabled: false }
                    }
                }
            });
            </text>
        }

        new Chart(document.getElementById('attendanceChart'), {
            type: 'doughnut',
            data: {
                labels: ['Attended', 'Missed'],
                datasets: [{
                    data: [@Model.TotalAttended, Math.max(0, @Model.TotalBooked - @Model.TotalAttended)],
                    backgroundColor: ['#28a745', '#dc3545'],
                    borderWidth: 0
                }]
            },
            options: {
                cutout: '70%',
                responsive: false,
                plugins: {
                    legend: { display: false },
                    tooltip: { callbacks: { label: ctx => ctx.label + ': ' + ctx.parsed + ' sessions' } }
                }
            }
        });
    </script>
}
