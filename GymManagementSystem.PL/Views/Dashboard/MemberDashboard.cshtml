@model MemberDashboardViewModel
@{
    ViewData["Title"] = "My Dashboard";
}

<div class="welcome-header">
    <h1>Welcome, <span class="text-gradient">@Model.MemberName</span></h1>
    <p>Member since @Model.JoinDate.ToString("MMM yyyy")</p>
</div>

<div class="row g-4">
    <div class="col-lg-4">
        <div class="stat-card h-100">
            <div class="stat-icon primary">
                <i class="bi bi-card-text"></i>
            </div>
            <h5 class="fw-bold mb-3">Membership</h5>
            @if (Model.HasActiveMembership)
            {
                <span class="badge bg-success mb-2">Active</span>
                <h4 class="fw-bold" style="color: var(--primary);">@Model.PlanName</h4>
                <p class="text-muted small mb-1">
                    <i class="bi bi-calendar-check me-1"></i>@Model.MembershipStart?.ToString("dd MMM yyyy") - @Model.MembershipEnd?.ToString("dd MMM yyyy")
                </p>
                <div class="mt-3">
                    <div class="d-flex justify-content-between mb-1 small">
                        <span class="text-muted">Days Remaining</span>
                        <span class="fw-bold @(Model.DaysRemaining <= 7 ? "" : "")" style="color: @(Model.DaysRemaining <= 7 ? "var(--danger)" : "var(--success)")">@Model.DaysRemaining</span>
                    </div>
                    <div class="progress">
                        <div class="progress-bar" style="width:@Math.Min(100, Model.DaysRemaining * 100 / 365)%"></div>
                    </div>
                </div>
            }
            else
            {
                <div class="text-center py-3">
                    <i class="bi bi-exclamation-circle" style="font-size: 2.5rem; color: var(--text-muted);"></i>
                    <p class="text-muted mt-2 small">No active membership</p>
                    <a asp-controller="Plans" asp-action="Index" class="btn btn-sm btn-gradient">Browse Plans</a>
                </div>
            }
        </div>
    </div>

    <div class="col-lg-4">
        <div class="stat-card h-100">
            <div class="stat-icon secondary">
                <i class="bi bi-heart-pulse"></i>
            </div>
            <h5 class="fw-bold mb-3">Health Stats</h5>
            @if (Model.Bmi.HasValue)
            {
                <div class="text-center">
                    <canvas id="bmiChart" width="140" height="140" style="max-width:140px;margin:0 auto"></canvas>
                            <h3 class="fw-bold mt-2 mb-0" style="font-size: 1.5rem;">@Model.Bmi.Value.ToString("F1", null) <small class="text-muted" style="font-size:0.75rem;">BMI</small></h3>
                    <span class="badge bg-info">@Model.BmiCategory</span>
                </div>
                <div class="row mt-3 g-2">
                    <div class="col-6">
                        <div class="detail-group text-center p-2">
                            <div class="detail-label">Weight</div>
                            <div class="fw-bold">@Model.Weight kg</div>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="detail-group text-center p-2">
                            <div class="detail-label">Height</div>
                            <div class="fw-bold">@Model.Height cm</div>
                        </div>
                    </div>
                </div>
            }
            else
            {
                <div class="text-center py-3">
                    <i class="bi bi-clipboard-data" style="font-size: 2.5rem; color: var(--text-muted);"></i>
                    <p class="text-muted mt-2 small">No health data recorded</p>
                </div>
            }
        </div>
    </div>

    <div class="col-lg-4">
        <div class="stat-card h-100">
            <div class="stat-icon success">
                <i class="bi bi-bar-chart"></i>
            </div>
            <h5 class="fw-bold mb-3">Attendance</h5>
            <div class="text-center">
                <canvas id="attendanceChart" width="140" height="140" style="max-width:140px;margin:0 auto"></canvas>
                <div class="row mt-3 g-2">
                    <div class="col-6">
                        <div class="detail-group text-center p-2">
                            <div class="detail-label">Booked</div>
                            <div class="fw-bold">@Model.TotalBooked</div>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="detail-group text-center p-2">
                            <div class="detail-label">Attended</div>
                            <div class="fw-bold" style="color: var(--success);">@Model.TotalAttended</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="premium-card mt-4">
    <div class="premium-card-header">
        <h5 class="mb-0"><i class="bi bi-calendar-event me-2" style="color: var(--primary);"></i>Upcoming Sessions</h5>
        <a asp-controller="Bookings" asp-action="Index" class="btn btn-sm btn-gradient">Book a Session</a>
    </div>
    <div class="premium-card-body">
        @if (Model.UpcomingSessions.Count == 0)
        {
            <div class="empty-state">
                <div class="empty-icon"><i class="bi bi-calendar-plus"></i></div>
                <h5>No upcoming sessions</h5>
                <p class="small">Book your first session to get started.</p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table align-middle mb-0">
                    <thead>
                        <tr>
                            <th>Session</th>
                            <th>Date & Time</th>
                            <th>Trainer</th>
                            <th>Category</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var session in Model.UpcomingSessions)
                        {
                            <tr>
                                <td class="fw-semibold">@session.SessionName</td>
                                <td>@session.ScheduleTime.ToString("dd MMM yyyy HH:mm")</td>
                                <td>@session.TrainerName</td>
                                <td><span class="badge bg-primary">@session.CategoryName</span></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@section Scripts
{
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <script>
        const isDark = document.documentElement.getAttribute('data-theme') === 'dark';
        const textColor = isDark ? '#f5f5f4' : '#292524';

        @if (Model.Bmi.HasValue)
        {
            <text>
            new Chart(document.getElementById('bmiChart'), {
                type: 'doughnut',
                data: {
                    labels: ['BMI', 'Remaining'],
                    datasets: [{
                        data: [@Model.Bmi.Value.ToString("F1", null), Math.Max(0, 40 - (double)@Model.Bmi.Value)],
                        backgroundColor: ['#a855f7', isDark ? '#292524' : '#f5f5f0'],
                        borderWidth: 0
                    }]
                },
                options: {
                    cutout: '78%',
                    responsive: false,
                    plugins: { legend: { display: false }, tooltip: { enabled: false } }
                }
            });
            </text>
        }

        new Chart(document.getElementById('attendanceChart'), {
            type: 'doughnut',
            data: {
                labels: ['Attended', 'Missed'],
                datasets: [{
                    data: [@Model.TotalAttended, Math.max(0, @Model.TotalBooked - @Model.TotalAttended)],
                    backgroundColor: ['#22c55e', isDark ? '#292524' : '#f5f5f0'],
                    borderWidth: 0
                }]
            },
            options: {
                cutout: '73%',
                responsive: false,
                plugins: {
                    legend: { display: false },
                    tooltip: { callbacks: { label: ctx => ctx.label + ': ' + ctx.parsed + ' sessions' } }
                }
            }
        });
    </script>
}
