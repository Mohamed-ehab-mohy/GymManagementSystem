@model DashboardStatsDto
@{
    ViewData["Title"] = "Dashboard";
}

<div class="welcome-header">
    <h1>Gym <span class="text-gradient">Dashboard</span></h1>
    <p>@DateTime.Now.ToString("dddd, MMMM dd, yyyy")</p>
</div>

<div class="row g-4">
    <div class="col-md-4 col-lg-3">
        <div class="stat-card">
            <div class="stat-icon" style="background: rgba(249,115,22,0.1); color: var(--primary);">
                <i class="bi bi-people-fill"></i>
            </div>
            <div class="stat-value">@Model.TotalMembers</div>
            <div class="stat-label">Total Members</div>
        </div>
    </div>
    <div class="col-md-4 col-lg-3">
        <div class="stat-card">
            <div class="stat-icon" style="background: rgba(168,85,247,0.1); color: var(--secondary);">
                <i class="bi bi-person-badge-fill"></i>
            </div>
            <div class="stat-value">@Model.TotalTrainers</div>
            <div class="stat-label">Total Trainers</div>
        </div>
    </div>
    <div class="col-md-4 col-lg-3">
        <div class="stat-card">
            <div class="stat-icon" style="background: rgba(34,197,94,0.1); color: var(--success);">
                <i class="bi bi-card-checklist"></i>
            </div>
            <div class="stat-value">@Model.ActivePlans</div>
            <div class="stat-label">Active Plans</div>
        </div>
    </div>
    <div class="col-md-4 col-lg-3">
        <div class="stat-card">
            <div class="stat-icon" style="background: rgba(6,182,212,0.1); color: var(--accent);">
                <i class="bi bi-calendar-event-fill"></i>
            </div>
            <div class="stat-value">@Model.TodaySessions</div>
            <div class="stat-label">Today's Sessions</div>
        </div>
    </div>
    <div class="col-md-4 col-lg-3">
        <div class="stat-card">
            <div class="stat-icon" style="background: rgba(34,197,94,0.1); color: var(--success);">
                <i class="bi bi-check-circle-fill"></i>
            </div>
            <div class="stat-value">@Model.TodayAttendance</div>
            <div class="stat-label">Today's Attendance</div>
        </div>
    </div>
    <div class="col-md-4 col-lg-3">
        <div class="stat-card">
            <div class="stat-icon" style="background: rgba(239,68,68,0.1); color: var(--danger);">
                <i class="bi bi-exclamation-triangle-fill"></i>
            </div>
            <div class="stat-value">@Model.ExpiringMemberships</div>
            <div class="stat-label">Expiring (&lt; 7 days)</div>
        </div>
    </div>
    <div class="col-md-4 col-lg-3">
        <div class="stat-card">
            <div class="stat-icon" style="background: rgba(168,162,158,0.1); color: var(--text-muted);">
                <i class="bi bi-layers-fill"></i>
            </div>
            <div class="stat-value">@Model.TotalPlans</div>
            <div class="stat-label">Total Plans</div>
        </div>
    </div>
</div>

<hr class="section-divider" />

<div class="premium-card">
    <div class="premium-card-header">
        <h5 class="mb-0"><i class="bi bi-lightning-charge-fill me-2" style="color: var(--primary);"></i>Quick Actions</h5>
    </div>
    <div class="premium-card-body">
        <div class="d-flex flex-wrap gap-3">
            <a asp-controller="Members" asp-action="Create" class="btn btn-gradient"><i class="bi bi-person-plus"></i>Add Member</a>
            <a asp-controller="Trainers" asp-action="Create" class="btn btn-glass"><i class="bi bi-person-badge"></i>Add Trainer</a>
            <a asp-controller="Plans" asp-action="Create" class="btn btn-glass"><i class="bi bi-plus-circle"></i>Add Plan</a>
            <a asp-controller="ClassSessions" asp-action="Create" class="btn btn-glass"><i class="bi bi-calendar-plus"></i>Create Session</a>
            <a asp-controller="Attendance" asp-action="Scan" class="btn btn-glass"><i class="bi bi-qr-code-scan"></i>Scan QR</a>
        </div>
    </div>
</div>
