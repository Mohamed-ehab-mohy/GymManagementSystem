@{
    ViewData["Title"] = "DI Lifetimes Demo";

    string SameLabel(bool same) => same ? "✅ SAME" : "❌ DIFFERENT";
    string SameColor(bool same) => same ? "#22c55e" : "#ef4444";
}

<style>
    .lifetime-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
        gap: 1.5rem;
        margin-top: 2rem;
    }

    .lifetime-card {
        background: var(--bg-secondary);
        border: 1px solid var(--border-color);
        border-radius: 16px;
        padding: 1.75rem;
        position: relative;
        overflow: hidden;
        transition: transform .2s, box-shadow .2s;
    }

    .lifetime-card:hover {
        transform: translateY(-3px);
        box-shadow: 0 12px 30px rgba(0,0,0,.35);
    }

    .lifetime-card::before {
        content: '';
        position: absolute;
        top: 0; left: 0; right: 0;
        height: 3px;
        background: var(--accent);
    }

    .lifetime-badge {
        display: inline-block;
        background: var(--accent-light);
        color: var(--accent);
        font-size: .72rem;
        font-weight: 700;
        letter-spacing: 1px;
        text-transform: uppercase;
        padding: .25rem .75rem;
        border-radius: 999px;
        margin-bottom: 1rem;
    }

    .lifetime-title {
        font-size: 1.3rem;
        font-weight: 800;
        margin-bottom: .4rem;
    }

    .lifetime-description {
        font-size: .85rem;
        color: var(--text-secondary);
        margin-bottom: 1.25rem;
        line-height: 1.6;
    }

    .guid-row {
        background: rgba(255,255,255,.04);
        border: 1px solid var(--border-color, #2d2d4e);
        border-radius: 8px;
        padding: .6rem .9rem;
        margin-bottom: .5rem;
        font-family: monospace;
        font-size: .78rem;
    }

    .guid-label {
        font-size: .7rem;
        color: var(--text-secondary);
        font-family: sans-serif;
        margin-bottom: .15rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: .5px;
    }

    .guid-value {
        word-break: break-all;
    }

    .result-badge {
        display: flex;
        align-items: center;
        gap: .4rem;
        margin-top: 1rem;
        font-weight: 700;
        font-size: .9rem;
    }

    .refresh-hint {
        background: rgba(99,102,241,.08);
        border: 1px solid rgba(99,102,241,.2);
        border-radius: 12px;
        padding: 1rem 1.5rem;
        margin-top: 2.5rem;
        font-size: .9rem;
        color: var(--text-secondary);
    }

    .refresh-hint strong { color: #a5b4fc; }
</style>

<div class="container py-4">
    <header class="mb-5">
        <h2 class="display-5 fw-bold mb-2">
            DI <span class="text-gradient">Lifetimes</span> Demo
        </h2>
        <p class="text-secondary fs-5 mb-0">
            Each service is resolved <strong>twice per request</strong> — compare the Guids to understand when a new instance is created.
        </p>
    </header>

    <div class="lifetime-grid">

        {{!-- ── SCOPED ─────────────────────────────────────────────────────────── --}}
        <div class="lifetime-card" style="--accent:#6366f1; --accent-light:rgba(99,102,241,.12)">
            <span class="lifetime-badge">Scoped</span>
            <div class="lifetime-title">AddScoped&lt;T&gt;</div>
            <p class="lifetime-description">
                One instance per HTTP request. Both injections within the same request share the same object.
                A fresh instance is created for the next request.
            </p>

            <div class="guid-row">
                <div class="guid-label">Instance #1</div>
                <div class="guid-value">@ViewBag.Scoped1</div>
            </div>
            <div class="guid-row">
                <div class="guid-label">Instance #2</div>
                <div class="guid-value">@ViewBag.Scoped2</div>
            </div>

            <div class="result-badge" style="color: @SameColor((bool)ViewBag.ScopedSame)">
                @SameLabel((bool)ViewBag.ScopedSame)
                <span style="font-size:.8rem; font-weight:400; color:var(--text-secondary)">
                    — expected: SAME within one request
                </span>
            </div>
        </div>

        {{!-- ── TRANSIENT ───────────────────────────────────────────────────────── --}}
        <div class="lifetime-card" style="--accent:#f59e0b; --accent-light:rgba(245,158,11,.12)">
            <span class="lifetime-badge">Transient</span>
            <div class="lifetime-title">AddTransient&lt;T&gt;</div>
            <p class="lifetime-description">
                A brand-new instance every single time the service is resolved — even twice in the same request.
                Use for lightweight, stateless services.
            </p>

            <div class="guid-row">
                <div class="guid-label">Instance #1</div>
                <div class="guid-value">@ViewBag.Transient1</div>
            </div>
            <div class="guid-row">
                <div class="guid-label">Instance #2</div>
                <div class="guid-value">@ViewBag.Transient2</div>
            </div>

            <div class="result-badge" style="color: @SameColor((bool)ViewBag.TransientSame)">
                @SameLabel((bool)ViewBag.TransientSame)
                <span style="font-size:.8rem; font-weight:400; color:var(--text-secondary)">
                    — expected: DIFFERENT every time
                </span>
            </div>
        </div>

        {{!-- ── SINGLETON ───────────────────────────────────────────────────────── --}}
        <div class="lifetime-card" style="--accent:#22c55e; --accent-light:rgba(34,197,94,.12)">
            <span class="lifetime-badge">Singleton</span>
            <div class="lifetime-title">AddSingleton&lt;T&gt;</div>
            <p class="lifetime-description">
                One instance for the entire application lifetime. The Guid never changes — not between
                injections, not between requests, not until the app restarts.
            </p>

            <div class="guid-row">
                <div class="guid-label">Instance #1</div>
                <div class="guid-value">@ViewBag.Singleton1</div>
            </div>
            <div class="guid-row">
                <div class="guid-label">Instance #2</div>
                <div class="guid-value">@ViewBag.Singleton2</div>
            </div>

            <div class="result-badge" style="color: @SameColor((bool)ViewBag.SingletonSame)">
                @SameLabel((bool)ViewBag.SingletonSame)
                <span style="font-size:.8rem; font-weight:400; color:var(--text-secondary)">
                    — expected: SAME always (even across requests)
                </span>
            </div>
        </div>

    </div>

    <div class="refresh-hint">
        <i class="bi bi-arrow-clockwise me-2"></i>
        <strong>Tip:</strong> Press <kbd>F5</kbd> to refresh this page.
        Watch how <strong style="color:#6366f1">Scoped</strong> gets a new Guid on each request,
        <strong style="color:#f59e0b">Transient</strong> always shows two different Guids,
        and <strong style="color:#22c55e">Singleton</strong> keeps the same Guid until the app restarts.
    </div>
</div>
