@{
    ViewData["Title"] = "Scan QR";
}

<div class="mb-6 text-center">
    <div class="w-14 h-14 rounded-xl bg-primary-100 dark:bg-primary-900/30 flex items-center justify-center text-primary-600 dark:text-primary-400 text-2xl mx-auto mb-3">
        <i class="bi bi-qr-code-scan"></i>
    </div>
    <h1 class="page-title">Check-In Scanner</h1>
    <p class="page-subtitle mt-1">Point the camera at the member's booking QR code.</p>
</div>

<div class="max-w-xl mx-auto">
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="mb-4 rounded-lg bg-emerald-50 dark:bg-emerald-900/20 p-4 border border-emerald-200 dark:border-emerald-800 text-emerald-700 dark:text-emerald-400 flex items-start gap-3 text-sm">
            <i class="bi bi-check-circle-fill mt-0.5"></i>
            <div>@TempData["SuccessMessage"]</div>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="mb-4 rounded-lg bg-red-50 dark:bg-red-900/20 p-4 border border-red-200 dark:border-red-800 text-red-700 dark:text-red-400 flex items-start gap-3 text-sm">
            <i class="bi bi-exclamation-triangle-fill mt-0.5"></i>
            <div>@TempData["ErrorMessage"]</div>
        </div>
    }
    @if (TempData["WarningMessage"] != null)
    {
        <div class="mb-4 rounded-lg bg-amber-50 dark:bg-amber-900/20 p-4 border border-amber-200 dark:border-amber-800 text-amber-700 dark:text-amber-400 flex items-start gap-3 text-sm">
            <i class="bi bi-info-circle-fill mt-0.5"></i>
            <div>@TempData["WarningMessage"]</div>
        </div>
    }

    <div class="page-card p-2 mb-4">
        <div id="qr-reader" class="w-full bg-black rounded-lg overflow-hidden" style="min-height: 280px;"></div>
    </div>

    <form id="checkInForm" asp-action="CheckIn" method="post" class="hidden">
        <input type="hidden" name="payload" id="payloadInput" />
        @Html.AntiForgeryToken()
    </form>

    <a asp-controller="Members" asp-action="Index" class="btn-outline w-full justify-center py-2.5">
        Cancel and Return
    </a>
</div>

@section Scripts {
    <script src="https://unpkg.com/html5-qrcode" type="text/javascript"></script>

    <script>
        function onScanSuccess(decodedText, decodedResult) {
            html5QrcodeScanner.clear();
            document.getElementById('payloadInput').value = decodedText;
            document.getElementById('checkInForm').submit();
        }

        function onScanFailure(error) { }

        let html5QrcodeScanner = new Html5QrcodeScanner(
            "qr-reader",
            { fps: 15, qrbox: { width: 250, height: 250 }, rememberLastUsedCamera: true },
            false);

        html5QrcodeScanner.render(onScanSuccess, onScanFailure);

        document.addEventListener('DOMContentLoaded', () => {
            const observer = new MutationObserver(() => {
                const btn = document.getElementById('html5-qrcode-button-camera-permission');
                if (btn) btn.className = 'btn-primary px-4 py-2 text-sm mt-4';
                const startBtn = document.getElementById('html5-qrcode-button-camera-start');
                if (startBtn) startBtn.className = 'btn-primary px-4 py-2 text-sm m-2';
                const stopBtn = document.getElementById('html5-qrcode-button-camera-stop');
                if (stopBtn) stopBtn.className = 'btn-outline px-4 py-2 text-sm m-2';
                const select = document.getElementById('html5-qrcode-select-camera');
                if (select) select.className = 'form-select w-auto inline-block m-2';
            });

            const qrReader = document.getElementById('qr-reader');
            if (qrReader) observer.observe(qrReader, { childList: true, subtree: true });
        });
    </script>
}
