@model GymManagementSystem.PL.ViewModels.AttendanceQrViewModel

@{
    ViewData["Title"] = "My QR Code";
}

<div class="flex items-center justify-center py-8">
    <div class="page-card w-full max-w-md p-8">
        <div class="text-center mb-6">
            <div class="w-14 h-14 rounded-xl bg-primary-100 dark:bg-primary-900/30 flex items-center justify-center text-primary-600 dark:text-primary-400 text-2xl mx-auto mb-3">
                <i class="bi bi-qr-code"></i>
            </div>
            <h3 class="text-xl font-bold text-slate-900 dark:text-white mb-1">Attendance QR Code</h3>
            <p class="text-sm text-slate-500 dark:text-slate-400">Show this at the reception desk to check in.</p>
        </div>

        <div class="p-4 bg-white rounded-xl mb-6 max-w-[260px] mx-auto border border-slate-200">
            <img src="@Model.QrCodeBase64" alt="Check-In QR Code" class="w-full h-auto aspect-square object-contain" />
        </div>

        <div class="border-t border-slate-200 dark:border-slate-700 pt-5 mb-6 space-y-3">
            <div class="flex justify-between items-center">
                <span class="text-xs font-medium text-slate-500 dark:text-slate-400 uppercase tracking-wider">Member</span>
                <span class="text-sm font-semibold text-slate-900 dark:text-white">@Model.MemberName</span>
            </div>
            <div class="flex justify-between items-center">
                <span class="text-xs font-medium text-slate-500 dark:text-slate-400 uppercase tracking-wider">Session</span>
                <span class="text-sm font-semibold text-slate-900 dark:text-white">@Model.SessionName</span>
            </div>
            <div class="flex justify-between items-center">
                <span class="text-xs font-medium text-slate-500 dark:text-slate-400 uppercase tracking-wider">Date</span>
                <span class="text-sm text-slate-700 dark:text-slate-300">@Model.SessionDate.ToString("dd MMM yyyy - hh:mm tt")</span>
            </div>
        </div>

        <div class="flex flex-col gap-3">
            <button onclick="window.print();" class="btn-outline w-full justify-center py-2.5">
                <i class="bi bi-printer mr-1"></i> Print QR Code
            </button>
            <a asp-controller="Dashboard" asp-action="Index" class="btn-primary w-full justify-center py-2.5">
                Back to Dashboard
            </a>
        </div>
    </div>
</div>
