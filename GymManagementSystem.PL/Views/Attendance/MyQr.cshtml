@model GymManagementSystem.PL.ViewModels.AttendanceQrViewModel

@{
    ViewData["Title"] = "My Check-In QR Code";
}

<div class="container mt-5 d-flex justify-content-center">
    <div class="premium-card p-4 text-center border-0 rounded-4" style="max-width: 450px;">
        <h3 class="fw-bold mb-3 text-primary">Attendance QR Code</h3>
        <p class="text-muted mb-4">Show this QR code to the reception desk to check in.</p>

        <div class="p-3 bg-white rounded-3 shadow-sm d-inline-block mx-auto mb-4">
            <img src="@Model.QrCodeBase64" alt="Check-In QR Code" class="img-fluid" style="width: 250px; height: 250px;" />
        </div>

        <hr />

        <div class="text-start mt-3">
            <p class="mb-2"><strong>Member:</strong> @Model.MemberName</p>
            <p class="mb-2"><strong>Session:</strong> @Model.SessionName</p>
            <p class="mb-0"><strong>Date:</strong> @Model.SessionDate.ToString("dd MMM yyyy - hh:mm tt")</p>
        </div>

        <div class="mt-4">
            <a href="#" onclick="window.print();" class="btn btn-outline-secondary rounded-pill btn-sm w-100 mb-2">
                <i class="bi bi-printer"></i> Print QR Code
            </a>
            <a asp-controller="Members" asp-action="Index" class="btn btn-primary rounded-pill w-100">
                Back to Dashboard
            </a>
        </div>
    </div>
</div>
