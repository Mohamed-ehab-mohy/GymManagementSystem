@model GymManagementSystem.Models.Plan

<div class="card h-100 shadow-sm border-0 plan-card">
    <div class="card-header text-white text-center py-4 @(Model.IsActive ? "bg-primary-color" : "bg-secondary")">
        <h4 class="mb-0">@Model.Name</h4>
    </div>
    <div class="card-body d-flex flex-column">
        <div class="text-center mb-4">
            <div class="display-4 fw-bold text-primary-color">@Model.Price.ToString("G29")</div>
            <small class="text-muted">EGP</small>
        </div>

        <div class="mb-3">
            <p class="text-muted mb-2">
                <i class="bi bi-calendar-check text-primary-color me-2"></i>
                <strong>Duration:</strong> @Model.DurationDays Days
            </p>
            <p class="text-muted mb-3">
                <i class="bi bi-file-text text-primary-color me-2"></i>
                <strong>Description:</strong>
            </p>
            <p class="small">@Model.Description</p>
        </div>

        <div class="mt-auto">
            <div class="d-grid gap-2">
                <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline btn-sm">
                    <i class="bi bi-eye me-1"></i>View Details
                </a>

                <div class="d-flex gap-2">
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline btn-sm flex-fill">
                        <i class="bi bi-pencil me-1"></i>Edit
                    </a>
                    <form asp-action="ToggleActive" asp-route-id="@Model.Id" method="post" class="flex-fill">
                        <button type="submit" class="btn btn-outline btn-sm w-100 @(Model.IsActive ? "text-danger" : "text-success")">
                            @if (Model.IsActive)
                            {
                                <i class="bi bi-x-circle me-1"> Deactivate </i>
                            }
                            else
                            {
                                <i class="bi bi-check-circle me-1"> Activate </i>
                            }
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
